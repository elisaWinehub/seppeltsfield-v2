{%- doc -%}
  @param {string} id_suffix
  @param {number} [min]
  @param {number} [max]
{%- enddoc -%}

{%- liquid
  assign qty_id = 'Sf2Qty-' | append: id_suffix
  assign qty_min = min | default: 1
  assign qty_max = max | default: 999
-%}

<div class="sf2-qty" data-sf2-qty>
  <button type="button" aria-label="{{ 'products.product.quantity.decrease' | t: product: '' }}" data-qty-change="-1">−</button>
  <label class="visually-hidden" for="{{ qty_id }}">{{ 'products.product.quantity.input_label' | t: product: '' }}</label>
  <input
    id="{{ qty_id }}"
    type="number"
    name="quantity"
    value="{{ qty_min }}"
    min="{{ qty_min }}"
    max="{{ qty_max }}"
    inputmode="numeric"
  >
  <button type="button" aria-label="{{ 'products.product.quantity.increase' | t: product: '' }}" data-qty-change="1">+</button>
</div>
