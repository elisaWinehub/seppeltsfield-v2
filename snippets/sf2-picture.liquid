{%- doc -%}
  @param {image} image
  @param {image} [mobile_image]
  @param {string} [alt]
  @param {string} [class]
  @param {string} [sizes]
  @param {string} [loading]
  @param {string} [fit] - cover | contain
{%- enddoc -%}
{%- liquid
  assign img = image
  if mobile_image != blank
    assign img_m = mobile_image
  else
    assign img_m = image
  endif
  assign img_class = class | default: ''
  assign img_fit = fit | default: 'cover'
  assign img_loading = loading | default: 'lazy'
  assign img_sizes = sizes | default: '100vw'
  assign img_alt = alt | default: image.alt | default: ''
  assign img_style = 'object-fit: ' | append: img_fit
-%}
{%- if image != blank -%}
  <picture class="sf2-picture {{ img_class }}">
    {%- if mobile_image != blank -%}
      {{ img_m | image_url: width: 1200 | image_tag: class: 'sf2-picture__img sf2-picture__img--mobile', loading: img_loading, widths: '400,600,800,1000,1200', sizes: img_sizes, alt: img_alt, style: img_style }}
    {%- endif -%}
    {{ img | image_url: width: 2200 | image_tag: class: 'sf2-picture__img sf2-picture__img--desktop', loading: img_loading, widths: '600,900,1200,1600,2000,2200', sizes: img_sizes, alt: img_alt, style: img_style }}
  </picture>
{%- endif -%}
