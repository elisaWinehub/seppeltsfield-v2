{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: 'enquiry' -%}
{%- assign form_id = 'sf2-enquiry-' | append: section.id -%}

<section id="{{ anchor_id }}" class="sf2-enquiry sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-enquiry__grid">
    <div class="sf2-enquiry__copy">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    </div>
    <div class="sf2-enquiry__form-wrap">
      {%- form 'contact', id: form_id, class: 'sf2-enquiry__form' -%}
        {%- if form.posted_successfully? -%}
          <div class="sf2-enquiry__success" role="status" tabindex="-1">
            {{- 'blocks.contact_form.post_success' | t -}}
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="sf2-enquiry__error" role="alert" tabindex="-1">
              {{- 'blocks.contact_form.error_heading' | t -}}
              {%- if form.errors.messages.email -%} {{ form.errors.messages.email }}{%- endif -%}
            </div>
          {%- endif -%}

          <div class="sf2-enquiry__fields">
            <div class="sf2-enquiry__field">
              <label for="{{ form_id }}-name">First &amp; Last Name</label>
              <input id="{{ form_id }}-name" type="text" name="contact[name]" value="{{ form.name }}" autocomplete="name" required>
            </div>
            <div class="sf2-enquiry__field">
              <label for="{{ form_id }}-country">Country</label>
              {%- if localization.available_countries.size > 0 -%}
                <select id="{{ form_id }}-country" name="contact[Country]" autocomplete="country-name">
                  {%- for country in localization.available_countries -%}
                    <option value="{{ country.name }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>{{ country.name }}</option>
                  {%- endfor -%}
                </select>
              {%- else -%}
                <input id="{{ form_id }}-country" type="text" name="contact[Country]" autocomplete="country-name">
              {%- endif -%}
            </div>
            <div class="sf2-enquiry__field">
              <label for="{{ form_id }}-phone">Phone</label>
              <input id="{{ form_id }}-phone" type="tel" name="contact[phone]" value="{{ form.phone }}" autocomplete="tel">
            </div>
            <div class="sf2-enquiry__field">
              <label for="{{ form_id }}-email">Email</label>
              <input id="{{ form_id }}-email" type="email" name="contact[email]" value="{{ form.email }}" autocomplete="email" spellcheck="false" autocapitalize="off" required{% if form.errors contains 'email' %} aria-invalid="true"{% endif %}>
            </div>
            <div class="sf2-enquiry__field sf2-enquiry__field--full">
              <label for="{{ form_id }}-type">What is your enquiry related to?</label>
              <select id="{{ form_id }}-type" name="contact[Enquiry type]">
                {%- for block in section.blocks -%}
                  <option value="{{ block.settings.label }}">{{ block.settings.label }}</option>
                {%- endfor -%}
              </select>
            </div>
            <div class="sf2-enquiry__field sf2-enquiry__field--full">
              <label for="{{ form_id }}-message">Enquiry</label>
              <textarea id="{{ form_id }}-message" name="contact[body]" rows="6" required>{{ form.body }}</textarea>
            </div>
          </div>
          {% render 'sf2-button', preset: 'primary_dark', label: section.settings.submit_label, type: 'submit' %}
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Enquiry Form",
  "tag": "section",
  "class": "sf2-enquiry-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "enquiry" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Send an enquiry" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Write to the right team." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The enquiry type can route submissions to different recipients or Shopify Flow automations while keeping one consistent public form." },
    { "type": "text", "id": "submit_label", "label": "Submit button label", "default": "Submit Enquiry" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "ivory", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "enquiry_option",
      "name": "Enquiry type",
      "limit": 12,
      "settings": [
        { "type": "text", "id": "label", "label": "Option label", "default": "General enquiry" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SF2 Enquiry Form",
      "blocks": [
        { "type": "enquiry_option", "settings": { "label": "General enquiry" } },
        { "type": "enquiry_option", "settings": { "label": "Cellar Door & bookings" } },
        { "type": "enquiry_option", "settings": { "label": "Wine Club" } },
        { "type": "enquiry_option", "settings": { "label": "Online orders" } },
        { "type": "enquiry_option", "settings": { "label": "Weddings & private events" } },
        { "type": "enquiry_option", "settings": { "label": "Trade & distribution" } },
        { "type": "enquiry_option", "settings": { "label": "Stockists" } },
        { "type": "enquiry_option", "settings": { "label": "Media & partnerships" } }
      ]
    }
  ]
}
{% endschema %}
