<section class="spp-section" {% render 'section-style-attributes' %}>
  <div class="section section--{{ section.settings.section_width }}">
    <div class="spp-split-media-text {% if section.settings.image_side == 'left' %}is-reverse{% endif %}" data-reveal>
      <div class="spp-split-media-text__media">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', alt: section.settings.heading }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
      <div class="spp-split-media-text__content">
        {% if section.settings.show_seal %}
          <div class="spp-split-media-text__seal">{% render 'seal-mark' %}</div>
        {% endif %}
        {% if section.settings.eyebrow != blank %}{% render 'heading-eyebrow', text: section.settings.eyebrow %}{% endif %}
        <h2 style="margin-top:14px;">{{ section.settings.heading }}</h2>
        <div style="margin-top:14px;">{{ section.settings.body }}</div>
        {% if section.settings.button_label != blank %}
          <div style="margin-top:22px;">
            {% render 'button', link: section.settings.button_link, text: section.settings.button_label, style: section.settings.button_style %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .spp-split-media-text { display: grid; gap: 32px; grid-template-columns: minmax(0,1fr) minmax(0,1fr); align-items: center; }
  .spp-split-media-text.is-reverse .spp-split-media-text__media { order: 2; }
  .spp-split-media-text.is-reverse .spp-split-media-text__content { order: 1; }
  .spp-split-media-text__media img, .spp-split-media-text__media svg { width: 100%; display: block; object-fit: cover; aspect-ratio: 4/3; }
  .spp-split-media-text__seal { width: 120px; opacity: .4; margin-bottom: 10px; }
  @media (max-width: 989px) { .spp-split-media-text, .spp-split-media-text.is-reverse { grid-template-columns: 1fr; } .spp-split-media-text.is-reverse .spp-split-media-text__media { order: 1; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Split media text",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Estate" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A setting like no other" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>A heritage estate for tastings, dining and celebrations in the Barossa.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_side", "label": "Image side", "options": [{ "value":"left","label":"Left" }, { "value":"right","label":"Right" }], "default": "right" },
    { "type": "checkbox", "id": "show_seal", "label": "Show seal watermark", "default": false },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Learn more" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [{ "value":"primary","label":"Solid" },{ "value":"outline","label":"Outline" },{ "value":"light","label":"Light (for dark/image backgrounds)" }], "default": "outline" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "padding_top", "label": "Top padding", "options": [{"value":"sm","label":"Small"},{"value":"md","label":"Medium"},{"value":"lg","label":"Large"},{"value":"xl","label":"Extra large"}], "default": "lg" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom padding", "options": [{"value":"sm","label":"Small"},{"value":"md","label":"Medium"},{"value":"lg","label":"Large"},{"value":"xl","label":"Extra large"}], "default": "lg" },
    { "type": "header", "content": "Background" },
    { "type": "select", "id": "background_type", "label": "Background type", "options": [{"value":"color","label":"Color"},{"value":"image","label":"Image"}], "default": "color" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#F7F6F3" },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Image overlay darkness", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 0 },
    { "type": "header", "content": "Heading" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#12141A" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 24, "max": 96, "step": 2, "unit": "px", "default": 40 },
    { "type": "header", "content": "Body text" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#565B63" },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{"value":"page-width","label":"Page"},{"value":"full-width","label":"Full"}], "default": "page-width" }
  ],
  "presets": [{ "name": "Split media text" }]
}
{% endschema %}
