{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-home.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}

<section id="discover" class="sf2-intro sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-intro__grid">
    <div class="sf2-intro__copy">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<div>{{ section.settings.body }}</div>{%- endif -%}
      {%- if section.settings.link_label != blank -%}
        {% render 'sf2-button', preset: 'text_link', label: section.settings.link_label, url: section.settings.link_url %}
      {%- endif -%}
      <div class="sf2-intro__seal">
        {{ section.settings.seal_line_1 }}<br>{{ section.settings.seal_line_2 }}
      </div>
    </div>
    <div class="sf2-intro__stack">
      {%- if section.settings.main_image != blank -%}
        <div class="sf2-intro__main">
          {% render 'sf2-picture', image: section.settings.main_image, sizes: '(min-width: 990px) 44vw, 100vw' %}
        </div>
      {%- endif -%}
      {%- if section.settings.secondary_image != blank -%}
        <div class="sf2-intro__small">
          {% render 'sf2-picture', image: section.settings.secondary_image, sizes: '(min-width: 990px) 28vw, 80vw' %}
        </div>
      {%- endif -%}
      <div class="sf2-intro__label">
        {% render 'sf2-eyebrow', text: section.settings.label_eyebrow, brand: true %}
        <strong>{{ section.settings.label_heading }}</strong>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Editorial Intro",
  "tag": "section",
  "class": "sf2-intro-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The house of Seppeltsfield" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A grand estate with a living soul." },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Enter the 175-year story" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "text", "id": "seal_line_1", "label": "Seal line 1", "default": "Est. 1851" },
    { "type": "text", "id": "seal_line_2", "label": "Seal line 2", "default": "Barossa Valley" },
    { "type": "image_picker", "id": "main_image", "label": "Main image" },
    { "type": "image_picker", "id": "secondary_image", "label": "Secondary image" },
    { "type": "text", "id": "label_eyebrow", "label": "Label eyebrow", "default": "Seven generations" },
    { "type": "text", "id": "label_heading", "label": "Label heading", "default": "Heritage that remains in motion." },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "ivory", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }, { "value": "editorial", "label": "Editorial" }
    ]}
  ],
  "presets": [{ "name": "SF2 Editorial Intro" }]
}
{% endschema %}
