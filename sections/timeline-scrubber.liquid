<section class="spp-section" {% render 'section-style-attributes' %}>
  <div class="section section--{{ section.settings.section_width }}" data-timeline-{{ section.id }}>
    <div class="spp-scrubber-nav">
      {% for block in section.blocks %}
        <button type="button" class="{% if forloop.first %}is-active{% endif %}" data-target="{{ block.id }}">{{ block.settings.year }}</button>
      {% endfor %}
    </div>
    {% for block in section.blocks %}
      <div class="spp-scrubber-panel {% if forloop.first %}is-active{% endif %}" data-panel="{{ block.id }}">
        <h3>{{ block.settings.heading }}</h3>
        <p>{{ block.settings.text }}</p>
      </div>
    {% endfor %}
  </div>
</section>

<script>
  (() => {
    const root = document.querySelector("[data-timeline-{{ section.id }}]");
    if (!root) return;
    const buttons = root.querySelectorAll(".spp-scrubber-nav button");
    const panels = root.querySelectorAll(".spp-scrubber-panel");
    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        buttons.forEach((b) => b.classList.remove("is-active"));
        panels.forEach((p) => p.classList.remove("is-active"));
        button.classList.add("is-active");
        root.querySelector(`[data-panel="${button.dataset.target}"]`)?.classList.add("is-active");
      });
    });
  })();
</script>

{% stylesheet %}
  .spp-scrubber-nav { display:flex; justify-content: space-between; border-top:1px solid var(--spp-line); padding-top: 10px; gap: 12px; flex-wrap: wrap; }
  .spp-scrubber-nav button { border:0; background:none; color:var(--spp-text-color); }
  .spp-scrubber-nav button.is-active { color:var(--spp-heading-color); }
  .spp-scrubber-panel { display:none; margin-top:28px; }
  .spp-scrubber-panel.is-active { display:block; }
{% endstylesheet %}

{% schema %}
{
  "name": "Timeline scrubber",
  "blocks": [
    { "type": "event", "name": "Event", "settings": [
      { "type": "text", "id": "year", "label": "Year", "default": "1851" },
      { "type": "text", "id": "heading", "label": "Heading", "default": "Seppeltsfield founded" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "The Seppelt family established the estate in the Barossa Valley." }
    ] }
  ],
  "settings": [
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f1f2f1" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#0e1012" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#53575b" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 22, "max": 56, "step": 2, "unit": "px", "default": 34 },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 20, "step": 1, "unit": "px", "default": 16 },
    { "type": "select", "id": "padding_top", "label": "Top spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "lg" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "lg" },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{ "value": "page-width", "label": "Page" }, { "value": "full-width", "label": "Full" }], "default": "page-width" }
  ],
  "presets": [{ "name": "Timeline scrubber", "blocks": [{ "type": "event" }, { "type": "event" }, { "type": "event" }] }]
}
{% endschema %}
