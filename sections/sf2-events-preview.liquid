{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: 'events' -%}

<section id="{{ anchor_id }}" class="sf2-events sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-events__grid">
    <div class="sf2-events__copy">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
      {%- if section.settings.link_label != blank -%}
        {% render 'sf2-button', preset: 'text_link', label: section.settings.link_label, url: section.settings.link_url %}
      {%- endif -%}
    </div>
    <div class="sf2-events__list">
      {%- for block in section.blocks -%}
        <a class="sf2-events__item" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          <div class="sf2-events__date">
            <div><strong>{{ block.settings.day }}</strong><span>{{ block.settings.month }}</span></div>
          </div>
          <div><b>{{ block.settings.title }}</b>{%- if block.settings.subtitle != blank -%}<small>{{ block.settings.subtitle }}</small>{%- endif -%}</div>
          {% render 'sf2-icon', icon: 'arrow-right' %}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Events Preview",
  "tag": "section",
  "class": "sf2-events-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "events" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What's on" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Events worth planning around." },
    { "type": "textarea", "id": "body", "label": "Body" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View the full calendar" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "light", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "event",
      "name": "Event",
      "settings": [
        { "type": "text", "id": "day", "label": "Day", "default": "21" },
        { "type": "text", "id": "month", "label": "Month", "default": "AUG" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Events Preview" }]
}
{% endschema %}
