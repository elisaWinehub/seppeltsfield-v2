{{ 'sf-about.css' | asset_url | stylesheet_tag }}
<section id="SfAboutTimeline-{{ section.id }}" class="sf-about-timeline" style="--sf-bg:{{ section.settings.background_color }};--sf-head:{{ section.settings.heading_color }};--sf-text:{{ section.settings.text_color }};--sf-muted:{{ section.settings.muted_color }};--sf-accent:{{ section.settings.accent_color }};--sf-pad-top-d:{{ section.settings.padding_top_desktop }}px;--sf-pad-bottom-d:{{ section.settings.padding_bottom_desktop }}px;--sf-pad-top-m:{{ section.settings.padding_top_mobile }}px;--sf-pad-bottom-m:{{ section.settings.padding_bottom_mobile }}px;">
  <div class="sf-about-container">
    <div class="sf-about-timeline__head">
      <div>
        {% if section.settings.eyebrow != blank %}<p class="sf-about-timeline__eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
        {% if section.settings.heading != blank %}<h2 class="sf-about-timeline__heading">{{ section.settings.heading | newline_to_br }}</h2>{% endif %}
        {% if section.settings.copy != blank %}<p class="sf-about-timeline__copy">{{ section.settings.copy }}</p>{% endif %}
      </div>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}<a class="sf-about-link" href="{{ section.settings.link_url }}">{{ section.settings.link_label }}</a>{% endif %}
    </div>
    <div class="sf-about-timeline__track">
      {% for block in section.blocks %}
        {%- assign mobile_image = block.settings.mobile_image | default: block.settings.image -%}
        <article class="sf-about-timeline__item{% if block.settings.highlighted %} is-highlighted{% endif %}" {{ block.shopify_attributes }}>
          <p class="sf-about-timeline__year">{{ block.settings.year }}</p>
          <h3>{{ block.settings.heading }}</h3>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag: class: 'sf-about-timeline__img sf-about-timeline__img--desktop', loading: 'lazy', widths: '375,550,750,800', sizes: '(min-width:990px) 16vw, 68vw', alt: block.settings.heading }}
            {{ mobile_image | image_url: width: 800 | image_tag: class: 'sf-about-timeline__img sf-about-timeline__img--mobile', loading: 'lazy', widths: '375,550,750,800', sizes: '(max-width:989px) 68vw, 1px', alt: block.settings.heading }}
          {% endif %}
          {% if block.settings.description != blank %}<p>{{ block.settings.description }}</p>{% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% stylesheet %}
.sf-about-timeline{background:var(--sf-bg);padding-top:var(--sf-pad-top-d);padding-bottom:var(--sf-pad-bottom-d)}.sf-about-timeline__head{display:flex;justify-content:space-between;gap:1rem;color:var(--sf-text)}.sf-about-timeline__eyebrow{margin:0;color:var(--sf-accent);text-transform:uppercase;letter-spacing:.14em;font-size:.75rem}.sf-about-timeline__heading{margin:.55rem 0 0;color:var(--sf-head);font-size:clamp(1.7rem,2.7vw,3rem);line-height:1.04}.sf-about-timeline__copy{margin:.8rem 0 0;max-width:52ch}.sf-about-timeline__track{margin-top:1rem;display:grid;grid-auto-flow:column;grid-auto-columns:minmax(11rem,1fr);gap:.8rem;overflow-x:auto;scroll-snap-type:x mandatory}.sf-about-timeline__item{scroll-snap-align:start;padding:.7rem;border-top:1px solid color-mix(in srgb,var(--sf-text) 28%,transparent)}.sf-about-timeline__item.is-highlighted{border-color:var(--sf-accent)}.sf-about-timeline__year{margin:0;color:var(--sf-head);font-size:1.1rem}.sf-about-timeline__item h3{margin:.4rem 0 0;color:var(--sf-text);font-size:.8rem}.sf-about-timeline__img{width:100%;height:120px;object-fit:cover;margin:.5rem 0}.sf-about-timeline__img--mobile{display:none}.sf-about-timeline__item p{margin:.35rem 0 0;color:var(--sf-muted);font-size:.82rem}@media(max-width:989px){.sf-about-timeline{padding-top:var(--sf-pad-top-m);padding-bottom:var(--sf-pad-bottom-m)}.sf-about-timeline__head{flex-direction:column;align-items:flex-start}.sf-about-timeline__img--desktop{display:none}.sf-about-timeline__img--mobile{display:block}}
{% endstylesheet %}
{% schema %}
{"name":"SF About Time","tag":"section","class":"sf-about-section","max_blocks":10,"settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"OUR HERITAGE"},{"type":"textarea","id":"heading","label":"Heading","default":"A legacy in\nevery generation"},{"type":"textarea","id":"copy","label":"Copy","default":"From the first vines planted in 1851 to the Centennial Cellar, the world's longest continuously operating solera system."},{"type":"text","id":"link_label","label":"Link label","default":"EXPLORE TIMELINE"},{"type":"url","id":"link_url","label":"Link URL"},{"type":"color","id":"background_color","label":"Background","default":"#050505"},{"type":"color","id":"heading_color","label":"Heading color","default":"#FFFFFF"},{"type":"color","id":"text_color","label":"Body color","default":"#F4F1EA"},{"type":"color","id":"muted_color","label":"Muted color","default":"#D6CEC1"},{"type":"color","id":"accent_color","label":"Accent color","default":"#47A8DF"},{"type":"range","id":"padding_top_desktop","label":"Desktop padding top","min":0,"max":200,"step":4,"unit":"px","default":28},{"type":"range","id":"padding_bottom_desktop","label":"Desktop padding bottom","min":0,"max":200,"step":4,"unit":"px","default":28},{"type":"range","id":"padding_top_mobile","label":"Mobile padding top","min":0,"max":200,"step":4,"unit":"px","default":20},{"type":"range","id":"padding_bottom_mobile","label":"Mobile padding bottom","min":0,"max":200,"step":4,"unit":"px","default":20}],"blocks":[{"type":"timeline_item","name":"Timeline item","settings":[{"type":"text","id":"year","label":"Year","default":"1851"},{"type":"text","id":"heading","label":"Heading","default":"Joseph Seppelt plants the first vines"},{"type":"textarea","id":"description","label":"Description"},{"type":"image_picker","id":"image","label":"Image"},{"type":"image_picker","id":"mobile_image","label":"Mobile image"},{"type":"checkbox","id":"highlighted","label":"Highlighted","default":false}]}],"presets":[{"name":"SF About Time","category":"Seppeltsfield","blocks":[{"type":"timeline_item","settings":{"year":"1851","heading":"Joseph Seppelt plants the first vines","description":"Joseph and Johanna Seppelt establish the estate and lay its foundations."}},{"type":"timeline_item","settings":{"year":"1878","heading":"Centennial Cellar is built","description":"A single vintage Tawny is set aside each year, creating an unbroken lineage."}},{"type":"timeline_item","settings":{"year":"1888-1890","heading":"Gravity Cellar built into the hillside","description":"Designed for gentle handling of fruit, later revived for the 2010 vintage."}},{"type":"timeline_item","settings":{"year":"1900","heading":"Bottling Hall established","description":"The hall that now houses the Cellar Door and FINO Restaurant."}},{"type":"timeline_item","settings":{"year":"2009","heading":"Randall Wine Group era begins","description":"Warren Randall purchases Seppeltsfield and begins the estate's next chapter."}}]}]}
{% endschema %}
