{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}

<section class="sf2-location sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-location__grid">
    <div class="sf2-location__map">
      {%- if section.settings.map_image != blank -%}
        {% render 'sf2-picture', image: section.settings.map_image, sizes: '(min-width: 990px) 50vw, 100vw' %}
      {%- endif -%}
      <div class="sf2-location__card">
        <strong>{{ section.settings.address_line_1 }}</strong>
        <span>{{ section.settings.address_line_2 }}</span>
      </div>
    </div>
    <div class="sf2-location__copy">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow, brand: true %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
      <div class="sf2-location__list">
        {%- for block in section.blocks -%}
          <div class="sf2-location__item" {{ block.shopify_attributes }}>
            {% render 'sf2-icon', icon: block.settings.icon %}
            <div>
              <b>{{ block.settings.title }}</b>
              {%- if block.settings.link_url != blank -%}
                <a href="{{ block.settings.link_url }}">{{ block.settings.body }}</a>
              {%- else -%}
                <span>{{ block.settings.body }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
      {%- if section.settings.link_label != blank and section.settings.link_url != blank -%}
        <div class="sf2-location__link">
          {% render 'sf2-button', preset: 'text_link', label: section.settings.link_label, url: section.settings.link_url %}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Location Map",
  "tag": "section",
  "class": "sf2-location-section",
  "settings": [
    { "type": "image_picker", "id": "map_image", "label": "Map image" },
    { "type": "text", "id": "address_line_1", "label": "Address line 1", "default": "730 Seppeltsfield Road" },
    { "type": "text", "id": "address_line_2", "label": "Address line 2", "default": "Seppeltsfield, Barossa Valley SA 5355 Australia" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Hours & location" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Plan your arrival." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Seppeltsfield is under one hour from Adelaide and is open to the public daily, excluding selected public holidays." },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View full visitor information" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "soft_blue", "options": [
      { "value": "soft_blue", "label": "Soft Blue" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "info_item",
      "name": "Info item",
      "limit": 6,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "clock", "options": [
          { "value": "clock", "label": "Clock" }, { "value": "goblet", "label": "Bottle / goblet" },
          { "value": "map-pin", "label": "Map pin" }, { "value": "phone", "label": "Phone" }
        ]},
        { "type": "text", "id": "title", "label": "Title", "default": "Estate hours" },
        { "type": "text", "id": "body", "label": "Body", "default": "Open daily from 10am to 5pm." },
        { "type": "text", "id": "link_url", "label": "Link URL (e.g. tel:+61885686200)" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Location Map" }]
}
{% endschema %}
