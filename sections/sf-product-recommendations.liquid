{{ 'sf-product.css' | asset_url | stylesheet_tag }}
{{ 'sf-collection.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sf-collection.js' | asset_url }}" type="module"></script>
<script src="{{ 'product-recommendations.js' | asset_url }}" type="module"></script>

{% liquid
  case section.settings.content_width
    when 'narrow'
      assign content_max = '960px'
    when 'wide'
      assign content_max = '1440px'
    when 'full'
      assign content_max = '100%'
    else
      assign content_max = '1200px'
  endcase

  assign products_to_render = recommendations.products
  if products_to_render == blank or products_to_render.size == 0
    if section.settings.manual_products.count > 0
      assign products_to_render = section.settings.manual_products
    else
      assign products_to_render = collections.all.products | reject: 'id', product.id
    endif
  endif

  assign products_limit = section.settings.product_count
  assign use_carousel = false
  if products_to_render.size > 4 or products_limit > 4
    assign use_carousel = true
  endif
%}

<product-recommendations
  id="sf-product-recommendations-{{ section.id }}"
  class="sf-product-recommendations"
  data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.product_count }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-intent="{{ section.settings.recommendation_type }}"
  data-recommendations-performed="{{ recommendations.performed }}"
  {{ section.shopify_attributes }}
>
  <div class="sf-section-container" style="--sf-content-max: {{ content_max }};">
    <div class="sf-product-recommendations__header">
      <h2 class="sf-product-recommendations__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.view_all_url != blank and section.settings.view_all_label != blank %}
        <a href="{{ section.settings.view_all_url }}" class="sf-product-recommendations__view-all">{{ section.settings.view_all_label }}</a>
      {% endif %}
    </div>

    {% if products_to_render != blank and products_to_render.size > 0 %}
      <div class="sf-product-recommendations__track{% if use_carousel %} sf-product-recommendations__track--carousel{% else %} sf-product-recommendations__track--grid{% endif %}">
        {% for card_product in products_to_render limit: products_limit %}
          <div class="sf-product-recommendations__item">
            {% render 'sf-product-card', product: card_product, section: section %}
          </div>
        {% endfor %}
      </div>
    {% elsif recommendations.performed == false %}
      <p class="sf-product-recommendations__loading">Loading recommendations…</p>
    {% endif %}
  </div>
</product-recommendations>

{% schema %}
{
  "name": "SF Product Recs",
  "class": "sf-product-section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "You may also enjoy" },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "standard", "label": "Standard" },
        { "value": "wide", "label": "Wide" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "standard"
    },
    { "type": "range", "id": "product_count", "label": "Product count", "min": 2, "max": 12, "step": 1, "default": 4 },
    {
      "type": "select",
      "id": "recommendation_type",
      "label": "Recommendation type",
      "options": [
        { "value": "related", "label": "Related products" },
        { "value": "complementary", "label": "Complementary products" }
      ],
      "default": "related"
    },
    { "type": "url", "id": "view_all_url", "label": "View-all link" },
    { "type": "text", "id": "view_all_label", "label": "View-all label", "default": "View all" },
    { "type": "product_list", "id": "manual_products", "label": "Manual product fallback" },
    { "type": "header", "content": "Product card" },
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": false },
    { "type": "checkbox", "id": "show_vintage", "label": "Show vintage", "default": true },
    { "type": "checkbox", "id": "show_product_type", "label": "Show product type", "default": true },
    { "type": "checkbox", "id": "show_subtitle", "label": "Show subtitle metafield", "default": false },
    { "type": "text", "id": "subtitle_namespace", "label": "Subtitle metafield namespace", "default": "custom" },
    { "type": "text", "id": "subtitle_key", "label": "Subtitle metafield key", "default": "subtitle" },
    { "type": "checkbox", "id": "show_price", "label": "Show price", "default": true },
    { "type": "checkbox", "id": "show_compare_at_price", "label": "Show compare-at price", "default": true },
    { "type": "checkbox", "id": "show_quick_add", "label": "Show quick add", "default": true },
    { "type": "checkbox", "id": "show_quantity_selector", "label": "Show quantity selector", "default": true },
    {
      "type": "select",
      "id": "mobile_purchase_layout",
      "label": "Mobile purchase row layout",
      "options": [
        { "value": "same-line", "label": "Same line" },
        { "value": "stacked", "label": "Stacked" }
      ],
      "default": "same-line"
    },
    { "type": "text", "id": "add_to_cart_label", "label": "Add to cart label", "default": "Add to cart" },
    { "type": "text", "id": "choose_options_label", "label": "Choose options label", "default": "Choose options" },
    { "type": "checkbox", "id": "show_second_image_hover", "label": "Show second image on hover", "default": false },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "1 / 1", "label": "Square" },
        { "value": "3 / 4", "label": "Portrait" },
        { "value": "4 / 5", "label": "Tall portrait" }
      ],
      "default": "3 / 4"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "contain", "label": "Contain" },
        { "value": "cover", "label": "Cover" }
      ],
      "default": "contain"
    },
    { "type": "color", "id": "image_background", "label": "Image background", "default": "#FFFFFF" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#FFFFFF" },
    { "type": "color", "id": "card_border_color", "label": "Card border", "default": "#E6E6E6" },
    { "type": "range", "id": "card_border_width", "label": "Card border width", "min": 0, "max": 4, "step": 1, "unit": "px", "default": 1 },
    { "type": "range", "id": "card_border_radius", "label": "Card border radius", "min": 0, "max": 24, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "card_padding", "label": "Card padding", "min": 0, "max": 24, "step": 1, "unit": "px", "default": 12 },
    {
      "type": "select",
      "id": "title_size",
      "label": "Product title size",
      "options": [
        { "value": "0.9rem", "label": "Small" },
        { "value": "1rem", "label": "Medium" },
        { "value": "1.1rem", "label": "Large" }
      ],
      "default": "1rem"
    },
    {
      "type": "select",
      "id": "price_size",
      "label": "Price size",
      "options": [
        { "value": "0.9rem", "label": "Small" },
        { "value": "1rem", "label": "Medium" },
        { "value": "1.1rem", "label": "Large" }
      ],
      "default": "1rem"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button size",
      "options": [
        { "value": "0.7rem", "label": "Small" },
        { "value": "0.75rem", "label": "Medium" },
        { "value": "0.82rem", "label": "Large" }
      ],
      "default": "0.75rem"
    },
    { "type": "checkbox", "id": "show_score_badge", "label": "Show score badge", "default": true },
    { "type": "text", "id": "score_namespace", "label": "Score metafield namespace", "default": "custom" },
    { "type": "text", "id": "score_key", "label": "Score metafield key", "default": "wine_score" },
    { "type": "color", "id": "score_badge_bg", "label": "Badge background", "default": "#FFFFFF" },
    { "type": "color", "id": "score_badge_text", "label": "Badge text colour", "default": "#111111" },
    { "type": "color", "id": "score_badge_border", "label": "Badge border colour", "default": "#D9DFE5" },
    { "type": "range", "id": "score_badge_size", "label": "Badge size", "min": 36, "max": 64, "step": 1, "unit": "px", "default": 44 }
  ],
  "presets": [
    {
      "name": "SF Product Recs",
      "category": "Seppeltsfield"
    }
  ]
}
{% endschema %}
