{{ 'sf-discovery.css' | asset_url | stylesheet_tag }}

{%- liquid
  case section.settings.content_width
    when 'narrow'
      assign content_max = '960px'
    when 'wide'
      assign content_max = '1440px'
    when 'full'
      assign content_max = '100%'
    else
      assign content_max = '1200px'
  endcase
  assign desktop_image = section.settings.desktop_image
  assign mobile_image = section.settings.mobile_image | default: desktop_image
-%}

<section
  id="SfDiscoveryHeritage-{{ section.id }}"
  class="sf-discovery-heritage"
  style="
    --sf-content-max: {{ content_max }};
    --sf-bg: {{ section.settings.background_color }};
    --sf-panel: {{ section.settings.panel_background }};
    --sf-head: {{ section.settings.heading_color }};
    --sf-text: {{ section.settings.text_color }};
    --sf-muted: {{ section.settings.muted_color }};
    --sf-accent: {{ section.settings.accent_color }};
    --sf-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --sf-pad-bottom-d: {{ section.settings.padding_bottom_desktop }}px;
    --sf-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --sf-pad-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="sf-discovery-container">
    <div class="sf-discovery-heritage__layout{% if section.settings.reverse_desktop %} is-reverse-desktop{% endif %}{% if section.settings.reverse_mobile %} is-reverse-mobile{% endif %}">
      <div class="sf-discovery-heritage__media">
        {% if desktop_image != blank %}
          {{
            desktop_image
            | image_url: width: 1600
            | image_tag:
              class: 'sf-discovery-heritage__img sf-discovery-heritage__img--desktop',
              loading: 'lazy',
              widths: '550,750,990,1200,1440,1600',
              sizes: '(min-width:990px) 54vw, 100vw',
              alt: desktop_image.alt
          }}
          {{
            mobile_image
            | image_url: width: 1000
            | image_tag:
              class: 'sf-discovery-heritage__img sf-discovery-heritage__img--mobile',
              loading: 'lazy',
              widths: '375,550,750,900,1000',
              sizes: '(max-width:989px) 100vw, 1px',
              alt: mobile_image.alt
          }}
        {% endif %}
      </div>
      <div class="sf-discovery-heritage__content">
        {% if section.settings.eyebrow != blank %}<p class="sf-discovery-heritage__eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
        {% if section.settings.heading != blank %}<h2 class="sf-discovery-heritage__heading">{{ section.settings.heading | newline_to_br }}</h2>{% endif %}
        {% if section.settings.copy != blank %}<p class="sf-discovery-heritage__copy">{{ section.settings.copy }}</p>{% endif %}
        {% if section.settings.link_label != blank and section.settings.link_url != blank %}
          <a class="sf-discovery-link" href="{{ section.settings.link_url }}">{{ section.settings.link_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .sf-discovery-heritage {
    background: var(--sf-bg);
    padding-top: var(--sf-pad-top-d);
    padding-bottom: var(--sf-pad-bottom-d);
  }
  .sf-discovery-heritage__layout {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 5fr);
  }
  .sf-discovery-heritage__layout.is-reverse-desktop .sf-discovery-heritage__media { order: 2; }
  .sf-discovery-heritage__layout.is-reverse-desktop .sf-discovery-heritage__content { order: 1; }
  .sf-discovery-heritage__media { min-height: 420px; }
  .sf-discovery-heritage__img { width: 100%; height: 100%; object-fit: cover; }
  .sf-discovery-heritage__img--mobile { display: none; }
  .sf-discovery-heritage__content {
    background: var(--sf-panel);
    color: var(--sf-text);
    padding: 1.3rem;
    display: grid;
    align-content: center;
  }
  .sf-discovery-heritage__eyebrow {
    margin: 0;
    color: var(--sf-muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
  }
  .sf-discovery-heritage__heading {
    margin: 0.55rem 0 0;
    color: var(--sf-head);
    font-size: clamp(1.9rem, 2.9vw, 3.2rem);
    line-height: 1.04;
  }
  .sf-discovery-heritage__copy {
    margin: 0.9rem 0 1rem;
    color: var(--sf-text);
    max-width: 48ch;
  }
  @media (max-width: 989px) {
    .sf-discovery-heritage {
      padding-top: var(--sf-pad-top-m);
      padding-bottom: var(--sf-pad-bottom-m);
    }
    .sf-discovery-heritage__layout { grid-template-columns: 1fr; }
    .sf-discovery-heritage__img--desktop { display: none; }
    .sf-discovery-heritage__img--mobile { display: block; }
    .sf-discovery-heritage__layout.is-reverse-mobile .sf-discovery-heritage__media { order: 2; }
    .sf-discovery-heritage__layout.is-reverse-mobile .sf-discovery-heritage__content { order: 1; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SF Discover Heritage",
  "tag": "section",
  "class": "sf-discovery-section",
  "settings": [
    { "type": "paragraph", "content": "Recommended search: Seppeltsfield Estate Aerial, Dragan Fine Art Photography" },
    { "type": "select", "id": "content_width", "label": "Content width", "options": [{ "value": "narrow", "label": "Narrow" }, { "value": "standard", "label": "Standard" }, { "value": "wide", "label": "Wide" }, { "value": "full", "label": "Full width" }], "default": "standard" },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "checkbox", "id": "reverse_desktop", "label": "Reverse desktop", "default": false },
    { "type": "checkbox", "id": "reverse_mobile", "label": "Reverse mobile", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "OUR ESTATE" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "175 years of\nBarossa heritage" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Established in 1851, Seppeltsfield is one of Australia's most historic wine estates. At its heart is the Centennial Cellar, home to 149 consecutive vintages of single vintage Tawny - the only unbroken lineage of its kind anywhere in the world." },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "DISCOVER OUR HISTORY" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#111315" },
    { "type": "color", "id": "panel_background", "label": "Panel background", "default": "#F4F1EA" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#111315" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#4D4D4D" },
    { "type": "color", "id": "muted_color", "label": "Muted color", "default": "#6D4B35" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#47A8DF" },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 32 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 32 }
  ],
  "presets": [{ "name": "SF Discover Heritage", "category": "Seppeltsfield" }]
}
{% endschema %}
