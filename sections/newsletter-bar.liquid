<section class="spp-section spp-band-dark" {% render 'section-style-attributes' %}>
  <div class="section section--{{ section.settings.section_width }}">
    <div class="spp-newsletter-bar" data-reveal>
      <div>
        {% if section.settings.eyebrow != blank %}{% render 'heading-eyebrow', text: section.settings.eyebrow %}{% endif %}
        <h3 style="margin-top:10px;">{{ section.settings.heading }}</h3>
      </div>
      {% form 'customer', class: 'spp-newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder | escape }}" required>
        <button type="submit" class="seppeltsfield-button seppeltsfield-button--light">{{ section.settings.button_label }}</button>
      {% endform %}
    </div>
  </div>
</section>

{% stylesheet %}
  .spp-newsletter-bar { display:flex; align-items:center; justify-content:space-between; gap: 18px; flex-wrap: wrap; }
  .spp-newsletter-form { display:flex; gap:10px; flex:1; justify-content:flex-end; flex-wrap: wrap; }
  .spp-newsletter-form input { min-width: 260px; padding: 12px; border:1px solid rgba(255,255,255,.3); background: transparent; color:#fff; }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter bar",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay in touch" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join our estate mailing list." },
    { "type": "text", "id": "placeholder", "label": "Email placeholder", "default": "Email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "select", "id": "padding_top", "label": "Top padding", "options": [{"value":"sm","label":"Small"},{"value":"md","label":"Medium"},{"value":"lg","label":"Large"},{"value":"xl","label":"Extra large"}], "default": "md" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom padding", "options": [{"value":"sm","label":"Small"},{"value":"md","label":"Medium"},{"value":"lg","label":"Large"},{"value":"xl","label":"Extra large"}], "default": "md" },
    { "type": "select", "id": "background_type", "label": "Background type", "options": [{"value":"color","label":"Color"},{"value":"image","label":"Image"}], "default": "color" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#0C0D10" },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Image overlay darkness", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 0 },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#F5F7F8" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 24, "max": 96, "step": 2, "unit": "px", "default": 30 },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#F5F7F8" },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{"value":"page-width","label":"Page"},{"value":"full-width","label":"Full"}], "default": "page-width" }
  ],
  "presets": [{ "name": "Newsletter bar" }]
}
{% endschema %}
