{{ 'sf-events.css' | asset_url | stylesheet_tag }}

{%- liquid
  case section.settings.content_width
    when 'narrow'
      assign content_max = '960px'
    when 'wide'
      assign content_max = '1440px'
    when 'full'
      assign content_max = '100%'
    else
      assign content_max = '1200px'
  endcase
  assign desktop_image = section.settings.desktop_image
  assign mobile_image = section.settings.mobile_image | default: desktop_image
-%}

<section
  id="SfEventsHero-{{ section.id }}"
  class="sf-events-hero"
  style="
    --sf-content-max: {{ content_max }};
    --sf-bg: {{ section.settings.background_color }};
    --sf-overlay: {{ section.settings.overlay_color }};
    --sf-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --sf-head: {{ section.settings.heading_color }};
    --sf-copy: {{ section.settings.copy_color }};
    --sf-eye: {{ section.settings.eyebrow_color }};
    --sf-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --sf-pad-bottom-d: {{ section.settings.padding_bottom_desktop }}px;
    --sf-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --sf-pad-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
    --sf-min-d: {{ section.settings.min_height_desktop }}vh;
    --sf-min-m: {{ section.settings.min_height_mobile }}vh;
    --sf-heading-d: {{ section.settings.heading_size_desktop }}px;
    --sf-heading-m: {{ section.settings.heading_size_mobile }}px;
    --sf-copy-d: {{ section.settings.copy_size_desktop }}px;
    --sf-copy-m: {{ section.settings.copy_size_mobile }}px;
  "
>
  <div class="sf-events-hero__media">
    {% if desktop_image != blank %}
      {{
        desktop_image
        | image_url: width: 2200
        | image_tag:
          class: 'sf-events-hero__image sf-events-hero__image--desktop',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750,990,1200,1440,1800,2200',
          sizes: '100vw',
          alt: desktop_image.alt
      }}
      {{
        mobile_image
        | image_url: width: 1200
        | image_tag:
          class: 'sf-events-hero__image sf-events-hero__image--mobile',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '375,550,750,990,1200',
          sizes: '100vw',
          alt: mobile_image.alt
      }}
    {% endif %}
  </div>
  <div class="sf-events-hero__overlay"></div>
  <div class="sf-events-container sf-events-hero__inner sf-events-hero__inner--{{ section.settings.vertical_alignment }}">
    <div class="sf-events-hero__content sf-events-hero__content--{{ section.settings.content_alignment }}">
      {% if section.settings.eyebrow != blank %}<p class="sf-events-hero__eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
      {% if section.settings.heading != blank %}<h1 class="sf-events-hero__heading">{{ section.settings.heading | newline_to_br }}</h1>{% endif %}
      {% if section.settings.copy != blank %}<p class="sf-events-hero__copy">{{ section.settings.copy }}</p>{% endif %}
      <div class="sf-events-hero__actions">
        {% if section.settings.button_primary_label != blank and section.settings.button_primary_url != blank %}
          <a
            href="{{ section.settings.button_primary_url }}"
            class="sf-events-button sf-events-button--{{ section.settings.button_primary_style }}"
            style="
              --sf-btn-text: {{ section.settings.button_primary_text_color }};
              --sf-btn-bg: {{ section.settings.button_primary_bg_color }};
              --sf-btn-border: {{ section.settings.button_primary_border_color }};
              --sf-btn-hover-text: {{ section.settings.button_primary_hover_text_color }};
              --sf-btn-hover-bg: {{ section.settings.button_primary_hover_bg_color }};
              --sf-btn-hover-border: {{ section.settings.button_primary_hover_bg_color }};
            "
          >{{ section.settings.button_primary_label }}</a>
        {% endif %}
        {% if section.settings.button_secondary_label != blank and section.settings.button_secondary_url != blank %}
          <a
            href="{{ section.settings.button_secondary_url }}"
            class="sf-events-button sf-events-button--{{ section.settings.button_secondary_style }}"
            style="
              --sf-btn-text: {{ section.settings.button_secondary_text_color }};
              --sf-btn-bg: {{ section.settings.button_secondary_bg_color }};
              --sf-btn-border: {{ section.settings.button_secondary_border_color }};
              --sf-btn-hover-text: {{ section.settings.button_secondary_hover_text_color }};
              --sf-btn-hover-bg: {{ section.settings.button_secondary_hover_bg_color }};
              --sf-btn-hover-border: {{ section.settings.button_secondary_hover_bg_color }};
            "
          >{{ section.settings.button_secondary_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .sf-events-hero {
    position: relative;
    width: 100%;
    max-width: 100%;
    margin-left: 0;
    margin-right: 0;
    min-height: var(--sf-min-d);
    padding-top: var(--sf-pad-top-d);
    padding-bottom: var(--sf-pad-bottom-d);
    background: var(--sf-bg);
    overflow: clip;
  }
  .sf-events-hero__media,
  .sf-events-hero__overlay { position: absolute; inset: 0; }
  .sf-events-hero__image { width: 100%; height: 100%; object-fit: cover; }
  .sf-events-hero__image--mobile { display: none; }
  .sf-events-hero__overlay { background: var(--sf-overlay); opacity: var(--sf-overlay-opacity); }
  .sf-events-hero__inner { position: relative; min-height: calc(var(--sf-min-d) - var(--sf-pad-top-d) - var(--sf-pad-bottom-d)); display: grid; align-content: end; }
  .sf-events-hero__inner--start { align-content: start; }
  .sf-events-hero__inner--center { align-content: center; }
  .sf-events-hero__content { max-width: 620px; }
  .sf-events-hero__content--center { margin-inline: auto; text-align: center; }
  .sf-events-hero__content--right { margin-left: auto; text-align: right; }
  .sf-events-hero__eyebrow { margin: 0; color: var(--sf-eye); text-transform: uppercase; letter-spacing: .14em; font-size: .75rem; }
  .sf-events-hero__heading { margin: .5rem 0 0; color: var(--sf-head); font-size: var(--sf-heading-d); line-height: 1.02; }
  .sf-events-hero__copy { margin: .9rem 0 1.2rem; color: var(--sf-copy); font-size: var(--sf-copy-d); max-width: 54ch; }
  .sf-events-hero__actions { display: flex; flex-wrap: wrap; gap: .6rem; }
  @media (max-width: 989px) {
    .sf-events-hero { min-height: var(--sf-min-m); padding-top: var(--sf-pad-top-m); padding-bottom: var(--sf-pad-bottom-m); }
    .sf-events-hero__image--desktop { display: none; }
    .sf-events-hero__image--mobile { display: block; }
    .sf-events-hero__heading { font-size: var(--sf-heading-m); }
    .sf-events-hero__copy { font-size: var(--sf-copy-m); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SF Events Hero",
  "tag": "section",
  "class": "sf-events-section",
  "settings": [
    { "type": "paragraph", "content": "Search files: Functions, Corporate Events, BRZ_8152, Weddings & Functions" },
    { "type": "select", "id": "content_width", "label": "Content width", "options": [{ "value": "narrow", "label": "Narrow" }, { "value": "standard", "label": "Standard" }, { "value": "wide", "label": "Wide" }, { "value": "full", "label": "Full width" }], "default": "standard" },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#050505" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#050505" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 40 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "CELEBRATE AT THE ESTATE" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Events at\nSeppeltsfield" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Memorable occasions deserve remarkable places. Host your next event amid 175 years of heritage in the heart of the Barossa Valley." },
    { "type": "text", "id": "button_primary_label", "label": "Primary button label", "default": "ENQUIRE NOW" },
    { "type": "url", "id": "button_primary_url", "label": "Primary button URL" },
    { "type": "select", "id": "button_primary_style", "label": "Primary button style", "options": [{ "value": "solid", "label": "Solid" }, { "value": "outline", "label": "Outline" }, { "value": "text", "label": "Text link" }], "default": "solid" },
    { "type": "text", "id": "button_secondary_label", "label": "Secondary button label", "default": "EXPLORE VENUES" },
    { "type": "url", "id": "button_secondary_url", "label": "Secondary button URL" },
    { "type": "select", "id": "button_secondary_style", "label": "Secondary button style", "options": [{ "value": "outline", "label": "Outline" }, { "value": "solid", "label": "Solid" }, { "value": "text", "label": "Text link" }], "default": "outline" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#D6CEC1" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#FFFFFF" },
    { "type": "color", "id": "copy_color", "label": "Copy color", "default": "#F4F1EA" },
    { "type": "color", "id": "button_primary_text_color", "label": "Primary text color", "default": "#FFFFFF" },
    { "type": "color", "id": "button_primary_bg_color", "label": "Primary background", "default": "#47A8DF" },
    { "type": "color", "id": "button_primary_border_color", "label": "Primary border", "default": "#47A8DF" },
    { "type": "color", "id": "button_primary_hover_text_color", "label": "Primary hover text", "default": "#FFFFFF" },
    { "type": "color", "id": "button_primary_hover_bg_color", "label": "Primary hover background", "default": "#0B8BB9" },
    { "type": "color", "id": "button_secondary_text_color", "label": "Secondary text color", "default": "#FFFFFF" },
    { "type": "color", "id": "button_secondary_bg_color", "label": "Secondary background", "default": "rgba(0,0,0,0)" },
    { "type": "color", "id": "button_secondary_border_color", "label": "Secondary border", "default": "#FFFFFF" },
    { "type": "color", "id": "button_secondary_hover_text_color", "label": "Secondary hover text", "default": "#050505" },
    { "type": "color", "id": "button_secondary_hover_bg_color", "label": "Secondary hover background", "default": "#FFFFFF" },
    { "type": "range", "id": "heading_size_desktop", "label": "Heading desktop", "min": 36, "max": 110, "step": 2, "unit": "px", "default": 72 },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading mobile", "min": 30, "max": 64, "step": 2, "unit": "px", "default": 42 },
    { "type": "range", "id": "copy_size_desktop", "label": "Copy desktop", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "copy_size_mobile", "label": "Copy mobile", "min": 12, "max": 20, "step": 1, "unit": "px", "default": 15 },
    { "type": "select", "id": "content_alignment", "label": "Content alignment", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" }], "default": "left" },
    { "type": "select", "id": "vertical_alignment", "label": "Vertical alignment", "options": [{ "value": "start", "label": "Top" }, { "value": "center", "label": "Center" }, { "value": "end", "label": "Bottom" }], "default": "end" },
    { "type": "range", "id": "min_height_desktop", "label": "Min height desktop", "min": 60, "max": 100, "step": 2, "unit": "vh", "default": 78 },
    { "type": "range", "id": "min_height_mobile", "label": "Min height mobile", "min": 50, "max": 100, "step": 2, "unit": "vh", "default": 64 },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 20 }
  ],
  "presets": [{ "name": "SF Events Hero", "category": "Seppeltsfield" }]
}
{% endschema %}
