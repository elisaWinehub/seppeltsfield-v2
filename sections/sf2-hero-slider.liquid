{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-home.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sf2-hero-slider.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign hero_height = section.settings.hero_height | default: 'full_screen'
  case hero_height
    when 'compact'
      assign min_h = 'var(--sf-hero-compact-m)'
      assign min_h_d = 'var(--sf-hero-compact-d)'
    when 'editorial'
      assign min_h = 'var(--sf-hero-editorial-m)'
      assign min_h_d = 'var(--sf-hero-editorial-d)'
    when 'immersive'
      assign min_h = 'var(--sf-hero-immersive-m)'
      assign min_h_d = 'var(--sf-hero-immersive-d)'
    else
      assign min_h = 'var(--sf-hero-full)'
      assign min_h_d = 'var(--sf-hero-full)'
  endcase
-%}

<section
  class="sf2-hero"
  data-sf2-hero
  data-autoplay="{{ section.settings.autoplay_speed }}"
  style="--sf2-hero-min: {{ min_h }}; --sf2-hero-min-d: {{ min_h_d }};"
  aria-label="Homepage promotions"
>
  <div class="sf2-hero__slides">
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        <article class="sf2-hero__slide{% if forloop.first %} is-active{% endif %}" data-sf2-slide {{ block.shopify_attributes }}>
          {%- if block.settings.background_image != blank -%}
            <div class="sf2-hero__bg">
              {% render 'sf2-picture', image: block.settings.background_image, mobile_image: block.settings.mobile_image, loading: 'eager', sizes: '100vw' %}
            </div>
          {%- endif -%}
          <div class="sf2-hero__content sf2-wrap">
            <div>
              {%- if block.settings.eyebrow != blank -%}
                <div class="sf2-hero__mark">{% render 'sf2-eyebrow', text: block.settings.eyebrow, brand: true %}</div>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h1 class="sf2-serif sf2-hero__heading">{{ block.settings.heading }}</h1>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <div class="sf2-hero__copy">{{ block.settings.body }}</div>
              {%- endif -%}
              <div class="sf2-hero__actions">
                {%- if block.settings.primary_button_label != blank -%}
                  {% render 'sf2-button', preset: 'primary_blue', label: block.settings.primary_button_label, url: block.settings.primary_button_url %}
                {%- endif -%}
                {%- if block.settings.secondary_button_label != blank -%}
                  {% render 'sf2-button', preset: 'outline_light', label: block.settings.secondary_button_label, url: block.settings.secondary_button_url %}
                {%- endif -%}
              </div>
            </div>
            {%- if block.settings.note_heading != blank -%}
              <aside class="sf2-hero__note">
                <strong class="sf2-serif">{{ block.settings.note_heading }}</strong>
                {%- if block.settings.note_body != blank -%}<span>{{ block.settings.note_body }}</span>{%- endif -%}
              </aside>
            {%- endif -%}
          </div>
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="sf2-hero__dots" role="tablist" aria-label="Select slide">
    {%- assign slide_i = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        <button type="button" class="sf2-hero__dot{% if slide_i == 0 %} is-active{% endif %}" data-sf2-dot="{{ slide_i }}" aria-label="Slide {{ slide_i | plus: 1 }}" role="tab"></button>
        {%- assign slide_i = slide_i | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="sf2-hero__quickbar">
    <div class="sf2-hero__quickgrid sf2-wrap">
      {%- for block in section.blocks -%}
        {%- if block.type == 'quick_link' -%}
          <a class="sf2-hero__quick" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
            <span class="sf2-hero__crest">{% render 'sf2-icon', icon: block.settings.icon %}</span>
            <div><b>{{ block.settings.title }}</b><small>{{ block.settings.subtitle }}</small></div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Hero Slider",
  "tag": "section",
  "class": "sf2-hero-section",
  "settings": [
    { "type": "select", "id": "hero_height", "label": "Hero height", "default": "full_screen", "options": [
      { "value": "compact", "label": "Compact" },
      { "value": "editorial", "label": "Editorial" },
      { "value": "immersive", "label": "Immersive" },
      { "value": "full_screen", "label": "Full Screen" }
    ]},
    { "type": "range", "id": "autoplay_speed", "label": "Autoplay (seconds)", "min": 3, "max": 12, "step": 0.5, "default": 6.5 },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "dark", "options": [
      { "value": "light", "label": "Light" }, { "value": "dark", "label": "Dark" }, { "value": "black", "label": "Black" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "standard", "options": [
      { "value": "compact", "label": "Compact" }, { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }, { "value": "editorial", "label": "Editorial" }
    ]}
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "background_image", "label": "Background image" },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "175 years of Seppeltsfield" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "A legacy crowned by time." },
        { "type": "richtext", "id": "body", "label": "Body" },
        { "type": "text", "id": "primary_button_label", "label": "Primary button", "default": "Explore Our History" },
        { "type": "url", "id": "primary_button_url", "label": "Primary URL", "default": "/pages/heritage-story" },
        { "type": "text", "id": "secondary_button_label", "label": "Secondary button", "default": "Plan Your Visit" },
        { "type": "url", "id": "secondary_button_url", "label": "Secondary URL", "default": "/pages/visit" },
        { "type": "text", "id": "note_heading", "label": "Note heading", "default": "The jewel in the crown" },
        { "type": "text", "id": "note_body", "label": "Note body" }
      ]
    },
    {
      "type": "quick_link",
      "name": "Quick link",
      "limit": 4,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "crown", "options": [
          { "value": "crown", "label": "Crown" }, { "value": "clock", "label": "Clock" }, { "value": "map-pin", "label": "Map pin" }, { "value": "calendar", "label": "Calendar" }
        ]},
        { "type": "text", "id": "title", "label": "Title", "default": "Crown Society" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Member pricing & privileges" },
        { "type": "url", "id": "url", "label": "URL", "default": "/pages/wine-club" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Hero Slider" }]
}
{% endschema %}
