{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-home.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign logo = settings.logo
  if settings.logo_inverse != blank
    assign logo_inverse = settings.logo_inverse
  else
    assign logo_inverse = settings.logo
  endif
-%}

<footer class="sf2-footer">
  <div class="sf2-wrap sf2-footer__grid">
    <div>
      <a class="sf2-footer__logo" href="{{ routes.root_url }}">
        {%- if logo_inverse != blank -%}
          {{ logo_inverse | image_url: width: 400 | image_tag: widths: '200,300,400', sizes: '190px', alt: shop.name, loading: 'lazy' }}
        {%- else -%}
          <span class="sf2-serif">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if section.settings.blurb != blank -%}
        <div class="sf2-footer__blurb">{{ section.settings.blurb }}</div>
      {%- endif -%}
    </div>
    {%- for block in section.blocks -%}
      <div {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}<h4>{{ block.settings.heading }}</h4>{%- endif -%}
        {%- if block.settings.menu != blank -%}
          {%- for link in block.settings.menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
  <div class="sf2-wrap sf2-footer__legal">
    <span>© {{ 'now' | date: '%Y' }} {{ section.settings.legal_text | default: shop.name }}</span>
    {%- if section.settings.legal_links != blank -%}
      <nav aria-label="Legal">
        {%- for link in section.settings.legal_links.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>{% unless forloop.last %} · {% endunless %}
        {%- endfor -%}
      </nav>
    {%- else -%}
      <nav aria-label="Legal">
        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
            <a href="{{ policy.url }}">{{ policy.title }}</a>{% unless forloop.last %} · {% endunless %}
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "SF2 Footer",
  "tag": "footer",
  "class": "sf2-footer-section",
  "settings": [
    { "type": "richtext", "id": "blurb", "label": "Blurb", "default": "<p>A premium Shopify homepage balancing heritage, destination storytelling, collection discovery and bookable estate experiences.</p>" },
    { "type": "text", "id": "legal_text", "label": "Legal name", "default": "Seppeltsfield" },
    { "type": "link_list", "id": "legal_links", "label": "Legal links" }
  ],
  "blocks": [
    {
      "type": "footer_column",
      "name": "Footer column",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Discover" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Footer" }]
}
{% endschema %}
