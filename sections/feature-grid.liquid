<section class="spp-section" {% render 'section-style-attributes' %}>
  <div class="section section--{{ section.settings.section_width }}">
    <div class="section-head" data-reveal>
      {% if section.settings.eyebrow != blank %}{% render 'heading-eyebrow', text: section.settings.eyebrow %}{% endif %}
      <h2 style="margin-top:14px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
    </div>
    <div class="spp-feature-grid">
      {% for block in section.blocks %}
        {% render 'feature-card',
          image: block.settings.image,
          eyebrow: block.settings.eyebrow,
          title: block.settings.title,
          text: block.settings.text,
          link_label: block.settings.link_label,
          link: block.settings.link
        %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .spp-feature-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2px; background: var(--spp-line); }
  @media screen and (max-width: 989px) { .spp-feature-grid { grid-template-columns: 1fr 1fr; } }
  @media screen and (max-width: 649px) { .spp-feature-grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Feature grid",
  "blocks": [
    { "type": "feature", "name": "Feature", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Experience" },
      { "type": "text", "id": "title", "label": "Title", "default": "Centennial Cellar tasting" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "Taste an aged-flight directly from the barrel hall." },
      { "type": "text", "id": "link_label", "label": "Link label", "default": "Explore" },
      { "type": "url", "id": "link", "label": "Link" }
    ] }
  ],
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Discover" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Plan your estate day" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f1f2f1" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#0e1012" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#53575b" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 26, "max": 64, "step": 2, "unit": "px", "default": 44 },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 20, "step": 1, "unit": "px", "default": 16 },
    { "type": "select", "id": "padding_top", "label": "Top spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "lg" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "lg" },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{ "value": "page-width", "label": "Page" }, { "value": "full-width", "label": "Full" }], "default": "page-width" }
  ],
  "presets": [{ "name": "Feature grid", "blocks": [{ "type": "feature" }, { "type": "feature" }, { "type": "feature" }] }]
}
{% endschema %}
