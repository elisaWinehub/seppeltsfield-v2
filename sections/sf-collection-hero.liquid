{{ 'sf-collection.css' | asset_url | stylesheet_tag }}

{% liquid
  assign title_text = section.settings.title_override | strip
  if title_text == blank
    assign title_text = collection.title
  endif

  assign description_text = section.settings.description_override
  if description_text == blank
    assign description_text = collection.description
  endif

  assign desktop_image = section.settings.hero_image_override
  assign mobile_image = section.settings.hero_image_mobile_override

  if desktop_image == blank and collection.image != blank
    assign desktop_image = collection.image
  endif
  if mobile_image == blank and desktop_image != blank
    assign mobile_image = desktop_image
  endif

  if collection.handle == 'all' or collection.image == blank
    if desktop_image == blank and section.settings.default_collection_image != blank
      assign desktop_image = section.settings.default_collection_image
    endif
    if mobile_image == blank and section.settings.default_mobile_collection_image != blank
      assign mobile_image = section.settings.default_mobile_collection_image
    endif
  endif

  if desktop_image == blank and section.settings.default_collection_image != blank
    assign desktop_image = section.settings.default_collection_image
  endif
  if mobile_image == blank and section.settings.default_mobile_collection_image != blank
    assign mobile_image = section.settings.default_mobile_collection_image
  endif
  if mobile_image == blank
    assign mobile_image = desktop_image
  endif

  assign overlay_rgb = section.settings.overlay_color.red | append: ' ' | append: section.settings.overlay_color.green | append: ' ' | append: section.settings.overlay_color.blue

  assign content_horizontal = 'flex-start'
  case section.settings.content_position
    when 'center'
      assign content_horizontal = 'center'
    when 'right'
      assign content_horizontal = 'flex-end'
  endcase

  assign content_vertical = 'center'
  case section.settings.vertical_position
    when 'top'
      assign content_vertical = 'flex-start'
    when 'bottom'
      assign content_vertical = 'flex-end'
  endcase

  assign heading_weight = section.settings.heading_weight | default: 500
  assign eyebrow_weight = section.settings.eyebrow_weight | default: 600
  assign description_weight = section.settings.description_weight | default: 400
%}

<section
  class="sf-collection-hero"
  style="
    --sf-collection-hero-height-desktop: {{ section.settings.image_height_desktop }}px;
    --sf-collection-hero-height-mobile: {{ section.settings.image_height_mobile }}px;
    --sf-collection-hero-position-desktop: {{ section.settings.image_position_desktop }};
    --sf-collection-hero-position-mobile: {{ section.settings.image_position_mobile }};
    --sf-collection-hero-fit: {{ section.settings.image_fit }};
    --sf-collection-overlay-rgb: {{ overlay_rgb }};
    --sf-collection-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --sf-collection-overlay-gradient-direction: {{ section.settings.gradient_direction }};
    --sf-collection-hero-content-max: {{ section.settings.content_max_width }}px;
    --sf-collection-title-max: {{ section.settings.heading_max_width }}px;
    --sf-collection-description-max: {{ section.settings.description_max_width }}ch;
    --sf-collection-hero-content-desktop: {{ content_horizontal }};
    --sf-collection-hero-content-mobile: {{ content_horizontal }};
    --sf-collection-hero-vertical-desktop: {{ content_vertical }};
    --sf-collection-hero-vertical-mobile: {{ content_vertical }};
    --sf-collection-hero-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --sf-collection-hero-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --sf-collection-hero-padding-inline-desktop: {{ section.settings.padding_horizontal_desktop }}px;
    --sf-collection-hero-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --sf-collection-hero-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --sf-collection-hero-padding-inline-mobile: {{ section.settings.padding_horizontal_mobile }}px;
    --sf-collection-hero-text: {{ section.settings.heading_color }};
    --sf-collection-eyebrow-size-desktop: {{ section.settings.eyebrow_size_desktop }}rem;
    --sf-collection-eyebrow-size-mobile: {{ section.settings.eyebrow_size_mobile }}rem;
    --sf-collection-eyebrow-color: {{ section.settings.eyebrow_color }};
    --sf-collection-eyebrow-weight: {{ eyebrow_weight }};
    --sf-collection-heading-size-desktop: {{ section.settings.heading_size_desktop }}rem;
    --sf-collection-heading-size-mobile: {{ section.settings.heading_size_mobile }}rem;
    --sf-collection-heading-color: {{ section.settings.heading_color }};
    --sf-collection-heading-weight: {{ heading_weight }};
    --sf-collection-heading-line-height: {{ section.settings.heading_line_height }};
    --sf-collection-description-size-desktop: {{ section.settings.description_size_desktop }}rem;
    --sf-collection-description-size-mobile: {{ section.settings.description_size_mobile }}rem;
    --sf-collection-description-color: {{ section.settings.description_color }};
    --sf-collection-description-weight: {{ description_weight }};
    --sf-collection-description-line-height: {{ section.settings.description_line_height }};
  "
>
  <div class="sf-collection-hero__media">
    <div class="sf-collection-hero__image">
      {% if desktop_image != blank %}
        <picture>
          {% if mobile_image != blank %}
            <source
              media="(max-width: 749px)"
              srcset="
                {{ mobile_image | image_url: width: 550 }} 550w,
                {{ mobile_image | image_url: width: 750 }} 750w,
                {{ mobile_image | image_url: width: 990 }} 990w,
                {{ mobile_image | image_url: width: 1200 }} 1200w
              "
            >
          {% endif %}
          {{
            desktop_image
            | image_url: width: 2200
            | image_tag:
              widths: '550, 750, 990, 1200, 1440, 1800, 2200',
              sizes: '(max-width: 749px) 100vw, 100vw',
              loading: 'eager',
              fetchpriority: 'high',
              alt: desktop_image.alt | default: collection.title
          }}
        </picture>
      {% elsif mobile_image != blank %}
        {{
          mobile_image
          | image_url: width: 2200
          | image_tag:
            widths: '550, 750, 990, 1200, 1440, 1800, 2200',
            sizes: '(max-width: 749px) 100vw, 100vw',
            loading: 'eager',
            fetchpriority: 'high',
            alt: mobile_image.alt | default: collection.title
        }}
      {% else %}
        {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

    <div class="sf-collection-hero__overlay sf-collection-hero__overlay--solid"></div>
    {% if section.settings.enable_gradient_overlay %}
      <div class="sf-collection-hero__overlay sf-collection-hero__overlay--gradient"></div>
    {% endif %}
  </div>

</section>

{% schema %}
{
  "name": "SF Collection Hero",
  "class": "sf-collection-section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },
    { "type": "text", "id": "breadcrumb_home_label", "label": "Breadcrumb home label", "default": "Home" },
    { "type": "text", "id": "breadcrumb_shop_label", "label": "Breadcrumb shop label", "default": "Shop" },
    { "type": "text", "id": "eyebrow", "label": "Manual eyebrow", "default": "Collection" },
    { "type": "text", "id": "title_override", "label": "Manual title override" },
    { "type": "richtext", "id": "description_override", "label": "Manual description override" },
    { "type": "checkbox", "id": "show_description", "label": "Show description", "default": true },
    { "type": "checkbox", "id": "truncate_description", "label": "Truncate description", "default": false },
    { "type": "range", "id": "description_max_width", "label": "Description max width (ch)", "min": 32, "max": 100, "step": 1, "default": 58 },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Centre" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "vertical_position",
      "label": "Vertical position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "middle"
    },
    { "type": "range", "id": "content_max_width", "label": "Content max width", "min": 480, "max": 1100, "step": 20, "unit": "px", "default": 760 },
    { "type": "range", "id": "heading_max_width", "label": "Heading max width", "min": 360, "max": 1000, "step": 20, "unit": "px", "default": 680 },

    { "type": "header", "content": "Images" },
    { "type": "image_picker", "id": "hero_image_override", "label": "Hero image override (desktop)" },
    { "type": "image_picker", "id": "hero_image_mobile_override", "label": "Hero image override (mobile)" },
    { "type": "image_picker", "id": "default_collection_image", "label": "Default / All Collection Hero Image", "info": "Used for the All Products collection and any collection without its own image." },
    { "type": "image_picker", "id": "default_mobile_collection_image", "label": "Default mobile collection image" },
    { "type": "range", "id": "image_height_desktop", "label": "Image height desktop", "min": 320, "max": 820, "step": 10, "unit": "px", "default": 420 },
    { "type": "range", "id": "image_height_mobile", "label": "Image height mobile", "min": 240, "max": 680, "step": 10, "unit": "px", "default": 320 },
    { "type": "text", "id": "image_position_desktop", "label": "Image position desktop", "default": "center center" },
    { "type": "text", "id": "image_position_mobile", "label": "Image position mobile", "default": "center center" },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ],
      "default": "cover"
    },
    { "type": "color", "id": "overlay_color", "label": "Overlay colour", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 35 },
    { "type": "checkbox", "id": "enable_gradient_overlay", "label": "Optional gradient overlay", "default": true },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient direction",
      "options": [
        { "value": "to right", "label": "Left to right" },
        { "value": "to left", "label": "Right to left" },
        { "value": "to top", "label": "Bottom to top" },
        { "value": "to bottom", "label": "Top to bottom" }
      ],
      "default": "to right"
    },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "eyebrow_size_desktop", "label": "Eyebrow size desktop", "min": 0.6, "max": 1.2, "step": 0.1, "default": 0.8 },
    { "type": "range", "id": "eyebrow_size_mobile", "label": "Eyebrow size mobile", "min": 0.6, "max": 1.2, "step": 0.1, "default": 0.8 },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow colour", "default": "#9DC9E3" },
    { "type": "range", "id": "eyebrow_weight", "label": "Eyebrow weight", "min": 400, "max": 700, "step": 100, "default": 600 },
    { "type": "range", "id": "heading_size_desktop", "label": "Heading size desktop", "min": 1.8, "max": 4.8, "step": 0.1, "default": 3.3 },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size mobile", "min": 1.5, "max": 3.4, "step": 0.1, "default": 2.5 },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#FFFFFF" },
    { "type": "range", "id": "heading_weight", "label": "Heading weight", "min": 400, "max": 700, "step": 100, "default": 500 },
    { "type": "range", "id": "heading_line_height", "label": "Heading line height", "min": 0.9, "max": 1.4, "step": 0.1, "default": 1.1 },
    { "type": "range", "id": "description_size_desktop", "label": "Description size desktop", "min": 0.8, "max": 1.4, "step": 0.1, "default": 1.1 },
    { "type": "range", "id": "description_size_mobile", "label": "Description size mobile", "min": 0.8, "max": 1.2, "step": 0.1, "default": 1.0 },
    { "type": "color", "id": "description_color", "label": "Description colour", "default": "#FFFFFF" },
    { "type": "range", "id": "description_weight", "label": "Description weight", "min": 300, "max": 700, "step": 100, "default": 400 },
    { "type": "range", "id": "description_line_height", "label": "Description line height", "min": 1.2, "max": 1.8, "step": 0.1, "default": 1.5 },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 52 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 52 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 36 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 36 },
    { "type": "range", "id": "padding_horizontal_desktop", "label": "Horizontal padding desktop", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_horizontal_mobile", "label": "Horizontal padding mobile", "min": 0, "max": 56, "step": 2, "unit": "px", "default": 16 }
  ],
  "presets": [
    {
      "name": "SF Collection Hero",
      "category": "Seppeltsfield"
    }
  ]
}
{% endschema %}
