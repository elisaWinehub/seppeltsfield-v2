{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: 'light', spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: 'trade' -%}

<section id="{{ anchor_id }}" class="sf2-trade sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-trade__grid">
    {%- for block in section.blocks -%}
      {%- assign card_scheme = 'dark' -%}
      {%- if forloop.index == 2 -%}{%- assign card_scheme = 'soft_blue' -%}{%- endif -%}
      <article class="sf2-trade__card sf2-trade__card--{{ card_scheme }}" {{ block.shopify_attributes }}>
        <div>
          {% render 'sf2-eyebrow', text: block.settings.eyebrow, brand: true %}
          <h2 class="sf2-serif">{{ block.settings.heading }}</h2>
          {%- if block.settings.body != blank -%}<p>{{ block.settings.body }}</p>{%- endif -%}
        </div>
        {%- if block.settings.link_label != blank and block.settings.link_url != blank -%}
          {% render 'sf2-button', preset: 'text_link', label: block.settings.link_label, url: block.settings.link_url %}
        {%- endif -%}
      </article>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "SF2 Trade Banner",
  "tag": "section",
  "class": "sf2-trade-section",
  "max_blocks": 2,
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "trade" },
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "trade_card",
      "name": "Trade card",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Distributors" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Trade partners in Australia and abroad." },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "View distributors" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Trade Banner" }]
}
{% endschema %}
