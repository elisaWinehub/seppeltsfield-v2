{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}

<section class="sf2-split sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-split__grid">
    <div class="sf2-split__copy">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<div class="rte">{{ section.settings.body }}</div>{%- endif -%}
      {%- if section.settings.link_label != blank and section.settings.link_url != blank -%}
        <div class="sf2-split__link">
          {% render 'sf2-button', preset: 'text_link', label: section.settings.link_label, url: section.settings.link_url %}
        </div>
      {%- endif -%}
    </div>
    <div class="sf2-split__media">
      {%- if section.settings.main_image != blank -%}
        <div class="sf2-split__main">
          {% render 'sf2-picture', image: section.settings.main_image, sizes: '(min-width: 990px) 44vw, 100vw' %}
        </div>
      {%- endif -%}
      {%- if section.settings.secondary_image != blank -%}
        <div class="sf2-split__small">
          {% render 'sf2-picture', image: section.settings.secondary_image, sizes: '(min-width: 990px) 28vw, 80vw' %}
        </div>
      {%- endif -%}
      <div class="sf2-split__note">
        {% render 'sf2-eyebrow', text: section.settings.note_eyebrow, brand: true %}
        <b>{{ section.settings.note_heading }}</b>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Editorial Split",
  "tag": "section",
  "class": "sf2-split-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the Crown Society" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A wine club built around choice." },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "text", "id": "link_label", "label": "Link label" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "image_picker", "id": "main_image", "label": "Main image" },
    { "type": "image_picker", "id": "secondary_image", "label": "Secondary image" },
    { "type": "text", "id": "note_eyebrow", "label": "Note eyebrow", "default": "Member privileges" },
    { "type": "text", "id": "note_heading", "label": "Note heading", "default": "Wine, experiences and estate access." },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "light", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }, { "value": "soft_blue", "label": "Soft Blue" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }, { "value": "editorial", "label": "Editorial" }
    ]}
  ],
  "presets": [{ "name": "SF2 Editorial Split" }]
}
{% endschema %}
