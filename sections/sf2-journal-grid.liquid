{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-home.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}

<section class="sf2-story sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap">
    {% render 'sf2-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      link_label: section.settings.link_label,
      link_url: section.settings.link_url
    %}
    <div class="sf2-story__grid">
      {%- for block in section.blocks -%}
        <a class="sf2-story__card" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {% render 'sf2-picture', image: block.settings.image, sizes: '(min-width: 990px) 33vw, 100vw' %}
          {%- endif -%}
          <div class="sf2-story__copy">
            {%- if block.settings.eyebrow != blank -%}{% render 'sf2-eyebrow', text: block.settings.eyebrow, brand: true %}{%- endif -%}
            <h3>{{ block.settings.title }}</h3>
            {%- if block.settings.body != blank -%}<p>{{ block.settings.body }}</p>{%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Journal Grid",
  "tag": "section",
  "class": "sf2-story-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the estate journal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stories from Seppeltsfield." },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View all stories" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "ivory", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "standard", "options": [
      { "value": "compact", "label": "Compact" }, { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "story_card",
      "name": "Story card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Heritage" },
        { "type": "text", "id": "title", "label": "Title", "default": "175 years in the Barossa" },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Journal Grid" }]
}
{% endschema %}
