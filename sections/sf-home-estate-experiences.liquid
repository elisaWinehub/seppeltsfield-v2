{{ 'sf-home.css' | asset_url | stylesheet_tag }}

{%- liquid
  case section.settings.content_width
    when 'narrow'
      assign content_max = '960px'
    when 'wide'
      assign content_max = '1440px'
    when 'full'
      assign content_max = '100%'
    else
      assign content_max = '1200px'
  endcase
-%}

<section
  id="SfHomeEstate-{{ section.id }}"
  class="sf-home-estate-experiences"
  style="
    --sf-content-max: {{ content_max }};
    --sf-bg: {{ section.settings.background_color }};
    --sf-intro-bg: {{ section.settings.intro_panel_background }};
    --sf-text: {{ section.settings.text_color }};
    --sf-muted: {{ section.settings.muted_color }};
    --sf-accent: {{ section.settings.accent_color }};
    --sf-gap: {{ section.settings.card_gap }}px;
    --sf-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --sf-pad-bottom-d: {{ section.settings.padding_bottom_desktop }}px;
    --sf-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --sf-pad-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="sf-section-container">
    <div class="sf-home-estate-experiences__wrap">
      <article class="sf-home-estate-experiences__intro">
        {% if section.settings.intro_eyebrow != blank %}
          <p class="sf-home-estate-experiences__eyebrow">{{ section.settings.intro_eyebrow }}</p>
        {% endif %}
        {% if section.settings.intro_heading != blank %}
          <h2 class="sf-home-estate-experiences__heading">{{ section.settings.intro_heading | newline_to_br }}</h2>
        {% endif %}
        {% if section.settings.intro_copy != blank %}
          <p class="sf-home-estate-experiences__copy">{{ section.settings.intro_copy }}</p>
        {% endif %}
        {% if section.settings.intro_link_label != blank and section.settings.intro_link_url != blank %}
          <a class="sf-home-link" href="{{ section.settings.intro_link_url }}">{{ section.settings.intro_link_label }}</a>
        {% endif %}
      </article>
      {% for block in section.blocks %}
        {%- liquid
          assign card_image = block.settings.image
          if block.settings.mobile_image != blank
            assign card_mobile = block.settings.mobile_image
          else
            assign card_mobile = card_image
          endif
        -%}
        <article class="sf-home-estate-experiences__card{% if block.settings.featured %} is-featured{% endif %}" {{ block.shopify_attributes }}>
          <div class="sf-home-estate-experiences__card-media">
            {% if card_image != blank %}
              {{
                card_image
                | image_url: width: 1400
                | image_tag:
                  class: 'sf-home-estate-experiences__card-img sf-home-estate-experiences__card-img--desktop',
                  loading: 'lazy',
                  widths: '375, 550, 750, 990, 1200, 1400',
                  sizes: '(min-width: 990px) 20vw, 74vw',
                  alt: card_image.alt
              }}
              {{
                card_mobile
                | image_url: width: 1000
                | image_tag:
                  class: 'sf-home-estate-experiences__card-img sf-home-estate-experiences__card-img--mobile',
                  loading: 'lazy',
                  widths: '375, 550, 750, 900, 1000',
                  sizes: '(max-width: 989px) 78vw, 1px',
                  alt: card_mobile.alt
              }}
            {% endif %}
            <div class="sf-home-estate-experiences__card-overlay"></div>
          </div>
          <div class="sf-home-estate-experiences__card-content">
            {% if block.settings.eyebrow != blank %}
              <p class="sf-home-estate-experiences__card-eyebrow">{{ block.settings.eyebrow }}</p>
            {% endif %}
            {% if block.settings.heading != blank %}
              <h3 class="sf-home-estate-experiences__card-heading">{{ block.settings.heading }}</h3>
            {% endif %}
            {% if block.settings.copy != blank %}
              <p class="sf-home-estate-experiences__card-copy">{{ block.settings.copy }}</p>
            {% endif %}
            {% if block.settings.link_label != blank and block.settings.link_url != blank %}
              <a href="{{ block.settings.link_url }}" class="sf-home-link">{{ block.settings.link_label }}</a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .sf-home-estate-experiences {
    background: var(--sf-bg);
    color: var(--sf-text);
    padding-top: var(--sf-pad-top-d);
    padding-bottom: var(--sf-pad-bottom-d);
  }
  .sf-home-estate-experiences__wrap {
    display: flex;
    align-items: stretch;
    gap: var(--sf-gap);
  }
  .sf-home-estate-experiences__intro {
    background: var(--sf-intro-bg);
    padding: 1.3rem;
    align-self: stretch;
    flex: 0 0 clamp(220px, 22vw, 340px);
  }
  .sf-home-estate-experiences__eyebrow {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sf-muted);
  }
  .sf-home-estate-experiences__heading {
    margin: 0.6rem 0 0;
    line-height: 1.03;
    font-size: clamp(1.6rem, 2.7vw, 3.3rem);
  }
  .sf-home-estate-experiences__copy {
    margin: 0.9rem 0 0;
    color: color-mix(in srgb, var(--sf-text) 82%, transparent);
  }
  .sf-home-estate-experiences__card {
    position: relative;
    overflow: hidden;
    min-height: 460px;
    min-width: 0;
    flex: 1;
    transition: flex 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sf-home-estate-experiences__card-media,
  .sf-home-estate-experiences__card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sf-home-estate-experiences__card-img--mobile {
    display: none;
  }
  .sf-home-estate-experiences__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5, 5, 5, 0.15), rgba(5, 5, 5, 0.72));
  }
  .sf-home-estate-experiences__card-content {
    position: relative;
    z-index: 2;
    color: #fff;
    padding: 1rem;
    display: grid;
    align-content: end;
    min-height: 100%;
  }
  .sf-home-estate-experiences__card-eyebrow {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .sf-home-estate-experiences__card-heading {
    margin: 0.45rem 0 0;
    font-size: clamp(1.1rem, 1.6vw, 1.8rem);
  }
  .sf-home-estate-experiences__card-copy {
    margin: 0.5rem 0 0;
    font-size: 0.94rem;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf-home-estate-experiences__card:hover {
      flex: 1.6;
      z-index: 2;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sf-home-estate-experiences__card {
      transition: none;
    }
  }
  @media (max-width: 989px) {
    .sf-home-estate-experiences {
      padding-top: var(--sf-pad-top-m);
      padding-bottom: var(--sf-pad-bottom-m);
    }
    .sf-home-estate-experiences__wrap {
      display: grid;
      grid-template-columns: 1fr;
    }
    .sf-home-estate-experiences__card {
      min-height: 360px;
      flex: unset;
    }
    .sf-home-estate-experiences__card-img--desktop {
      display: none;
    }
    .sf-home-estate-experiences__card-img--mobile {
      display: block;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SF Home Estate Exp",
  "tag": "section",
  "class": "sf-home-section",
  "max_blocks": 6,
  "settings": [
    { "type": "paragraph", "content": "Recommended files: centennialcellarHERO2, finoHERO, BMAC7229, THE-AVENUE-OF-PALMS" },
    { "type": "select", "id": "content_width", "label": "Content width", "options": [{ "value": "narrow", "label": "Narrow" }, { "value": "standard", "label": "Standard" }, { "value": "wide", "label": "Wide" }, { "value": "full", "label": "Full width" }], "default": "wide" },
    { "type": "text", "id": "intro_eyebrow", "label": "Intro eyebrow", "default": "THE ESTATE" },
    { "type": "textarea", "id": "intro_heading", "label": "Intro heading", "default": "More Than Wine.\nAn Experience." },
    { "type": "textarea", "id": "intro_copy", "label": "Intro copy", "default": "Cellar door tastings, award-winning dining, luxury accommodation and immersive experiences await you." },
    { "type": "text", "id": "intro_link_label", "label": "Intro link label", "default": "EXPLORE THE ESTATE" },
    { "type": "url", "id": "intro_link_url", "label": "Intro link URL" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#050505" },
    { "type": "color", "id": "intro_panel_background", "label": "Intro panel background", "default": "#111315" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "color", "id": "muted_color", "label": "Muted text color", "default": "#D6CEC1" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#47A8DF" },
    { "type": "range", "id": "card_gap", "label": "Card gap", "min": 8, "max": 40, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 28 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 28 }
  ],
  "blocks": [
    {
      "type": "experience",
      "name": "Experience card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Experience" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Centennial Cellar" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Discover iconic tours and tastings." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Explore" },
        { "type": "url", "id": "link_url", "label": "Link URL" },
        { "type": "checkbox", "id": "featured", "label": "Featured state", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "SF - Home Estate Exp",
      "category": "Seppeltsfield",
      "blocks": [
        { "type": "experience", "settings": { "heading": "Centennial Cellar", "copy": "Explore one of the worldÃ¢â‚¬â„¢s most extraordinary wine collections." } },
        { "type": "experience", "settings": { "heading": "Dine at FINO", "copy": "Regional produce and estate views in every season." } },
        { "type": "experience", "settings": { "heading": "Stay at The Lodge", "copy": "A luxurious stay among palms and vineyards." } },
        { "type": "experience", "settings": { "heading": "Experiences on the Estate", "copy": "Craft, culture and cellar discoveries." } }
      ]
    }
  ]
}
{% endschema %}
