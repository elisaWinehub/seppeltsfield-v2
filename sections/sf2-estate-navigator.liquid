{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: '' -%}

<section{% if anchor_id != blank %} id="{{ anchor_id }}"{% endif %} class="sf2-navigator sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-navigator__grid">
    <div class="sf2-navigator__copy">
      <div>
        {% render 'sf2-eyebrow', text: section.settings.eyebrow, brand: true %}
        <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
        {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
      </div>
      {%- if section.settings.link_label != blank -%}
        {% render 'sf2-button', preset: 'text_link', label: section.settings.link_label, url: section.settings.link_url %}
      {%- endif -%}
    </div>
    <div class="sf2-navigator__list">
      {%- for block in section.blocks -%}
        <a class="sf2-navigator__card" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {% render 'sf2-picture', image: block.settings.image, sizes: '(min-width: 990px) 25vw, 50vw' %}
          {%- endif -%}
          <div>
            {%- if block.settings.eyebrow != blank -%}
              {% render 'sf2-eyebrow', text: block.settings.eyebrow, brand: true %}
            {%- elsif block.settings.icon != blank -%}
              {% render 'sf2-icon', icon: block.settings.icon %}
            {%- endif -%}
            <b>{{ block.settings.title }}</b>
            {%- if block.settings.body != blank -%}<small>{{ block.settings.body }}</small>{%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Estate Navigator",
  "tag": "section",
  "class": "sf2-navigator-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Explore the estate" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Build your day around the village." },
    { "type": "textarea", "id": "body", "label": "Body" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View visitor information" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "light", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "nav_card",
      "name": "Navigator card",
      "limit": 6,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow (optional, replaces icon)" },
        { "type": "select", "id": "icon", "label": "Icon", "default": "", "options": [
          { "value": "", "label": "None" },
          { "value": "goblet", "label": "Goblet" }, { "value": "dining", "label": "Dining" }, { "value": "cup", "label": "Cup" },
          { "value": "village", "label": "Village" }, { "value": "bed", "label": "Bed" }, { "value": "book", "label": "Book" }
        ]},
        { "type": "text", "id": "title", "label": "Title", "default": "Cellar Door" },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Estate Navigator" }]
}
{% endschema %}
