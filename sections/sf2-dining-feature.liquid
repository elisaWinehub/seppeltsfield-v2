{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: 'light', spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: 'dining' -%}

<section id="{{ anchor_id }}" class="sf2-dining sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-dining__grid">
    <div class="sf2-dining__media">
      {%- if section.settings.image != blank -%}
        {% render 'sf2-picture', image: section.settings.image, sizes: '(min-width: 990px) 55vw, 100vw' %}
      {%- endif -%}
      <div class="sf2-dining__label">
        {% render 'sf2-eyebrow', text: section.settings.label_eyebrow, brand: true %}
        <strong>{{ section.settings.label_heading }}</strong>
      </div>
    </div>
    <div class="sf2-dining__copy sf2-dining__copy--{{ section.settings.color_scheme }}">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
      <div class="sf2-dining__links">
        {%- for block in section.blocks -%}
          <a class="sf2-dining__link" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
            <b>{{ block.settings.label }}</b>
            {% render 'sf2-icon', icon: 'arrow-right' %}
          </a>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Dining Feature",
  "tag": "section",
  "class": "sf2-dining-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "dining" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "label_eyebrow", "label": "Image label eyebrow", "default": "Estate dining" },
    { "type": "text", "id": "label_heading", "label": "Image label heading", "default": "Seasonal food in a remarkable setting." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Dine at Seppeltsfield" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From long lunches to relaxed garden dining." },
    { "type": "textarea", "id": "body", "label": "Body" },
    { "type": "select", "id": "color_scheme", "label": "Copy panel scheme", "default": "soft_blue", "options": [
      { "value": "soft_blue", "label": "Soft Blue" }, { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "dining_link",
      "name": "Dining link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "FINO Restaurant" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Dining Feature" }]
}
{% endschema %}
