{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: '' -%}

<section{% if anchor_id != blank %} id="{{ anchor_id }}"{% endif %} class="sf2-feature sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-feature__grid">
    <div class="sf2-feature__copy">
      <div>
        {% render 'sf2-eyebrow', text: section.settings.eyebrow, brand: true %}
        <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
        {%- if section.settings.body != blank -%}<div>{{ section.settings.body }}</div>{%- endif -%}
      </div>
      {%- if section.settings.link_label != blank -%}
        {% render 'sf2-button', preset: 'text_link', label: section.settings.link_label, url: section.settings.link_url %}
      {%- endif -%}
    </div>
    <a class="sf2-feature__media" href="{{ section.settings.link_url | default: '#' }}">
      {%- if section.settings.image != blank -%}
        {% render 'sf2-picture', image: section.settings.image, sizes: '(min-width: 990px) 55vw, 100vw' %}
      {%- endif -%}
      {%- if section.settings.badge_text != blank -%}
        <span class="sf2-feature__badge">{{ section.settings.badge_text }}</span>
      {%- endif -%}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Feature Banner",
  "tag": "section",
  "class": "sf2-feature-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "feature" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Self-guided history experience" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ten stories across the estate." },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Explore the history trail" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "badge_text", "label": "Badge text" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "ivory", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "presets": [{ "name": "SF2 Feature Banner" }]
}
{% endschema %}
