<section class="spp-section" {% render 'section-style-attributes' %}>
  <div class="section section--{{ section.settings.section_width }}">
    <div class="spp-collage-heritage" data-reveal>
      <div class="spp-collage-heritage__media">
        {% if section.settings.main_image != blank %}
          {{ section.settings.main_image | image_url: width: 1400 | image_tag: loading: 'lazy', alt: section.settings.heading }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
        <div class="spp-collage-heritage__inset">
          {% if section.settings.inset_image != blank %}
            {{ section.settings.inset_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: section.settings.heading }}
          {% else %}
            {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        <div class="spp-collage-heritage__seal">{% render 'seal-mark' %}</div>
      </div>
      <div>
        {% if section.settings.eyebrow != blank %}{% render 'heading-eyebrow', text: section.settings.eyebrow %}{% endif %}
        <h2 style="margin-top:14px;">{{ section.settings.heading }}</h2>
        <div style="margin-top:14px;">{{ section.settings.body }}</div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .spp-collage-heritage { display:grid; gap:32px; grid-template-columns: minmax(0,1.1fr) minmax(0,.9fr); align-items:center; }
  .spp-collage-heritage__media { position:relative; padding-right:20%; }
  .spp-collage-heritage__media > img, .spp-collage-heritage__media > svg { width:100%; display:block; aspect-ratio: 4/5; object-fit:cover; }
  .spp-collage-heritage__inset { position:absolute; right:0; bottom:8%; width:42%; border: 5px solid #f7f6f3; }
  .spp-collage-heritage__inset img, .spp-collage-heritage__inset svg { width:100%; display:block; aspect-ratio:1/1; object-fit:cover; }
  .spp-collage-heritage__seal { position:absolute; left:-50px; bottom:-42px; width:120px; opacity:.35; }
  @media (max-width:989px){ .spp-collage-heritage { grid-template-columns:1fr; } .spp-collage-heritage__media { padding-right:18%; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Collage heritage",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Heritage" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A legacy in every generation" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Since 1851, Seppeltsfield has blended place, people and patience into every vintage.</p>" },
    { "type": "image_picker", "id": "main_image", "label": "Main image" },
    { "type": "image_picker", "id": "inset_image", "label": "Inset image" },
    { "type": "select", "id": "padding_top", "label": "Top padding", "options": [{"value":"sm","label":"Small"},{"value":"md","label":"Medium"},{"value":"lg","label":"Large"},{"value":"xl","label":"Extra large"}], "default": "lg" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom padding", "options": [{"value":"sm","label":"Small"},{"value":"md","label":"Medium"},{"value":"lg","label":"Large"},{"value":"xl","label":"Extra large"}], "default": "lg" },
    { "type": "select", "id": "background_type", "label": "Background type", "options": [{"value":"color","label":"Color"},{"value":"image","label":"Image"}], "default": "color" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#F7F6F3" },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Image overlay darkness", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 0 },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#12141A" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 24, "max": 96, "step": 2, "unit": "px", "default": 40 },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#565B63" },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{"value":"page-width","label":"Page"},{"value":"full-width","label":"Full"}], "default": "page-width" }
  ],
  "presets": [{ "name": "Collage heritage" }]
}
{% endschema %}
