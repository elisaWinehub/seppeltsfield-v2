{{ 'sf-wine-club.css' | asset_url | stylesheet_tag }}

{%- liquid
  case section.settings.content_width
    when 'narrow'
      assign content_max = '960px'
    when 'wide'
      assign content_max = '1440px'
    when 'full'
      assign content_max = '100%'
    else
      assign content_max = '1200px'
  endcase
-%}

<section
  id="SfWineClubBenefits-{{ section.id }}"
  class="sf-wine-club-benefits"
  style="
    --sf-content-max: {{ content_max }};
    --sf-bg: {{ section.settings.background_color }};
    --sf-head: {{ section.settings.heading_color }};
    --sf-text: {{ section.settings.text_color }};
    --sf-muted: {{ section.settings.muted_color }};
    --sf-accent: {{ section.settings.accent_color }};
    --sf-gap: {{ section.settings.grid_gap }}px;
    --sf-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --sf-pad-bottom-d: {{ section.settings.padding_bottom_desktop }}px;
    --sf-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --sf-pad-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
    --sf-cols-d: {{ section.settings.columns_desktop }};
    --sf-cols-t: {{ section.settings.columns_tablet }};
  "
>
  <div class="sf-wine-club-container">
    <div class="sf-wine-club-benefits__intro sf-wine-club-benefits__intro--{{ section.settings.intro_layout }}">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="sf-wine-club-benefits__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="sf-wine-club-benefits__heading">{{ section.settings.heading | newline_to_br }}</h2>
        {% endif %}
      </div>
      {% if section.settings.intro_copy != blank %}
        <p class="sf-wine-club-benefits__intro-copy">{{ section.settings.intro_copy }}</p>
      {% endif %}
    </div>

    <div class="sf-wine-club-benefits__grid sf-wine-club-benefits__grid--mobile-{{ section.settings.mobile_layout }}">
      {% for block in section.blocks %}
        <article class="sf-wine-club-benefits__item{% if block.settings.featured %} is-featured{% endif %}" {{ block.shopify_attributes }}>
          <div class="sf-wine-club-benefits__icon-wrap">
            {% if block.settings.custom_icon != blank %}
              {{
                block.settings.custom_icon
                | image_url: width: 120
                | image_tag: loading: 'lazy', widths: '40,60,80,120', sizes: '40px', alt: block.settings.heading
              }}
            {% else %}
              <span class="sf-wine-club-benefits__icon">{{ block.settings.icon }}</span>
            {% endif %}
          </div>
          {% if block.settings.heading != blank %}
            <h3 class="sf-wine-club-benefits__item-heading">{{ block.settings.heading }}</h3>
          {% endif %}
          {% if block.settings.copy != blank %}
            <p class="sf-wine-club-benefits__item-copy">{{ block.settings.copy }}</p>
          {% endif %}
          {% if block.settings.link_label != blank and block.settings.link_url != blank %}
            <a class="sf-wine-link" href="{{ block.settings.link_url }}">{{ block.settings.link_label }}</a>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .sf-wine-club-benefits {
    background: var(--sf-bg);
    color: var(--sf-text);
    padding-top: var(--sf-pad-top-d);
    padding-bottom: var(--sf-pad-bottom-d);
  }
  .sf-wine-club-benefits__intro {
    display: grid;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1.3rem;
  }
  .sf-wine-club-benefits__intro--split {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }
  .sf-wine-club-benefits__eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--sf-muted);
    font-size: 0.75rem;
  }
  .sf-wine-club-benefits__heading {
    margin: 0.45rem 0 0;
    color: var(--sf-head);
    font-size: clamp(1.8rem, 3.3vw, 3.9rem);
    line-height: 1.04;
  }
  .sf-wine-club-benefits__intro-copy {
    margin: 0;
    color: var(--sf-muted);
    max-width: 50ch;
  }
  .sf-wine-club-benefits__grid {
    display: grid;
    grid-template-columns: repeat(var(--sf-cols-d), minmax(0, 1fr));
    gap: var(--sf-gap);
  }
  .sf-wine-club-benefits__item {
    border-top: 1px solid color-mix(in srgb, var(--sf-muted) 32%, transparent);
    padding-top: 0.9rem;
    min-height: 180px;
  }
  .sf-wine-club-benefits__icon-wrap {
    color: var(--sf-accent);
    min-height: 2rem;
  }
  .sf-wine-club-benefits__icon {
    font-size: 1.6rem;
    line-height: 1;
  }
  .sf-wine-club-benefits__icon-wrap img {
    width: 2.3rem;
    height: 2.3rem;
    object-fit: contain;
  }
  .sf-wine-club-benefits__item-heading {
    margin: 0.55rem 0 0;
    color: var(--sf-head);
    font-size: 1.1rem;
  }
  .sf-wine-club-benefits__item-copy {
    margin: 0.45rem 0 0.55rem;
    color: var(--sf-muted);
    font-size: 0.95rem;
  }
  .sf-wine-club-benefits__item.is-featured {
    border-top-color: var(--sf-accent);
  }
  @media (max-width: 989px) {
    .sf-wine-club-benefits {
      padding-top: var(--sf-pad-top-m);
      padding-bottom: var(--sf-pad-bottom-m);
    }
    .sf-wine-club-benefits__intro,
    .sf-wine-club-benefits__intro--split {
      grid-template-columns: 1fr;
    }
    .sf-wine-club-benefits__grid {
      grid-template-columns: repeat(var(--sf-cols-t), minmax(0, 1fr));
    }
    .sf-wine-club-benefits__grid--mobile-scroll {
      grid-auto-flow: column;
      grid-auto-columns: minmax(80%, 1fr);
      grid-template-columns: unset;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 0.35rem;
    }
    .sf-wine-club-benefits__grid--mobile-scroll .sf-wine-club-benefits__item {
      scroll-snap-align: start;
    }
    .sf-wine-club-benefits__grid--mobile-stack {
      grid-template-columns: 1fr;
    }
    .sf-wine-club-benefits__grid--mobile-two {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SF Wine Club Benefits",
  "tag": "section",
  "class": "sf-wine-club-section",
  "max_blocks": 10,
  "settings": [
    { "type": "select", "id": "content_width", "label": "Content width", "options": [{ "value": "narrow", "label": "Narrow" }, { "value": "standard", "label": "Standard" }, { "value": "wide", "label": "Wide" }, { "value": "full", "label": "Full width" }], "default": "standard" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WHY JOIN" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Exclusive benefits\nfor our members." },
    { "type": "textarea", "id": "intro_copy", "label": "Intro copy", "default": "As a Wine Club member, you're treated to a world of privileges designed to bring you closer to Seppeltsfield." },
    { "type": "select", "id": "intro_layout", "label": "Intro layout", "options": [{ "value": "split", "label": "Heading left, copy right" }, { "value": "stack", "label": "Stacked" }], "default": "split" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#F4F1EA" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#111315" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111315" },
    { "type": "color", "id": "muted_color", "label": "Muted color", "default": "#6D4B35" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#47A8DF" },
    { "type": "range", "id": "columns_desktop", "label": "Columns desktop", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "columns_tablet", "label": "Columns tablet", "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "select", "id": "mobile_layout", "label": "Mobile layout", "options": [{ "value": "scroll", "label": "Horizontal scroll" }, { "value": "two", "label": "Two-column" }, { "value": "stack", "label": "Stacked" }], "default": "scroll" },
    { "type": "range", "id": "grid_gap", "label": "Grid gap", "min": 8, "max": 40, "step": 2, "unit": "px", "default": 16 },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 32 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 32 }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "🍾", "label": "Wine bottles" }, { "value": "🍷", "label": "Wine glasses" }, { "value": "◴", "label": "Calendar" }, { "value": "⇢", "label": "Delivery truck" }, { "value": "✉", "label": "Newsletter" }, { "value": "♛", "label": "Crown" }, { "value": "✦", "label": "Star" }, { "value": "☑", "label": "Lock" }], "default": "🍾" },
        { "type": "image_picker", "id": "custom_icon", "label": "Custom icon image" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Exclusive Wines" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Access limited releases and museum wines not available anywhere else." },
        { "type": "text", "id": "link_label", "label": "Link label" },
        { "type": "url", "id": "link_url", "label": "Link URL" },
        { "type": "checkbox", "id": "featured", "label": "Featured state", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "SF Wine Club Benefits",
      "category": "Seppeltsfield",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "🍾", "heading": "Exclusive Wines", "copy": "Access limited releases and museum wines not available anywhere else." } },
        { "type": "benefit", "settings": { "icon": "✦", "heading": "Member Discounts", "copy": "Enjoy savings on wines, experiences, dining and accommodation." } },
        { "type": "benefit", "settings": { "icon": "◴", "heading": "Invitations", "copy": "Be the first to receive invitations to member events and tastings." } },
        { "type": "benefit", "settings": { "icon": "⇢", "heading": "Complimentary Freight", "copy": "Complimentary delivery Australia-wide on eligible wine orders." } },
        { "type": "benefit", "settings": { "icon": "✉", "heading": "Member News", "copy": "Stay connected with our quarterly member newsletter." } },
        { "type": "benefit", "settings": { "icon": "♛", "heading": "Crown Society", "copy": "Earn Crown Society points with every purchase and experience." } }
      ]
    }
  ]
}
{% endschema %}
