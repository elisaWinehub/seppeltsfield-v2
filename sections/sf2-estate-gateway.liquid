{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-home.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}

<section id="visit" class="sf2-gateway sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap">
    {% render 'sf2-section-header',
      eyebrow: section.settings.eyebrow,
      eyebrow_brand: true,
      heading: section.settings.heading,
      body: section.settings.body,
      scheme: 'dark'
    %}
  </div>
  <div class="sf2-gateway__grid">
    {%- for block in section.blocks -%}
      <a class="sf2-gateway__card" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {% render 'sf2-picture', image: block.settings.image, sizes: '(min-width: 990px) 25vw, 50vw' %}
        {%- endif -%}
        <div class="sf2-gateway__copy">
          <span class="num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <h3>{{ block.settings.title }}</h3>
          {%- if block.settings.body != blank -%}<p>{{ block.settings.body }}</p>{%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "SF2 Estate Gateway",
  "tag": "section",
  "class": "sf2-gateway-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Discover the estate" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "One destination. Many ways to experience it." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The existing Visit Us pages are grouped beneath one strong destination page, with filters or anchored sections for tastings, dining, makers, accommodation and practical visitor information." },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "black", "options": [
      { "value": "dark", "label": "Dark" }, { "value": "black", "label": "Black" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "standard", "options": [
      { "value": "compact", "label": "Compact" }, { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "gateway_card",
      "name": "Gateway card",
      "limit": 4,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Cellar Door & Experiences" },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Estate Gateway" }]
}
{% endschema %}
