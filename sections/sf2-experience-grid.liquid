{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-home.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}

<section id="experiences" class="sf2-experience sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap">
    {% render 'sf2-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      body: section.settings.body
    %}
    <div class="sf2-experience__grid">
      {%- for block in section.blocks -%}
        <a class="sf2-experience__card" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          <div class="sf2-experience__media">
            {%- if block.settings.image != blank -%}
              {% render 'sf2-picture', image: block.settings.image, sizes: '(min-width: 990px) 33vw, 50vw' %}
            {%- endif -%}
          </div>
          <div class="sf2-experience__copy">
            {%- if block.settings.eyebrow != blank -%}{% render 'sf2-eyebrow', text: block.settings.eyebrow, brand: true %}{%- endif -%}
            <h3>{{ block.settings.title }}</h3>
            {%- if block.settings.body != blank -%}<p>{{ block.settings.body }}</p>{%- endif -%}
            {%- if block.settings.link_label != blank -%}
              {% render 'sf2-button', preset: 'text_link', label: block.settings.link_label, url: block.settings.url %}
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Experience Grid",
  "tag": "section",
  "class": "sf2-experience-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Experience Seppeltsfield" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Turn discovery into a visit." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Bookable experiences appear after the collection storytelling so commerce and visitation both receive clear, premium pathways." },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "light", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "standard", "options": [
      { "value": "compact", "label": "Compact" }, { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "experience_card",
      "name": "Experience card",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Taste" },
        { "type": "text", "id": "title", "label": "Title", "default": "Wine Tastings" },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "View tastings" },
        { "type": "url", "id": "url", "label": "URL", "default": "/pages/wine-tastings" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Experience Grid" }]
}
{% endschema %}
