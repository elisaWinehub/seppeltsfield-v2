<section class="spp-section" {% render 'section-style-attributes' %}>
  <div class="section section--{{ section.settings.section_width }}">
    <div class="spp-split" data-reveal>
      <div>
        {% if section.settings.eyebrow != blank %}
          {% render 'heading-eyebrow', text: section.settings.eyebrow %}
        {% endif %}
        <h2 style="font-size:clamp(30px,4vw,56px);color:{{ section.settings.heading_color }};margin-top:14px;">{{ section.settings.heading }}</h2>
        <div style="margin-top:16px;">{{ section.settings.body }}</div>
        {% if section.settings.button_label != blank %}
          <div style="margin-top:24px;">
            {% render 'button', link: section.settings.button_link, text: section.settings.button_label, style: 'outline' %}
          </div>
        {% endif %}
      </div>
      <div class="spp-split__media">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.heading }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .spp-split { display:grid; grid-template-columns: 6fr 4fr; gap: 64px; align-items: center; }
  .spp-split__media img, .spp-split__media svg { width: 100%; height: auto; display: block; }
  @media screen and (max-width: 989px) { .spp-split { grid-template-columns: 1fr; gap: 28px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Story split",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Heritage and story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "175 years of winemaking in the Barossa Valley." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>From 1851 to today, Seppeltsfield has shaped the fortified style of the Barossa and continues to age every vintage in the Centennial Cellar.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Read the story" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f1f2f1" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#0e1012" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#53575b" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 26, "max": 72, "step": 2, "unit": "px", "default": 44 },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 20, "step": 1, "unit": "px", "default": 16 },
    { "type": "select", "id": "padding_top", "label": "Top spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "lg" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "lg" },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{ "value": "page-width", "label": "Page" }, { "value": "full-width", "label": "Full" }], "default": "page-width" }
  ],
  "presets": [{ "name": "Story split" }]
}
{% endschema %}
