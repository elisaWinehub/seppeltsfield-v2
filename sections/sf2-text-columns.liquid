{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}

<section class="sf2-columns sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-columns__grid">
    <div>
      {% render 'sf2-eyebrow', text: section.settings.eyebrow %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
    </div>
    {%- if section.settings.body != blank -%}
      <div class="sf2-columns__body{% if section.settings.column_count == '2' %} sf2-columns__body--2{% endif %} rte">{{ section.settings.body }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "SF2 Text Columns",
  "tag": "section",
  "class": "sf2-columns-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our shared commitment" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A membership with a personal relationship." },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "select", "id": "column_count", "label": "Column count", "default": "2", "options": [
      { "value": "1", "label": "1 column" }, { "value": "2", "label": "2 columns" }
    ]},
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "light", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "standard", "options": [
      { "value": "compact", "label": "Compact" }, { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "presets": [{ "name": "SF2 Text Columns" }]
}
{% endschema %}
