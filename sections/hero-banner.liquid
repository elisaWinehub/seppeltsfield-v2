<section class="spp-section spp-hero {% if section.settings.background_type == 'image' %}spp-bg-image{% endif %}" {% render 'section-style-attributes' %}>
  <div class="section section--{{ section.settings.section_width }} spp-hero-content-wrap">
    <div style="max-width: 860px;" data-reveal>
      {% if section.settings.eyebrow != blank %}
        {% render 'heading-eyebrow', text: section.settings.eyebrow %}
      {% endif %}
      <h1 style="margin-top:16px;font-size:clamp(42px,6vw,88px);line-height:1.02;color:{{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h1>
      {% if section.settings.body != blank %}
        <p style="margin-top:20px;max-width:560px;font-size:17px;">{{ section.settings.body }}</p>
      {% endif %}
      {% if section.settings.button_label != blank %}
        <div style="margin-top:32px;">
          {% render 'button', link: section.settings.button_link, text: section.settings.button_label, style: section.settings.button_style %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .spp-section.spp-bg-image.spp-hero {
    min-height: clamp(420px, 72vh, 860px);
    display: flex;
    align-items: flex-end;
  }
  .spp-hero-content-wrap {
    width: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Seppeltsfield" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Membership built around the barrel." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "First access to Centennial releases, complimentary tastings for you and your guests, and invitations into the cellar itself." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Learn more" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [{ "value": "primary", "label": "Primary" }, { "value": "outline", "label": "Outline" }, { "value": "light", "label": "Light" }], "default": "light" },
    { "type": "select", "id": "background_type", "label": "Background type", "options": [{ "value": "color", "label": "Color" }, { "value": "image", "label": "Image" }], "default": "image" },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 40 },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#0b0c0d" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#f5f7f8" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#f5f7f8" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 28, "max": 96, "step": 2, "unit": "px", "default": 68 },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 22, "step": 1, "unit": "px", "default": 17 },
    { "type": "select", "id": "padding_top", "label": "Top spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "xl" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "lg" },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{ "value": "page-width", "label": "Page" }, { "value": "full-width", "label": "Full" }], "default": "page-width" }
  ],
  "presets": [{ "name": "Hero banner" }]
}
{% endschema %}
