{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: 'plan' -%}

<section id="{{ anchor_id }}" class="sf2-plan sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-plan__grid">
    <div class="sf2-plan__copy">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow, brand: true %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
      {%- if section.settings.link_label != blank -%}
        <div class="sf2-plan__link">
          {% render 'sf2-button', preset: 'text_link', label: section.settings.link_label, url: section.settings.link_url %}
        </div>
      {%- endif -%}
    </div>
    <div class="sf2-plan__list">
      {%- for block in section.blocks -%}
        <div class="sf2-plan__item" {{ block.shopify_attributes }}>
          {% render 'sf2-icon', icon: block.settings.icon %}
          <div>
            <b>{{ block.settings.title }}</b>
            {%- if block.settings.body != blank -%}<span>{{ block.settings.body }}</span>{%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Plan Info",
  "tag": "section",
  "class": "sf2-plan-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "plan" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Plan your visit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Everything guests need before they arrive." },
    { "type": "textarea", "id": "body", "label": "Body" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View visitor information" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "black", "options": [
      { "value": "dark", "label": "Dark" }, { "value": "black", "label": "Black" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "info_item",
      "name": "Info item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "clock", "options": [
          { "value": "clock", "label": "Clock" }, { "value": "map-pin", "label": "Map pin" },
          { "value": "accessibility", "label": "Accessibility" }, { "value": "ev-charge", "label": "EV charge" }
        ]},
        { "type": "text", "id": "title", "label": "Title", "default": "Opening hours" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Plan Info" }]
}
{% endschema %}
