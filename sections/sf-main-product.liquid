    { "type": "color", "id": "button_border", "label": "Button border", "default": "#0F0F0F" },
    { "type": "color", "id": "button_hover_background", "label": "Button hover background", "default": "#0CA7E0" },
    { "type": "color", "id": "button_hover_text", "label": "Button hover text", "default": "#FFFFFF" },

    { "type": "header", "content": "Product media" },
