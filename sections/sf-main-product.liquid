{{ 'sf-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sf-product.js' | asset_url }}" type="module"></script>

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

{% liquid
  assign selected_variant = product.selected_or_first_available_variant
  assign variant_map_id = 'SfVariantMap-' | append: section.id
  assign score_value = product.metafields[section.settings.score_namespace][section.settings.score_key]
  assign breadcrumb_collection = collection
  if breadcrumb_collection == blank or breadcrumb_collection.handle == 'all'
    for coll in product.collections
      if coll.handle != 'all'
        assign breadcrumb_collection = coll
        break
      endif
    endfor
  endif
  assign breadcrumb_block = blank
  for block in section.blocks
    if block.type == 'breadcrumbs'
      assign breadcrumb_block = block
      break
    endif
  endfor
%}

<section
  class="sf-product-main"
  style="
    --sf-product-content-max:
      {% case section.settings.content_width %}
        {% when 'narrow' %}1040px
        {% when 'standard' %}1240px
        {% when 'wide' %}1400px
        {% else %}100vw
      {% endcase %};
    --sf-media-width: {{ section.settings.media_column_width }}%;
    --sf-info-width: {{ section.settings.info_column_width }}%;
    --sf-product-column-gap: {{ section.settings.column_gap }}px;
    --sf-product-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --sf-product-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --sf-product-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --sf-product-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --sf-main-text-color: {{ section.settings.main_text_color }};
    --sf-muted-color: {{ section.settings.muted_text_color }};
    --sf-accent-color: {{ section.settings.accent_color }};
    --sf-border-color: {{ section.settings.border_color }};
    --sf-card-bg: {{ section.settings.card_background }};
    --sf-button-bg: {{ section.settings.button_background }};
    --sf-button-text: {{ section.settings.button_text }};
    --sf-button-border: {{ section.settings.button_border }};
    --sf-button-bg-hover: {{ section.settings.button_hover_background }};
    --sf-button-text-hover: {{ section.settings.button_hover_text }};
    --sf-button-border-hover: {{ section.settings.button_hover_background }};
    color: {{ section.settings.main_text_color }};
    background: {{ section.settings.section_background }};
  "
>
  <script id="{{ variant_map_id }}" type="application/json">
    {
      {% for variant in product.variants %}
        "{{ variant.id }}": {
          "price_text": {{ variant.price | money | json }},
          "compare_at_text": {% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money | json }}{% else %}null{% endif %},
          "featured_media_id": {% if variant.featured_media %}{{ variant.featured_media.id }}{% else %}null{% endif %},
          "selling_plans": {
            {% for allocation in variant.selling_plan_allocations %}
              "{{ allocation.selling_plan.id }}": {
                "price_text": {{ allocation.price | money | json }},
                "compare_at_text": {% if allocation.compare_at_price > allocation.price %}{{ allocation.compare_at_price | money | json }}{% else %}null{% endif %}
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
          },
          "fallback_subscription_text": {{ variant.price | times: 90 | divided_by: 100 | money | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    }
  </script>

  <div class="sf-product-main__grid{% if section.settings.reverse_columns_desktop %} sf-product-main__grid--reverse{% endif %}">
    {% if breadcrumb_block %}
      {% render 'sf-product-info-block',
        product: product,
        block: breadcrumb_block,
        section: section,
        selected_variant: selected_variant,
        variant_map_id: variant_map_id,
        breadcrumb_collection: breadcrumb_collection,
        render_context: 'breadcrumbs_row'
      %}
    {% endif %}

    <div class="sf-product-main__media{% if section.settings.sticky_media %} sf-product-main__media--sticky{% endif %}">
      {% if section.settings.show_score_badge and score_value != blank and section.settings.score_badge_position == 'over_media' %}
        <div
          class="sf-product-score sf-product-score--media"
          style="
            --sf-score-size: {{ section.settings.score_badge_size_desktop }}px;
            --sf-score-bg: {{ section.settings.score_badge_bg }};
            --sf-score-text: {{ section.settings.score_badge_text }};
            --sf-score-border: {{ section.settings.score_badge_border }};
          "
        >
          <span><strong>{{ score_value }}</strong>{{ section.settings.score_suffix }}</span>
        </div>
      {% endif %}
      {% render 'sf-product-media-gallery', product: product, section: section %}
    </div>

    <div class="sf-product-main__info{% if section.settings.sticky_product_info %} sf-product-main__info--sticky{% endif %}">
      {% for block in section.blocks %}
        {% if block.type == 'breadcrumbs' %}
          {% continue %}
        {% endif %}
        {% render 'sf-product-info-block',
          product: product,
          block: block,
          section: section,
          selected_variant: selected_variant,
          variant_map_id: variant_map_id,
          breadcrumb_collection: breadcrumb_collection
        %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
