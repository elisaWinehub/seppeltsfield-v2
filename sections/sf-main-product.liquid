    { "type": "range", "id": "thumbnail_gap", "label": "Thumbnail gap", "min": 2, "max": 20, "step": 1, "unit": "px", "default": 8 },
    { "type": "range", "id": "main_image_max_height", "label": "Main image max height", "min": 420, "max": 980, "step": 10, "unit": "px", "default": 680 },
    { "type": "color", "id": "image_background_color", "label": "Image background colour", "default": "#FFFFFF" },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
