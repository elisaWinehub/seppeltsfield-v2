    { "type": "checkbox", "id": "sticky_media", "label": "Sticky media", "default": false },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 140, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 32 },
