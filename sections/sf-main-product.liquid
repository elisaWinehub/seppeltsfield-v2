    { "type": "range", "id": "info_column_width", "label": "Product information column width", "min": 35, "max": 60, "step": 1, "unit": "%", "default": 44 },
    { "type": "range", "id": "column_gap", "label": "Column gap", "min": 0, "max": 64, "step": 2, "unit": "px", "default": 24 },
