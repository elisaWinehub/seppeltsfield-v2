{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: 'village' -%}

<section id="{{ anchor_id }}" class="sf2-village sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap">
    {% render 'sf2-section-header',
      eyebrow: section.settings.eyebrow,
      eyebrow_brand: true,
      heading: section.settings.heading,
      body: section.settings.body
    %}
    <div class="sf2-village__grid">
      {%- for block in section.blocks -%}
        <a class="sf2-village__card" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          <div>
            {% render 'sf2-eyebrow', text: block.settings.eyebrow, brand: true %}
            <h3>{{ block.settings.title }}</h3>
            {%- if block.settings.body != blank -%}<p>{{ block.settings.body }}</p>{%- endif -%}
          </div>
          {%- if block.settings.meta_label != blank -%}<span class="sf2-village__meta">{{ block.settings.meta_label }}</span>{%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Village Partners",
  "tag": "section",
  "class": "sf2-village-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "village" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Explore the village" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Meet the makers who call Seppeltsfield home." },
    { "type": "textarea", "id": "body", "label": "Body" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "soft_blue", "options": [
      { "value": "soft_blue", "label": "Soft Blue" }, { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "partner",
      "name": "Partner",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Craft + design" },
        { "type": "text", "id": "title", "label": "Title", "default": "JamFactory" },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "text", "id": "meta_label", "label": "Meta label", "default": "Meet the makers" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Village Partners" }]
}
{% endschema %}
