{{ 'sf-about.css' | asset_url | stylesheet_tag }}
<section id="SfAboutCollections-{{ section.id }}" class="sf-about-collections" style="--sf-bg:{{ section.settings.background_color }};--sf-head:{{ section.settings.heading_color }};--sf-text:{{ section.settings.text_color }};--sf-accent:{{ section.settings.accent_color }};--sf-gap:{{ section.settings.card_gap }}px;--sf-pad-top-d:{{ section.settings.padding_top_desktop }}px;--sf-pad-bottom-d:{{ section.settings.padding_bottom_desktop }}px;--sf-pad-top-m:{{ section.settings.padding_top_mobile }}px;--sf-pad-bottom-m:{{ section.settings.padding_bottom_mobile }}px;">
  <div class="sf-about-container">
    <div class="sf-about-collections__head">
      <div>
        {% if section.settings.eyebrow != blank %}<p class="sf-about-collections__eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
        {% if section.settings.heading != blank %}<h2 class="sf-about-collections__heading">{{ section.settings.heading | newline_to_br }}</h2>{% endif %}
      </div>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}<a class="sf-about-link" href="{{ section.settings.link_url }}">{{ section.settings.link_label }}</a>{% endif %}
    </div>
    <div class="sf-about-collections__track">
      {% for block in section.blocks %}
        {%- assign mobile_image = block.settings.mobile_image | default: block.settings.image -%}
        <article class="sf-about-collections__card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 1200 | image_tag: class: 'sf-about-collections__img sf-about-collections__img--desktop', loading: 'lazy', widths: '375,550,750,990,1200', sizes: '(min-width:990px) 20vw, 80vw', alt: block.settings.title }}
            {{ mobile_image | image_url: width: 900 | image_tag: class: 'sf-about-collections__img sf-about-collections__img--mobile', loading: 'lazy', widths: '375,550,750,900', sizes: '(max-width:989px) 80vw, 1px', alt: block.settings.title }}
          {% endif %}
          <div class="sf-about-collections__overlay"></div>
          <div class="sf-about-collections__content">
            {% if block.settings.title != blank %}<h3>{{ block.settings.title }}</h3>{% endif %}
            {% if block.settings.copy != blank %}<p>{{ block.settings.copy }}</p>{% endif %}
            {% if block.settings.link_label != blank and block.settings.link_url != blank %}<a class="sf-about-link" href="{{ block.settings.link_url }}">{{ block.settings.link_label }}</a>{% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% stylesheet %}
.sf-about-collections{background:var(--sf-bg);padding-top:var(--sf-pad-top-d);padding-bottom:var(--sf-pad-bottom-d)}.sf-about-collections__head{display:flex;justify-content:space-between;gap:1rem;align-items:end}.sf-about-collections__eyebrow{margin:0;color:var(--sf-accent);text-transform:uppercase;letter-spacing:.14em;font-size:.75rem}.sf-about-collections__heading{margin:.5rem 0 0;color:var(--sf-head);font-size:clamp(1.7rem,2.6vw,2.8rem)}.sf-about-collections__track{margin-top:1rem;display:grid;grid-auto-flow:column;grid-auto-columns:minmax(12rem,1fr);gap:var(--sf-gap);overflow-x:auto;scroll-snap-type:x mandatory}.sf-about-collections__card{position:relative;min-height:300px;scroll-snap-align:start;overflow:hidden}.sf-about-collections__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.sf-about-collections__img--mobile{display:none}.sf-about-collections__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(5,5,5,.14),rgba(5,5,5,.74))}.sf-about-collections__content{position:relative;z-index:2;color:var(--sf-text);padding:1rem;display:grid;align-content:end;min-height:100%}.sf-about-collections__content h3{margin:0;font-size:.93rem;text-transform:uppercase;letter-spacing:.08em}.sf-about-collections__content p{margin:.5rem 0;font-size:.86rem}@media(max-width:989px){.sf-about-collections{padding-top:var(--sf-pad-top-m);padding-bottom:var(--sf-pad-bottom-m)}.sf-about-collections__img--desktop{display:none}.sf-about-collections__img--mobile{display:block}}
{% endstylesheet %}
{% schema %}
{"name":"SF About Collect","tag":"section","class":"sf-about-section","max_blocks":10,"settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"OUR COLLECTIONS"},{"type":"textarea","id":"heading","label":"Heading","default":"Wines crafted\nto be timeless"},{"type":"text","id":"link_label","label":"Link label","default":"VIEW ALL WINES"},{"type":"url","id":"link_url","label":"Link URL"},{"type":"color","id":"background_color","label":"Background","default":"#F4F1EA"},{"type":"color","id":"heading_color","label":"Heading color","default":"#111315"},{"type":"color","id":"text_color","label":"Text color","default":"#FFFFFF"},{"type":"color","id":"accent_color","label":"Accent color","default":"#47A8DF"},{"type":"range","id":"card_gap","label":"Card gap","min":8,"max":36,"step":2,"unit":"px","default":8},{"type":"range","id":"padding_top_desktop","label":"Desktop padding top","min":0,"max":200,"step":4,"unit":"px","default":56},{"type":"range","id":"padding_bottom_desktop","label":"Desktop padding bottom","min":0,"max":200,"step":4,"unit":"px","default":56},{"type":"range","id":"padding_top_mobile","label":"Mobile padding top","min":0,"max":200,"step":4,"unit":"px","default":32},{"type":"range","id":"padding_bottom_mobile","label":"Mobile padding bottom","min":0,"max":200,"step":4,"unit":"px","default":32}],"blocks":[{"type":"collection_card","name":"Collection card","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"image_picker","id":"mobile_image","label":"Mobile image"},{"type":"text","id":"title","label":"Title","default":"VILLAGE COLLECTION"},{"type":"textarea","id":"copy","label":"Copy","default":"Contemporary, aromatic wines designed to be enjoyed young. Riesling, Vermentino, Grenache Rose, Grenache, Nero d'Avola, Mataro, Touriga and Shiraz."},{"type":"paragraph","content":"Link each card to its matching Shopify collection manually in Theme Editor. Collection handles are not auto-assigned by default."},{"type":"text","id":"link_label","label":"Link label","default":"EXPLORE"},{"type":"url","id":"link_url","label":"Link URL"}]}],"presets":[{"name":"SF About Collect","category":"Seppeltsfield","blocks":[{"type":"collection_card","settings":{"title":"VILLAGE COLLECTION","copy":"Contemporary, aromatic wines designed to be enjoyed young. Riesling, Vermentino, Grenache Rose, Grenache, Nero d'Avola, Mataro, Touriga and Shiraz."}},{"type":"collection_card","settings":{"title":"BENCH BLEND COLLECTION","copy":"The art of assemblage. Traditional blends of Grenache, Shiraz and Mataro; contemporary blends built from Touriga, Tinta Cao and Tinta Amarela."}},{"type":"collection_card","settings":{"title":"THE GROUNDS COLLECTION","copy":"Single-vineyard Shiraz from all four points of the compass - Northing, Easting, Southing and Westing."}},{"type":"collection_card","settings":{"title":"ESTATE ICON VINEYARD","copy":"Bush vine Grenache from the Great Terraced Vineyard. Planted 1855, replanted in contoured rows in 1958, hand-pruned and hand-picked across 250 acres."}},{"type":"collection_card","settings":{"title":"PARA TAWNY COLLECTION","copy":"The heart of the Seppeltsfield fortified range. Para Grand Tawny, Para Rare Tawny and our Single Vintage Tawny releases."}}]}]}
{% endschema %}
