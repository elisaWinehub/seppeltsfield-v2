{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sf2-faq.js' | asset_url }}" defer="defer"></script>

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: 'faq' -%}

<section{% if anchor_id != blank %} id="{{ anchor_id }}"{% endif %} class="sf2-faq sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-faq__grid">
    <div class="sf2-faq__intro">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
    </div>
    <div class="sf2-faq__list">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          {% render 'sf2-accordion-item',
            question: block.settings.question,
            answer: block.settings.answer,
            open_by_default: block.settings.open_by_default,
            id_prefix: block.id
          %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 FAQ",
  "tag": "section",
  "class": "sf2-faq-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "faq" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Frequently asked questions" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Answers before you contact us." },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "light", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "compact", "label": "Compact" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Do I need to book a tasting?" },
        { "type": "richtext", "id": "answer", "label": "Answer" },
        { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [{ "name": "SF2 FAQ" }]
}
{% endschema %}
