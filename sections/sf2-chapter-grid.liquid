{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}

<section class="sf2-chapters sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap">
    {% render 'sf2-section-header',
      eyebrow: section.settings.eyebrow,
      eyebrow_brand: true,
      heading: section.settings.heading,
      body: section.settings.body,
      scheme: 'dark'
    %}
    <div class="sf2-chapters__grid">
      {%- for block in section.blocks -%}
        {%- assign card_class = 'sf2-chapters__card' -%}
        {%- if forloop.first -%}{%- assign card_class = card_class | append: ' sf2-chapters__card--tall' -%}{%- endif -%}
        {%- if forloop.last -%}{%- assign card_class = card_class | append: ' sf2-chapters__card--wide' -%}{%- endif -%}
        <a class="{{ card_class }}" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {% render 'sf2-picture', image: block.settings.image, sizes: '(min-width: 990px) 40vw, 100vw' %}
          {%- endif -%}
          <div class="sf2-chapters__copy">
            {% render 'sf2-eyebrow', text: block.settings.number_label, brand: true %}
            <h3>{{ block.settings.title }}</h3>
            {%- if block.settings.body != blank -%}<p>{{ block.settings.body }}</p>{%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Chapter Grid",
  "tag": "section",
  "class": "sf2-chapters-section",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Explore the story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Five chapters. One remarkable estate." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "These are the five content pillars from the proposed Discover navigation. Each module can link to a deeper anchor, modal, article or dedicated subpage if needed." },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "dark", "options": [
      { "value": "dark", "label": "Dark" }, { "value": "black", "label": "Black" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Chapter card",
      "limit": 4,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "number_label", "label": "Number label", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "History" },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SF2 Chapter Grid",
      "blocks": [
        { "type": "card", "settings": { "number_label": "01", "title": "History", "body": "From the Seppelt family's arrival in 1851 to the estate's next chapter." } },
        { "type": "card", "settings": { "number_label": "02", "title": "The Estate", "body": "Cellars, vineyards, gardens and architecture." } },
        { "type": "card", "settings": { "number_label": "03", "title": "Winemaking", "body": "Tradition, innovation and craftsmanship." } },
        { "type": "card", "settings": { "number_label": "04 — 05", "title": "Awards & Sustainability", "body": "Recognition earned over generations, with a clear commitment to responsible custodianship." } }
      ]
    }
  ]
}
{% endschema %}
