{{ 'sf-wine-club.css' | asset_url | stylesheet_tag }}

{%- liquid
  case section.settings.content_width
    when 'narrow'
      assign content_max = '960px'
    when 'wide'
      assign content_max = '1440px'
    when 'full'
      assign content_max = '100%'
    else
      assign content_max = '1200px'
  endcase
  assign desktop_image = section.settings.desktop_image
  assign mobile_image = section.settings.mobile_image | default: desktop_image
-%}

<section
  id="SfWineClubCrown-{{ section.id }}"
  class="sf-wine-club-crown"
  style="
    --sf-content-max: {{ content_max }};
    --sf-bg: {{ section.settings.background_color }};
    --sf-panel-bg: {{ section.settings.panel_background }};
    --sf-heading: {{ section.settings.heading_color }};
    --sf-copy: {{ section.settings.copy_color }};
    --sf-accent: {{ section.settings.accent_color }};
    --sf-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --sf-pad-bottom-d: {{ section.settings.padding_bottom_desktop }}px;
    --sf-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --sf-pad-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="sf-wine-club-container">
    <div class="sf-wine-club-crown__layout{% if section.settings.reverse_desktop %} is-reverse-desktop{% endif %}{% if section.settings.reverse_mobile %} is-reverse-mobile{% endif %}">
      <div class="sf-wine-club-crown__media">
        {% if desktop_image != blank %}
          {{
            desktop_image
            | image_url: width: 1600
            | image_tag:
              class: 'sf-wine-club-crown__img sf-wine-club-crown__img--desktop',
              loading: 'lazy',
              widths: '550, 750, 990, 1200, 1440, 1600',
              sizes: '(min-width: 990px) 56vw, 100vw',
              alt: desktop_image.alt
          }}
          {{
            mobile_image
            | image_url: width: 1000
            | image_tag:
              class: 'sf-wine-club-crown__img sf-wine-club-crown__img--mobile',
              loading: 'lazy',
              widths: '375, 550, 750, 900, 1000',
              sizes: '(max-width: 989px) 100vw, 1px',
              alt: mobile_image.alt
          }}
        {% endif %}
      </div>
      <div class="sf-wine-club-crown__content">
        {% if section.settings.eyebrow != blank %}
          <p class="sf-wine-club-crown__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="sf-wine-club-crown__heading">{{ section.settings.heading | newline_to_br }}</h2>
        {% endif %}
        {% if section.settings.copy != blank %}
          <p class="sf-wine-club-crown__copy">{{ section.settings.copy }}</p>
        {% endif %}
        {% if section.settings.link_label != blank and section.settings.link_url != blank %}
          <a class="sf-wine-link" href="{{ section.settings.link_url }}">{{ section.settings.link_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .sf-wine-club-crown {
    background: var(--sf-bg);
    padding-top: var(--sf-pad-top-d);
    padding-bottom: var(--sf-pad-bottom-d);
  }
  .sf-wine-club-crown__layout {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 5fr);
  }
  .sf-wine-club-crown__layout.is-reverse-desktop {
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
  }
  .sf-wine-club-crown__layout.is-reverse-desktop .sf-wine-club-crown__media {
    order: 2;
  }
  .sf-wine-club-crown__layout.is-reverse-desktop .sf-wine-club-crown__content {
    order: 1;
  }
  .sf-wine-club-crown__media {
    min-height: 420px;
  }
  .sf-wine-club-crown__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sf-wine-club-crown__img--mobile {
    display: none;
  }
  .sf-wine-club-crown__content {
    background: var(--sf-panel-bg);
    color: var(--sf-copy);
    padding: 1.35rem;
    display: grid;
    align-content: center;
  }
  .sf-wine-club-crown__eyebrow {
    margin: 0;
    color: var(--sf-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
  }
  .sf-wine-club-crown__heading {
    margin: 0.55rem 0 0;
    color: var(--sf-heading);
    line-height: 1.04;
    font-size: clamp(1.8rem, 2.9vw, 3.2rem);
  }
  .sf-wine-club-crown__copy {
    margin: 0.9rem 0 1rem;
    max-width: 50ch;
  }
  @media (max-width: 989px) {
    .sf-wine-club-crown {
      padding-top: var(--sf-pad-top-m);
      padding-bottom: var(--sf-pad-bottom-m);
    }
    .sf-wine-club-crown__layout,
    .sf-wine-club-crown__layout.is-reverse-desktop {
      grid-template-columns: 1fr;
    }
    .sf-wine-club-crown__img--desktop {
      display: none;
    }
    .sf-wine-club-crown__img--mobile {
      display: block;
    }
    .sf-wine-club-crown__layout.is-reverse-mobile .sf-wine-club-crown__media {
      order: 2;
    }
    .sf-wine-club-crown__layout.is-reverse-mobile .sf-wine-club-crown__content {
      order: 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SF Wine Club Crown",
  "tag": "section",
  "class": "sf-wine-club-section",
  "settings": [
    { "type": "paragraph", "content": "Recommended searches: Seppeltsfield Road, Avenue of Hopes and Dreams, THE-AVENUE-OF-PALMS" },
    { "type": "select", "id": "content_width", "label": "Content width", "options": [{ "value": "narrow", "label": "Narrow" }, { "value": "standard", "label": "Standard" }, { "value": "wide", "label": "Wide" }, { "value": "full", "label": "Full width" }], "default": "standard" },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "checkbox", "id": "reverse_desktop", "label": "Reverse columns desktop", "default": false },
    { "type": "checkbox", "id": "reverse_mobile", "label": "Reverse columns mobile", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "CROWN SOCIETY" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Every bottle you enjoy\nbrings you closer." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Earn points with every purchase and experience. Unlock exclusive rewards and elevated benefits as you move through the tiers." },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "DISCOVER CROWN SOCIETY" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#111315" },
    { "type": "color", "id": "panel_background", "label": "Content panel background", "default": "#F4F1EA" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#111315" },
    { "type": "color", "id": "copy_color", "label": "Copy color", "default": "#444444" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#47A8DF" },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 32 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 32 }
  ],
  "presets": [
    {
      "name": "SF Wine Club Crown",
      "category": "Seppeltsfield"
    }
  ]
}
{% endschema %}
