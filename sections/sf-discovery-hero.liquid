{{ 'sf-discovery.css' | asset_url | stylesheet_tag }}

{%- liquid
  case section.settings.content_width
    when 'narrow'
      assign content_max = '960px'
    when 'wide'
      assign content_max = '1440px'
    when 'full'
      assign content_max = '100%'
    else
      assign content_max = '1200px'
  endcase
  assign desktop_image = section.settings.desktop_image
  assign mobile_image = section.settings.mobile_image | default: desktop_image
-%}

<section
  id="SfDiscoveryHero-{{ section.id }}"
  class="sf-discovery-hero"
  style="
    --sf-content-max: {{ content_max }};
    --sf-bg: {{ section.settings.background_color }};
    --sf-overlay: {{ section.settings.overlay_color }};
    --sf-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --sf-head: {{ section.settings.heading_color }};
    --sf-copy: {{ section.settings.copy_color }};
    --sf-eye: {{ section.settings.eyebrow_color }};
    --sf-min-d: {{ section.settings.min_height_desktop }}vh;
    --sf-min-m: {{ section.settings.min_height_mobile }}vh;
    --sf-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --sf-pad-bottom-d: {{ section.settings.padding_bottom_desktop }}px;
    --sf-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --sf-pad-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
    --sf-heading-d: {{ section.settings.heading_size_desktop }}px;
    --sf-heading-m: {{ section.settings.heading_size_mobile }}px;
    --sf-copy-d: {{ section.settings.copy_size_desktop }}px;
    --sf-copy-m: {{ section.settings.copy_size_mobile }}px;
  "
>
  <div class="sf-discovery-hero__media">
    {% if desktop_image != blank %}
      {{
        desktop_image
        | image_url: width: 2200
        | image_tag:
          class: 'sf-discovery-hero__image sf-discovery-hero__image--desktop',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 990, 1200, 1440, 1800, 2200',
          sizes: '100vw',
          alt: desktop_image.alt
      }}
      {{
        mobile_image
        | image_url: width: 1200
        | image_tag:
          class: 'sf-discovery-hero__image sf-discovery-hero__image--mobile',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '375,550,750,990,1200',
          sizes: '100vw',
          alt: mobile_image.alt
      }}
    {% endif %}
  </div>
  <div class="sf-discovery-hero__overlay"></div>
  <div class="sf-discovery-container sf-discovery-hero__inner sf-discovery-hero__inner--{{ section.settings.vertical_alignment }}">
    <div class="sf-discovery-hero__content sf-discovery-hero__content--{{ section.settings.content_alignment }}">
      {% if section.settings.eyebrow != blank %}<p class="sf-discovery-hero__eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
      {% if section.settings.heading != blank %}<h1 class="sf-discovery-hero__heading">{{ section.settings.heading | newline_to_br }}</h1>{% endif %}
      {% if section.settings.copy != blank %}<p class="sf-discovery-hero__copy">{{ section.settings.copy }}</p>{% endif %}
      {% if section.settings.button_label != blank and section.settings.button_url != blank %}
        <a
          href="{{ section.settings.button_url }}"
          class="sf-discovery-button sf-discovery-button--{{ section.settings.button_style }}"
          style="
            --sf-btn-text: {{ section.settings.button_text_color }};
            --sf-btn-bg: {{ section.settings.button_bg_color }};
            --sf-btn-border: {{ section.settings.button_border_color }};
            --sf-btn-hover-text: {{ section.settings.button_hover_text_color }};
            --sf-btn-hover-bg: {{ section.settings.button_hover_bg_color }};
            --sf-btn-hover-border: {{ section.settings.button_hover_bg_color }};
          "
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .sf-discovery-hero {
    position: relative;
    width: 100%;
    max-width: 100%;
    margin-left: 0;
    margin-right: 0;
    background: var(--sf-bg);
    min-height: var(--sf-min-d);
    padding-top: var(--sf-pad-top-d);
    padding-bottom: var(--sf-pad-bottom-d);
    overflow: clip;
  }
  .sf-discovery-hero__media,
  .sf-discovery-hero__overlay {
    position: absolute;
    inset: 0;
  }
  .sf-discovery-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sf-discovery-hero__image--mobile {
    display: none;
  }
  .sf-discovery-hero__overlay {
    background: linear-gradient(180deg, rgba(5, 5, 5, 0.14), rgba(5, 5, 5, 0.68)), var(--sf-overlay);
    opacity: var(--sf-overlay-opacity);
  }
  .sf-discovery-hero__inner {
    position: relative;
    min-height: calc(var(--sf-min-d) - var(--sf-pad-top-d) - var(--sf-pad-bottom-d));
    display: grid;
    align-content: end;
  }
  .sf-discovery-hero__inner--start { align-content: start; }
  .sf-discovery-hero__inner--center { align-content: center; }
  .sf-discovery-hero__inner--end { align-content: end; }
  .sf-discovery-hero__content {
    max-width: 660px;
  }
  .sf-discovery-hero__content--center { text-align: center; margin-inline: auto; }
  .sf-discovery-hero__content--right { text-align: right; margin-left: auto; }
  .sf-discovery-hero__eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: clamp(0.62rem, 0.9vw, 0.8rem);
    color: var(--sf-eye);
  }
  .sf-discovery-hero__heading {
    margin: 0.6rem 0 0;
    font-size: var(--sf-heading-d);
    line-height: 1.02;
    color: var(--sf-head);
    max-width: 15ch;
  }
  .sf-discovery-hero__copy {
    margin: 0.95rem 0 1.3rem;
    color: var(--sf-copy);
    font-size: var(--sf-copy-d);
    max-width: 52ch;
  }
  @media (max-width: 989px) {
    .sf-discovery-hero {
      min-height: var(--sf-min-m);
      padding-top: var(--sf-pad-top-m);
      padding-bottom: var(--sf-pad-bottom-m);
    }
    .sf-discovery-hero__image--desktop { display: none; }
    .sf-discovery-hero__image--mobile { display: block; }
    .sf-discovery-hero__heading { font-size: var(--sf-heading-m); }
    .sf-discovery-hero__copy { font-size: var(--sf-copy-m); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SF Discover Hero",
  "tag": "section",
  "class": "sf-discovery-section",
  "settings": [
    { "type": "paragraph", "content": "Recommended search: Seppeltsfield Road, Avenue of Hopes and Dreams, THE-AVENUE-OF-PALMS" },
    { "type": "select", "id": "content_width", "label": "Content width", "options": [{ "value": "narrow", "label": "Narrow" }, { "value": "standard", "label": "Standard" }, { "value": "wide", "label": "Wide" }, { "value": "full", "label": "Full width" }], "default": "standard" },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#050505" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#111315" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 40 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "VISIT SEPPELTSFIELD" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "A place to\nexperience, stay\nand savour." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Set in the heart of the Barossa Valley, Seppeltsfield is a historic estate offering memorable experiences, exceptional dining, heritage accommodation and warm hospitality." },
    { "type": "select", "id": "content_alignment", "label": "Horizontal alignment", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" }], "default": "left" },
    { "type": "select", "id": "vertical_alignment", "label": "Vertical alignment", "options": [{ "value": "start", "label": "Top" }, { "value": "center", "label": "Center" }, { "value": "end", "label": "Bottom" }], "default": "end" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#F4F1EA" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#FFFFFF" },
    { "type": "color", "id": "copy_color", "label": "Copy color", "default": "#F4F1EA" },
    { "type": "range", "id": "heading_size_desktop", "label": "Heading size desktop", "min": 36, "max": 110, "step": 2, "unit": "px", "default": 74 },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size mobile", "min": 30, "max": 64, "step": 2, "unit": "px", "default": 42 },
    { "type": "range", "id": "copy_size_desktop", "label": "Copy size desktop", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 17 },
    { "type": "range", "id": "copy_size_mobile", "label": "Copy size mobile", "min": 12, "max": 20, "step": 1, "unit": "px", "default": 15 },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "PLAN YOUR VISIT" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [{ "value": "solid", "label": "Solid" }, { "value": "outline", "label": "Outline" }, { "value": "text", "label": "Text link" }], "default": "solid" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#FFFFFF" },
    { "type": "color", "id": "button_bg_color", "label": "Button background color", "default": "#47A8DF" },
    { "type": "color", "id": "button_border_color", "label": "Button border color", "default": "#47A8DF" },
    { "type": "color", "id": "button_hover_text_color", "label": "Button hover text", "default": "#FFFFFF" },
    { "type": "color", "id": "button_hover_bg_color", "label": "Button hover background", "default": "#0B8BB9" },
    { "type": "range", "id": "min_height_desktop", "label": "Min height desktop", "min": 60, "max": 100, "step": 2, "unit": "vh", "default": 86 },
    { "type": "range", "id": "min_height_mobile", "label": "Min height mobile", "min": 50, "max": 100, "step": 2, "unit": "vh", "default": 72 },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 36 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 28 }
  ],
  "presets": [{ "name": "SF Discover Hero", "category": "Seppeltsfield" }]
}
{% endschema %}
