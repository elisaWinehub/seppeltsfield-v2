{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: '' -%}

<section{% if anchor_id != blank %} id="{{ anchor_id }}"{% endif %} class="sf2-cta-banner sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-cta-banner__grid">
    <div>
      {%- if section.settings.eyebrow != blank -%}{% render 'sf2-eyebrow', text: section.settings.eyebrow %}{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="sf2-serif">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    </div>
    {%- if section.settings.button_label != blank -%}
      {% render 'sf2-button', preset: section.settings.button_preset, label: section.settings.button_label, url: section.settings.button_url %}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "SF2 CTA Banner",
  "tag": "section",
  "class": "sf2-cta-banner-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Become a member" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose your Crown Society selection." },
    { "type": "textarea", "id": "body", "label": "Body" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join the Crown Society" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "select", "id": "button_preset", "label": "Button preset", "default": "primary_dark", "options": [
      { "value": "primary_blue", "label": "Primary Blue" }, { "value": "primary_dark", "label": "Primary Dark" }, { "value": "light", "label": "Light" }
    ]},
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID (advanced)" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "brand_blue", "options": [
      { "value": "brand_blue", "label": "Brand Blue" }, { "value": "dark", "label": "Dark" }, { "value": "black", "label": "Black" }, { "value": "light", "label": "Light" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "compact", "options": [
      { "value": "compact", "label": "Compact" }, { "value": "standard", "label": "Standard" }
    ]}
  ],
  "presets": [{ "name": "SF2 CTA Banner" }]
}
{% endschema %}
