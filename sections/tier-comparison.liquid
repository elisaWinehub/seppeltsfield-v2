<section class="spp-section" {% render 'section-style-attributes' %}>
  <div class="section section--{{ section.settings.section_width }}">
    <div class="section-head" style="text-align:center;" data-reveal>
      {% if section.settings.eyebrow != blank %}{% render 'heading-eyebrow', text: section.settings.eyebrow %}{% endif %}
      <h2 style="margin-top:14px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
    </div>
    <div class="spp-tier-grid">
      {% for block in section.blocks %}
        <article class="spp-tier {% if block.settings.featured %}is-featured{% endif %}" data-reveal {{ block.shopify_attributes }}>
          <span class="spp-tier__label">{{ block.settings.label }}</span>
          <h3>{{ block.settings.price }}</h3>
          <p>{{ block.settings.description }}</p>
          {% if block.settings.cta != blank %}
            {% render 'button', link: block.settings.link, text: block.settings.cta, style: block.settings.button_style %}
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .spp-tier-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:24px; }
  .spp-tier { background:#fff; border:1px solid var(--spp-line); padding:32px 28px; }
  .spp-tier.is-featured { background: var(--spp-dark); color:#fff; }
  .spp-tier__label { font-size:11px; letter-spacing:2px; text-transform: uppercase; color: var(--spp-accent); }
  .spp-tier h3 { margin: 12px 0 8px; color: inherit; }
  .spp-tier p { margin: 0 0 18px; }
  @media screen and (max-width: 989px) { .spp-tier-grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Tier comparison",
  "blocks": [
    { "type": "tier", "name": "Tier", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Crown Society" },
      { "type": "text", "id": "price", "label": "Price", "default": "$180 / year" },
      { "type": "textarea", "id": "description", "label": "Description", "default": "Core membership with cellar access and priority allocations." },
      { "type": "text", "id": "cta", "label": "Button label", "default": "Join this tier" },
      { "type": "url", "id": "link", "label": "Button link" },
      { "type": "select", "id": "button_style", "label": "Button style", "options": [{ "value": "primary", "label": "Primary" }, { "value": "outline", "label": "Outline" }, { "value": "light", "label": "Light" }], "default": "outline" },
      { "type": "checkbox", "id": "featured", "label": "Featured", "default": false }
    ] }
  ],
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Membership" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose your tier" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f1f2f1" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#0e1012" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#53575b" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 22, "max": 56, "step": 2, "unit": "px", "default": 44 },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 20, "step": 1, "unit": "px", "default": 16 },
    { "type": "select", "id": "padding_top", "label": "Top spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "lg" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "lg" },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{ "value": "page-width", "label": "Page" }, { "value": "full-width", "label": "Full" }], "default": "page-width" }
  ],
  "presets": [{ "name": "Tier comparison", "blocks": [{ "type": "tier" }, { "type": "tier" }, { "type": "tier" }] }]
}
{% endschema %}
