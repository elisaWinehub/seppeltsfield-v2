{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sf2-header.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign logo = settings.logo
  if settings.logo_inverse != blank
    assign logo_inverse = settings.logo_inverse
  else
    assign logo_inverse = settings.logo
  endif
  assign logo_w = section.settings.logo_width | default: settings.logo_height | default: 36
  assign menu = section.settings.main_menu
  assign transparent = false
  if section.settings.transparency_mode == 'always_transparent'
    assign transparent = true
  elsif section.settings.transparency_mode == 'auto' and template.name == 'index'
    assign transparent = true
  endif
-%}

<header
  class="sf2-header{% if transparent %} sf2-header--transparent{% endif %}"
  data-sf2-header
  data-transparency="{{ section.settings.transparency_mode }}"
  style="--sf2-logo-width: {{ logo_w }}px;"
>
  <div class="sf2-wrap sf2-header__nav">
    <a class="sf2-header__logo" href="{{ routes.root_url }}">
      {%- if logo_inverse != blank -%}
        {{ logo_inverse | image_url: width: 400 | image_tag: widths: '200,300,400', sizes: '188px', alt: shop.name, loading: 'eager' }}
      {%- else -%}
        <span class="sf2-serif">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- if menu != blank -%}
      <ul class="sf2-header__links" aria-label="Primary">
        {%- for link in menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    <div class="sf2-header__actions">
      {% render 'sf2-button', preset: 'light', label: section.settings.cta_label, url: section.settings.cta_url, class: 'sf2-header__cta' %}
      <button class="sf2-header__round sf2-header__menu-btn" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="Sf2HeaderDrawer-{{ section.id }}" data-sf2-menu-open>
        <span class="sf2-icon">{{ 'icon-menu.svg' | inline_asset_content }}</span>
      </button>
      <button class="sf2-header__round" type="button" aria-label="Search" on:click="#search-modal/showDialog">
        {% render 'sf2-icon', icon: 'search' %}
      </button>
      <a class="sf2-header__round" href="{{ routes.account_url }}" aria-label="Account">
        {% render 'sf2-icon', icon: 'account' %}
      </a>
      <button class="sf2-header__round" type="button" aria-label="Cart" on:click="#cart-drawer/toggle" aria-controls="cart-drawer">
        {% render 'sf2-icon', icon: 'cart' %}
      </button>
    </div>
  </div>

  <div class="sf2-header__drawer" id="Sf2HeaderDrawer-{{ section.id }}" data-sf2-drawer hidden>
    <button class="sf2-header__drawer-backdrop" type="button" aria-label="Close menu" data-sf2-menu-close></button>
    <div class="sf2-header__drawer-panel" role="dialog" aria-modal="true" aria-label="Mobile menu">
      <button class="sf2-header__round" type="button" aria-label="Close menu" data-sf2-menu-close>×</button>
      {%- if menu != blank -%}
        <ul class="sf2-header__drawer-nav">
          {%- for link in menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
      {% render 'sf2-button', preset: 'light', label: section.settings.cta_label, url: section.settings.cta_url %}
    </div>
  </div>
</header>

{% schema %}
{
  "name": "SF2 Header",
  "tag": "section",
  "class": "sf2-header-section",
  "settings": [
    { "type": "range", "id": "logo_width", "label": "Logo width", "min": 100, "max": 240, "step": 4, "default": 188, "unit": "px" },
    { "type": "link_list", "id": "main_menu", "label": "Main menu", "default": "main-menu" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Book Experience" },
    { "type": "url", "id": "cta_url", "label": "CTA URL", "default": "/pages/book-experience" },
    { "type": "select", "id": "transparency_mode", "label": "Transparency", "default": "auto", "options": [
      { "value": "auto", "label": "Auto (transparent over hero)" },
      { "value": "always_transparent", "label": "Always transparent" },
      { "value": "always_solid", "label": "Always solid" }
    ]}
  ],
  "presets": [{ "name": "SF2 Header" }]
}
{% endschema %}
