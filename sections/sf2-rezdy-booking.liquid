{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sf2-rezdy-booking.js' | asset_url }}" defer="defer"></script>

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: 'rezdy-booking' -%}

<section id="{{ anchor_id }}" class="sf2-rezdy sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-rezdy__grid">
    <div class="sf2-rezdy__copy">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow, brand: true %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <div class="sf2-rezdy__notes">
          {%- for block in section.blocks -%}
            <div class="sf2-rezdy__note" {{ block.shopify_attributes }}>
              {% render 'sf2-icon', icon: block.settings.icon %}
              <div>
                <b>{{ block.settings.title }}</b>
                <span>{{ block.settings.body }}</span>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
      {%- if section.settings.fallback_link_label != blank and section.settings.fallback_link_url != blank -%}
        <div class="sf2-rezdy__fallback">
          {% render 'sf2-button', preset: 'text_link', label: section.settings.fallback_link_label, url: section.settings.fallback_link_url, new_tab: true %}
        </div>
      {%- endif -%}
    </div>
    <div class="sf2-rezdy__embed" data-sf2-rezdy data-iframe-url="{{ section.settings.iframe_url | escape }}" data-iframe-height="{{ section.settings.iframe_height | default: 1000 }}">
      <div class="sf2-rezdy__shell">
        <div class="sf2-rezdy__shell-head">
          <span>{{ section.settings.iframe_label }}</span>
          <small>{{ section.settings.iframe_powered_by }}</small>
        </div>
        <div class="sf2-rezdy__frame-wrap">
          <div class="sf2-rezdy__loading" data-sf2-rezdy-loading aria-hidden="true">
            <span class="sf2-rezdy__spinner"></span>
            <span>Loading booking catalogue…</span>
          </div>
          <iframe
            data-sf2-rezdy-iframe
            title="{{ section.settings.iframe_label | escape }}"
            loading="lazy"
            hidden
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<style>html { scroll-behavior: smooth; scroll-padding-top: 84px; }</style>

{% schema %}
{
  "name": "SF2 Rezdy Booking",
  "tag": "section",
  "class": "sf2-rezdy-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "rezdy-booking" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Tours and tastings" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Book directly through Rezdy." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The existing third-party booking system can remain embedded, but the surrounding page should feel fully integrated with the Seppeltsfield design system." },
    { "type": "text", "id": "iframe_url", "label": "Rezdy iframe URL", "default": "https://seppeltsfield.rezdy.com/catalog/108982/tours-tastings?iframe=true" },
    { "type": "range", "id": "iframe_height", "label": "Iframe height", "min": 600, "max": 1400, "step": 50, "unit": "px", "default": 1000 },
    { "type": "text", "id": "iframe_label", "label": "Iframe label", "default": "Live tours and tastings" },
    { "type": "text", "id": "iframe_powered_by", "label": "Powered by label", "default": "Powered by Rezdy" },
    { "type": "text", "id": "fallback_link_label", "label": "Fallback link label", "default": "Open booking catalogue" },
    { "type": "url", "id": "fallback_link_url", "label": "Fallback link URL" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "soft_blue", "options": [
      { "value": "soft_blue", "label": "Soft Blue" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "booking_note",
      "name": "Booking note",
      "limit": 3,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "clock", "options": [
          { "value": "clock", "label": "Clock" }, { "value": "catalogue", "label": "Catalogue" }, { "value": "shield-lock", "label": "Shield" }
        ]},
        { "type": "text", "id": "title", "label": "Title", "default": "Choose a date and time" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Rezdy Booking" }]
}
{% endschema %}
