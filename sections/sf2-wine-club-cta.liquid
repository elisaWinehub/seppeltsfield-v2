{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-home.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}

<section class="sf2-club sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-club__grid">
    <div class="sf2-club__crown">{% render 'sf2-icon', icon: section.settings.icon, size: 58 %}</div>
    <div>
      {% render 'sf2-eyebrow', text: section.settings.eyebrow, brand: true %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    </div>
    {%- if section.settings.button_label != blank -%}
      {% render 'sf2-button', preset: 'primary_blue', label: section.settings.button_label, url: section.settings.button_url %}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "SF2 Wine Club CTA",
  "tag": "section",
  "class": "sf2-club-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Crown Society" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Membership worthy of the estate." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Exclusive wine access, member pricing, complimentary delivery and private Seppeltsfield experiences." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore Membership" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "select", "id": "icon", "label": "Icon", "default": "crown", "options": [
      { "value": "crown", "label": "Crown" }
    ]},
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "black", "options": [
      { "value": "dark", "label": "Dark" }, { "value": "black", "label": "Black" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "compact", "options": [
      { "value": "compact", "label": "Compact" }, { "value": "standard", "label": "Standard" }
    ]}
  ],
  "presets": [{ "name": "SF2 Wine Club CTA" }]
}
{% endschema %}
