{{ 'sf-events.css' | asset_url | stylesheet_tag }}

{%- liquid
  case section.settings.content_width
    when 'narrow'
      assign content_max = '960px'
    when 'wide'
      assign content_max = '1440px'
    when 'full'
      assign content_max = '100%'
    else
      assign content_max = '1200px'
  endcase
-%}

<section
  id="SfEventsBenefits-{{ section.id }}"
  class="sf-events-benefits"
  style="
    --sf-content-max: {{ content_max }};
    --sf-bg: {{ section.settings.background_color }};
    --sf-text: {{ section.settings.text_color }};
    --sf-accent: {{ section.settings.accent_color }};
    --sf-divider: {{ section.settings.divider_color }};
    --sf-cols-d: {{ section.settings.columns_desktop }};
    --sf-cols-t: {{ section.settings.columns_tablet }};
    --sf-gap: {{ section.settings.grid_gap }}px;
    --sf-item-pad: {{ section.settings.item_padding }}px;
    --sf-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --sf-pad-bottom-d: {{ section.settings.padding_bottom_desktop }}px;
    --sf-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --sf-pad-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="sf-events-container">
    <div class="sf-events-benefits__grid sf-events-benefits__grid--mobile-{{ section.settings.mobile_layout }}">
      {% for block in section.blocks %}
        {%- liquid
          case block.settings.icon
            when 'heritage'
              assign icon_text = 'HB'
            when 'wine'
              assign icon_text = 'WG'
            when 'dining'
              assign icon_text = 'DC'
            when 'people'
              assign icon_text = 'PP'
            when 'calendar'
              assign icon_text = 'CL'
            when 'location'
              assign icon_text = 'LC'
            when 'gift'
              assign icon_text = 'GF'
            else
              assign icon_text = 'SF'
          endcase
        -%}
        <article class="sf-events-benefits__item{% if block.settings.featured %} is-featured{% endif %}" {{ block.shopify_attributes }}>
          <div class="sf-events-benefits__icon">
            {% if block.settings.custom_icon != blank %}
              {{
                block.settings.custom_icon
                | image_url: width: 120
                | image_tag: loading: 'lazy', widths: '40,60,80,120', sizes: '40px', alt: block.settings.heading
              }}
            {% else %}
              <span>{{ icon_text }}</span>
            {% endif %}
          </div>
          {% if block.settings.heading != blank %}<h3>{{ block.settings.heading }}</h3>{% endif %}
          {% if block.settings.copy != blank %}<p>{{ block.settings.copy }}</p>{% endif %}
          {% if block.settings.link_label != blank and block.settings.link_url != blank %}
            <a class="sf-events-link" href="{{ block.settings.link_url }}">{{ block.settings.link_label }}</a>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .sf-events-benefits { background: var(--sf-bg); color: var(--sf-text); padding-top: var(--sf-pad-top-d); padding-bottom: var(--sf-pad-bottom-d); }
  .sf-events-benefits__grid { display: grid; grid-template-columns: repeat(var(--sf-cols-d), minmax(0, 1fr)); gap: var(--sf-gap); }
  .sf-events-benefits__item { border: 1px solid color-mix(in srgb, var(--sf-divider) 65%, transparent); padding: var(--sf-item-pad); min-height: 150px; }
  .sf-events-benefits__item.is-featured { border-color: var(--sf-accent); }
  .sf-events-benefits__icon { color: var(--sf-accent); min-height: 1.6rem; }
  .sf-events-benefits__icon img { width: 24px; height: 24px; object-fit: contain; }
  .sf-events-benefits__icon span { font-size: .78rem; letter-spacing: .08em; text-transform: uppercase; }
  .sf-events-benefits__item h3 { margin: .5rem 0 0; text-transform: uppercase; letter-spacing: .08em; font-size: .83rem; }
  .sf-events-benefits__item p { margin: .45rem 0 .5rem; font-size: .9rem; color: color-mix(in srgb, var(--sf-text) 80%, transparent); }
  @media (max-width: 989px) {
    .sf-events-benefits { padding-top: var(--sf-pad-top-m); padding-bottom: var(--sf-pad-bottom-m); }
    .sf-events-benefits__grid { grid-template-columns: repeat(var(--sf-cols-t), minmax(0, 1fr)); }
    .sf-events-benefits__grid--mobile-scroll {
      grid-template-columns: unset;
      grid-auto-flow: column;
      grid-auto-columns: minmax(84vw, 1fr);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
    }
    .sf-events-benefits__grid--mobile-scroll .sf-events-benefits__item { scroll-snap-align: start; }
    .sf-events-benefits__grid--mobile-stack { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SF Events Benefit",
  "tag": "section",
  "class": "sf-events-section",
  "max_blocks": 8,
  "settings": [
    { "type": "select", "id": "content_width", "label": "Content width", "options": [{ "value": "narrow", "label": "Narrow" }, { "value": "standard", "label": "Standard" }, { "value": "wide", "label": "Wide" }, { "value": "full", "label": "Full width" }], "default": "standard" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#050505" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#47A8DF" },
    { "type": "color", "id": "divider_color", "label": "Divider color", "default": "#2f3338" },
    { "type": "range", "id": "columns_desktop", "label": "Desktop columns", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_tablet", "label": "Tablet columns", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "select", "id": "mobile_layout", "label": "Mobile layout", "options": [{ "value": "scroll", "label": "Horizontal scroll" }, { "value": "stack", "label": "Stacked" }], "default": "scroll" },
    { "type": "range", "id": "grid_gap", "label": "Grid gap", "min": 8, "max": 36, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "item_padding", "label": "Item padding", "min": 8, "max": 40, "step": 2, "unit": "px", "default": 16 },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 16 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 16 }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "heritage", "label": "Heritage building" }, { "value": "wine", "label": "Wine glass" }, { "value": "dining", "label": "Dining cloche" }, { "value": "people", "label": "People" }, { "value": "calendar", "label": "Calendar" }, { "value": "location", "label": "Location" }, { "value": "gift", "label": "Gift" }], "default": "heritage" },
        { "type": "image_picker", "id": "custom_icon", "label": "Custom icon image" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "HERITAGE VENUES" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Unique spaces across the estate steeped in history." },
        { "type": "text", "id": "link_label", "label": "Link label" },
        { "type": "url", "id": "link_url", "label": "Link URL" },
        { "type": "checkbox", "id": "featured", "label": "Featured", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "SF Events Benefit",
      "category": "Seppeltsfield",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "heritage", "heading": "HERITAGE VENUES", "copy": "Unique spaces across the estate steeped in history." } },
        { "type": "benefit", "settings": { "icon": "dining", "heading": "TAILORED EXPERIENCES", "copy": "Custom menus and wine pairings curated for your event." } },
        { "type": "benefit", "settings": { "icon": "wine", "heading": "AWARD-WINNING WINES", "copy": "Exceptional wines from our family estate." } },
        { "type": "benefit", "settings": { "icon": "people", "heading": "SEAMLESS SERVICE", "copy": "Our experienced team ensures every detail is perfect." } }
      ]
    }
  ]
}
{% endschema %}
