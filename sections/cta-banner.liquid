<section class="spp-section" {% render 'section-style-attributes' %}>
  <div class="spp-cta-banner">
    <div class="section section--{{ section.settings.section_width }}">
      <div class="spp-cta-banner__inner" data-reveal>
        <div>
          {% if section.settings.eyebrow != blank %}{% render 'heading-eyebrow', text: section.settings.eyebrow %}{% endif %}
          <h2 style="margin-top:12px;">{{ section.settings.heading }}</h2>
          {% if section.settings.body != blank %}<p style="margin-top:10px;">{{ section.settings.body }}</p>{% endif %}
        </div>
        {% if section.settings.button_label != blank %}
          {% render 'button', link: section.settings.button_link, text: section.settings.button_label, style: section.settings.button_style %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .spp-cta-banner { background: var(--spp-bg-color); color: var(--spp-text-color); }
  .spp-cta-banner__inner { min-height: 220px; display: flex; align-items: center; justify-content: space-between; gap: 22px; flex-wrap: wrap; }
{% endstylesheet %}

{% schema %}
{
  "name": "CTA banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Crown Society" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Every bottle you enjoy brings you closer." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Earn points on each purchase and unlock member-only rewards." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore Crown Society" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "select", "id": "button_style", "label": "Style", "options": [{"value":"primary","label":"Solid"},{"value":"outline","label":"Outline"},{"value":"light","label":"Light (for dark/image backgrounds)"}], "default": "light" },
    { "type": "select", "id": "padding_top", "label": "Top padding", "options": [{"value":"sm","label":"Small"},{"value":"md","label":"Medium"},{"value":"lg","label":"Large"},{"value":"xl","label":"Extra large"}], "default": "md" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom padding", "options": [{"value":"sm","label":"Small"},{"value":"md","label":"Medium"},{"value":"lg","label":"Large"},{"value":"xl","label":"Extra large"}], "default": "md" },
    { "type": "select", "id": "background_type", "label": "Background type", "options": [{"value":"color","label":"Color"},{"value":"image","label":"Image"}], "default": "color" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#469CC0" },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Image overlay darkness", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 0 },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#F5F7F8" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 24, "max": 96, "step": 2, "unit": "px", "default": 36 },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#F5F7F8" },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{"value":"page-width","label":"Page"},{"value":"full-width","label":"Full"}], "default": "page-width" }
  ],
  "presets": [{ "name": "CTA banner" }]
}
{% endschema %}
