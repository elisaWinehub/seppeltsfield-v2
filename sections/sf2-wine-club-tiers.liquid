{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: 'membership' -%}

<section id="{{ anchor_id }}" class="sf2-tiers sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap">
    {% render 'sf2-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      body: section.settings.body
    %}
    <div class="sf2-tiers__grid">
      {%- for block in section.blocks -%}
        <article class="sf2-tiers__card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="sf2-tiers__media">
              {% render 'sf2-picture', image: block.settings.image, fit: 'contain', sizes: '(min-width: 990px) 33vw, 100vw' %}
            </div>
          {%- endif -%}
          <div class="sf2-tiers__copy">
            {% render 'sf2-eyebrow', text: block.settings.eyebrow, brand: true %}
            <h3>{{ block.settings.title }}</h3>
            {%- if block.settings.body != blank -%}<div>{{ block.settings.body }}</div>{%- endif -%}
            <div class="sf2-tiers__list">
              {%- if block.settings.feature_1 != blank -%}<div>{{ block.settings.feature_1 }}</div>{%- endif -%}
              {%- if block.settings.feature_2 != blank -%}<div>{{ block.settings.feature_2 }}</div>{%- endif -%}
              {%- if block.settings.feature_3 != blank -%}<div>{{ block.settings.feature_3 }}</div>{%- endif -%}
            </div>
            {%- if block.settings.button_label != blank -%}
              {% render 'sf2-button', preset: 'primary_dark', label: block.settings.button_label, url: block.settings.button_url %}
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>html { scroll-behavior: smooth; scroll-padding-top: 80px; }</style>

{% schema %}
{
  "name": "SF2 Wine Club Tiers",
  "tag": "section",
  "class": "sf2-tiers-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "membership" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Choose your selection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three ways to join." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Each tier can later be powered by a product, subscription app, club plan or custom membership flow in Shopify." },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "ivory", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Tier",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bright and fresh" },
        { "type": "text", "id": "title", "label": "Title", "default": "Whites & Lights" },
        { "type": "richtext", "id": "body", "label": "Body" },
        { "type": "text", "id": "feature_1", "label": "Feature 1", "default": "Curated mixed selection" },
        { "type": "text", "id": "feature_2", "label": "Feature 2", "default": "Preferred member pricing" },
        { "type": "text", "id": "feature_3", "label": "Feature 3", "default": "Flexible annual delivery" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Choose This Selection" },
        { "type": "url", "id": "button_url", "label": "Button URL" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Wine Club Tiers" }]
}
{% endschema %}
