<section class="spp-section {% if section.settings.background_color == '#0C0D10' %}spp-band-dark{% endif %}" {% render 'section-style-attributes' %}>
  <div class="section section--{{ section.settings.section_width }}">
    {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
      <div class="section-head" data-reveal>
        {% if section.settings.eyebrow != blank %}{% render 'heading-eyebrow', text: section.settings.eyebrow %}{% endif %}
        {% if section.settings.heading != blank %}<h2 style="margin-top:14px;">{{ section.settings.heading }}</h2>{% endif %}
      </div>
    {% endif %}
    <div class="spp-tile-grid spp-tile-grid--{{ section.settings.columns }}">
      {% for block in section.blocks %}
        <article class="spp-tile" {{ block.shopify_attributes }} data-reveal>
          <div class="spp-tile__media">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {% else %}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
            <div class="spp-tile__overlay"></div>
            <span class="spp-tile__icon">{{ block.settings.icon }}</span>
          </div>
          <div class="spp-tile__content">
            <h3>{{ block.settings.title }}</h3>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}">Explore</a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .spp-tile-grid { display: grid; gap: 16px; }
  .spp-tile-grid--3 { grid-template-columns: repeat(3,minmax(0,1fr)); }
  .spp-tile-grid--4 { grid-template-columns: repeat(4,minmax(0,1fr)); }
  .spp-tile-grid--5 { grid-template-columns: repeat(5,minmax(0,1fr)); }
  .spp-tile { background: #111; position: relative; overflow: hidden; }
  .spp-tile__media { position: relative; }
  .spp-tile__media img, .spp-tile__media svg { width: 100%; display: block; aspect-ratio: 4/5; object-fit: cover; }
  .spp-tile__overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,.72), rgba(0,0,0,.1)); }
  .spp-tile__icon { position: absolute; left: 14px; top: 14px; color: #f5f7f8; }
  .spp-tile__content { position: absolute; left: 14px; right: 14px; bottom: 14px; color: #f5f7f8; }
  .spp-tile__content h3 { margin: 0 0 6px; color: inherit; }
  .spp-tile__content a { color: #f5f7f8; text-decoration: underline; }
  @media (max-width: 1024px) { .spp-tile-grid--4, .spp-tile-grid--5 { grid-template-columns: repeat(2,minmax(0,1fr)); } }
  @media (max-width: 700px) { .spp-tile-grid--3, .spp-tile-grid--4, .spp-tile-grid--5 { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Tile row",
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "icon", "label": "Icon", "default": "◌" },
        { "type": "text", "id": "title", "label": "Title", "default": "Estate Tasting" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Experiences" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "More than wine. A place to belong." },
    { "type": "select", "id": "columns", "label": "Columns", "options": [{ "value":"3","label":"3" }, { "value":"4","label":"4" }, { "value":"5","label":"5" }], "default": "4" },
    { "type": "select", "id": "padding_top", "label": "Top padding", "options": [{ "value":"sm","label":"Small" },{ "value":"md","label":"Medium" },{ "value":"lg","label":"Large" },{ "value":"xl","label":"Extra large" }], "default": "lg" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom padding", "options": [{ "value":"sm","label":"Small" },{ "value":"md","label":"Medium" },{ "value":"lg","label":"Large" },{ "value":"xl","label":"Extra large" }], "default": "lg" },
    { "type": "select", "id": "background_type", "label": "Background type", "options": [{ "value":"color","label":"Color" },{ "value":"image","label":"Image" }], "default": "color" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#0C0D10" },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Image overlay darkness", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 0 },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#F5F7F8" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 24, "max": 96, "step": 2, "unit": "px", "default": 36 },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#F5F7F8" },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{ "value":"page-width","label":"Page" }, { "value":"full-width","label":"Full" }], "default": "page-width" }
  ],
  "presets": [{ "name": "Tile row", "blocks": [{ "type": "tile" }, { "type": "tile" }, { "type": "tile" }] }]
}
{% endschema %}
