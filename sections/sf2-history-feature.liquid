{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: 'history' -%}

<section id="{{ anchor_id }}" class="sf2-history sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-history__grid">
    <div class="sf2-history__media">
      {%- if section.settings.image != blank -%}
        {% render 'sf2-picture', image: section.settings.image, sizes: '(min-width: 990px) 50vw, 100vw' %}
      {%- endif -%}
      <div class="sf2-history__label">
        {% render 'sf2-eyebrow', text: section.settings.label_eyebrow, brand: true %}
        <strong>{{ section.settings.label_heading }}</strong>
      </div>
    </div>
    <div class="sf2-history__copy">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<div>{{ section.settings.body }}</div>{%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <div class="sf2-history__stats">
          {%- for block in section.blocks -%}
            <div class="sf2-history__stat" {{ block.shopify_attributes }}>
              <strong>{{ block.settings.value }}</strong>
              <span>{{ block.settings.label }}</span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
      {%- if section.settings.link_label != blank and section.settings.link_url != blank -%}
        {% render 'sf2-button', preset: 'text_link', label: section.settings.link_label, url: section.settings.link_url %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 History Feature",
  "tag": "section",
  "class": "sf2-history-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "history" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "label_eyebrow", "label": "Image label eyebrow", "default": "Dedicated history page" },
    { "type": "text", "id": "label_heading", "label": "Image label heading", "default": "The complete archive belongs on its own immersive template." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "175 years of Seppeltsfield" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "An Australian story shaped by time." },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Explore the Full History" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "soft_blue", "options": [
      { "value": "soft_blue", "label": "Soft Blue" }, { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "1851" },
        { "type": "text", "id": "label", "label": "Label", "default": "Founded in the Barossa" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 History Feature" }]
}
{% endschema %}
