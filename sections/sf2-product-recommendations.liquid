{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-collection.css' | asset_url | stylesheet_tag }}
{{ 'sf2-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-recommendations.js' | asset_url }}" type="module"></script>

{%- liquid
  assign view_all_collection = collection
  if view_all_collection == blank
    for coll in product.collections
      if coll.handle != 'all'
        assign view_all_collection = coll
        break
      endif
    endfor
  endif

  assign products_to_render = recommendations.products
  if products_to_render == blank or products_to_render.size == 0
    assign products_to_render = collections.all.products | reject: 'id', product.id
  endif
  assign products_limit = section.settings.product_count
-%}

<product-recommendations
  id="sf2-product-recommendations-{{ section.id }}"
  class="sf2-product-recs"
  data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.product_count }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-intent="{{ section.settings.recommendation_type }}"
  data-recommendations-performed="{{ recommendations.performed }}"
  {{ section.shopify_attributes }}
>
  <section class="sf2-product-recs__inner sf2-section">
    <div class="sf2-wrap">
      <div class="sf2-section-head sf2-product-recs__head">
        <div>
          {%- if section.settings.eyebrow != blank -%}
            {% render 'sf2-eyebrow', text: section.settings.eyebrow, brand: true %}
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="sf2-serif sf2-section-head__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.show_view_all and view_all_collection != blank -%}
          <a href="{{ view_all_collection.url }}" class="sf2-btn sf2-btn--text_link">{{ section.settings.view_all_label }}</a>
        {%- endif -%}
      </div>

      {%- if products_to_render != blank and products_to_render.size > 0 -%}
        <div class="sf2-product-recs__grid">
          {%- for card_product in products_to_render limit: products_limit -%}
            <div class="sf2-product-recs__item">
              {% render 'sf2-product-card', product: card_product, section: section %}
            </div>
          {%- endfor -%}
        </div>
      {%- elsif recommendations.performed == false -%}
        <p class="sf2-product-recs__loading" role="status">Loading recommendations…</p>
      {%- endif -%}
    </div>
  </section>
</product-recommendations>

{% schema %}
{
  "name": "SF2 Product Recs",
  "tag": "section",
  "class": "sf2-product-recs-section",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "You may also enjoy" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Related wines." },
    { "type": "range", "id": "product_count", "label": "Product count", "min": 2, "max": 8, "step": 1, "default": 4 },
    {
      "type": "select",
      "id": "recommendation_type",
      "label": "Recommendation type",
      "options": [
        { "value": "related", "label": "Related products" },
        { "value": "complementary", "label": "Complementary products" }
      ],
      "default": "related"
    },
    { "type": "checkbox", "id": "show_view_all", "label": "Show view-all link", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View-all label", "default": "View all wines" },
    { "type": "header", "content": "Product card" },
    { "type": "checkbox", "id": "show_second_image_hover", "label": "Show second image on hover", "default": true },
    { "type": "text", "id": "add_to_cart_label", "label": "Add to cart label", "default": "Add to Cart" },
    { "type": "text", "id": "choose_options_label", "label": "Choose options label", "default": "Choose options" }
  ],
  "presets": [{ "name": "SF2 Product Recs" }]
}
{% endschema %}
