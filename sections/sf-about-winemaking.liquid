{{ 'sf-about.css' | asset_url | stylesheet_tag }}
{%- assign mobile_image = section.settings.mobile_image | default: section.settings.desktop_image -%}
<section id="SfAboutWinemaking-{{ section.id }}" class="sf-about-winemaking" style="--sf-bg:{{ section.settings.background_color }};--sf-head:{{ section.settings.heading_color }};--sf-text:{{ section.settings.text_color }};--sf-muted:{{ section.settings.muted_color }};--sf-pad-top-d:{{ section.settings.padding_top_desktop }}px;--sf-pad-bottom-d:{{ section.settings.padding_bottom_desktop }}px;--sf-pad-top-m:{{ section.settings.padding_top_mobile }}px;--sf-pad-bottom-m:{{ section.settings.padding_bottom_mobile }}px;">
  <div class="sf-about-container">
    <div class="sf-about-winemaking__layout{% if section.settings.reverse_columns %} is-reverse{% endif %}">
      <div class="sf-about-winemaking__media">
        {% if section.settings.desktop_image != blank %}
          {{ section.settings.desktop_image | image_url: width: 1400 | image_tag: class: 'sf-about-winemaking__img sf-about-winemaking__img--desktop', loading: 'lazy', widths: '550,750,990,1200,1400', sizes: '(min-width:990px) 50vw, 100vw', alt: section.settings.desktop_image.alt }}
          {{ mobile_image | image_url: width: 1000 | image_tag: class: 'sf-about-winemaking__img sf-about-winemaking__img--mobile', loading: 'lazy', widths: '375,550,750,900,1000', sizes: '(max-width:989px) 100vw, 1px', alt: mobile_image.alt }}
        {% endif %}
      </div>
      <div class="sf-about-winemaking__content">
        {% if section.settings.eyebrow != blank %}<p class="sf-about-winemaking__eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
        {% if section.settings.heading != blank %}<h2 class="sf-about-winemaking__heading">{{ section.settings.heading | newline_to_br }}</h2>{% endif %}
        {% if section.settings.copy != blank %}<div class="sf-about-winemaking__copy">{{ section.settings.copy | newline_to_br }}</div>{% endif %}
        {% if section.settings.link_label != blank and section.settings.link_url != blank %}<a class="sf-about-link" href="{{ section.settings.link_url }}">{{ section.settings.link_label }}</a>{% endif %}
      </div>
    </div>
  </div>
</section>
{% stylesheet %}
.sf-about-winemaking{background:var(--sf-bg);padding-top:var(--sf-pad-top-d);padding-bottom:var(--sf-pad-bottom-d)}.sf-about-winemaking__layout{display:grid;grid-template-columns:minmax(0,6fr) minmax(0,5fr);gap:1rem}.sf-about-winemaking__layout.is-reverse .sf-about-winemaking__media{order:2}.sf-about-winemaking__layout.is-reverse .sf-about-winemaking__content{order:1}.sf-about-winemaking__media{min-height:320px}.sf-about-winemaking__img{width:100%;height:100%;object-fit:cover}.sf-about-winemaking__img--mobile{display:none}.sf-about-winemaking__content{display:grid;align-content:center}.sf-about-winemaking__eyebrow{margin:0;color:var(--sf-muted);text-transform:uppercase;letter-spacing:.14em;font-size:.75rem}.sf-about-winemaking__heading{margin:.55rem 0 0;color:var(--sf-head);font-size:clamp(1.8rem,2.7vw,3rem);line-height:1.04}.sf-about-winemaking__copy{margin:.8rem 0 1rem;color:var(--sf-text)}@media(max-width:989px){.sf-about-winemaking{padding-top:var(--sf-pad-top-m);padding-bottom:var(--sf-pad-bottom-m)}.sf-about-winemaking__layout{grid-template-columns:1fr}.sf-about-winemaking__img--desktop{display:none}.sf-about-winemaking__img--mobile{display:block}}
{% endstylesheet %}
{% schema %}
{"name":"SF About Wine","tag":"section","class":"sf-about-section","settings":[{"type":"paragraph","content":"Search files: Fiona Donald Chief Winemaker, fiona-donald, Our Winemaking"},{"type":"image_picker","id":"desktop_image","label":"Desktop image"},{"type":"image_picker","id":"mobile_image","label":"Mobile image"},{"type":"checkbox","id":"reverse_columns","label":"Reverse columns","default":false},{"type":"text","id":"eyebrow","label":"Eyebrow","default":"OUR WINEMAKING"},{"type":"textarea","id":"heading","label":"Heading","default":"Guided by time.\nDefined by place."},{"type":"textarea","id":"copy","label":"Copy","default":"Our winemaking is both an art and a responsibility - to the land, our heritage and future generations.\n\nGuided by Chief Winemaker Fiona Donald, who has led Seppeltsfield's cellar since 2009 with more than 30 years across the Barossa's most respected wineries - including Penfolds, Hardys and Barossa Valley Estate - every wine we produce reflects the Barossa, our commitment to quality and a philosophy that values patience above all else."},{"type":"text","id":"link_label","label":"Link label","default":"MEET OUR WINEMAKING TEAM"},{"type":"url","id":"link_url","label":"Link URL"},{"type":"color","id":"background_color","label":"Background","default":"#F4F1EA"},{"type":"color","id":"heading_color","label":"Heading color","default":"#111315"},{"type":"color","id":"text_color","label":"Text color","default":"#424242"},{"type":"color","id":"muted_color","label":"Muted color","default":"#6D4B35"},{"type":"range","id":"padding_top_desktop","label":"Desktop padding top","min":0,"max":200,"step":4,"unit":"px","default":56},{"type":"range","id":"padding_bottom_desktop","label":"Desktop padding bottom","min":0,"max":200,"step":4,"unit":"px","default":56},{"type":"range","id":"padding_top_mobile","label":"Mobile padding top","min":0,"max":200,"step":4,"unit":"px","default":32},{"type":"range","id":"padding_bottom_mobile","label":"Mobile padding bottom","min":0,"max":200,"step":4,"unit":"px","default":32}],"presets":[{"name":"SF About Wine","category":"Seppeltsfield"}]}
{% endschema %}
