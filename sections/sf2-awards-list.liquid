{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}
{%- assign anchor_id = section.settings.section_anchor_id | default: 'recognition' -%}

<section id="{{ anchor_id }}" class="sf2-awards sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-awards__grid">
    <div class="sf2-awards__copy">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
      {%- if section.settings.link_label != blank and section.settings.link_url != blank -%}
        {% render 'sf2-button', preset: 'text_link', label: section.settings.link_label, url: section.settings.link_url %}
      {%- endif -%}
    </div>
    <div class="sf2-awards__list">
      {%- for block in section.blocks -%}
        <a class="sf2-awards__row" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          <time datetime="{{ block.settings.year_label }}">{{ block.settings.year_label }}</time>
          <b>{{ block.settings.title }}</b>
          {% render 'sf2-icon', icon: 'arrow-right' %}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Awards List",
  "tag": "section",
  "class": "sf2-awards-section",
  "settings": [
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "recognition" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Awards & recognition" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A legacy recognised around the world." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Rather than displaying every award as a logo wall, this section highlights major milestones and links to the complete awards archive." },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View all recognition" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "light", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "award",
      "name": "Award",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "year_label", "label": "Year or label", "default": "2026" },
        { "type": "text", "id": "title", "label": "Title", "default": "Major estate recognition or award title" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Awards List" }]
}
{% endschema %}
