{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-product.css' | asset_url | stylesheet_tag }}

<section id="reviews" class="sf2-product-reviews sf2-section" {{ section.shopify_attributes }}>
  <div class="sf2-wrap">
    {%- if section.settings.heading != blank -%}
      <h2 class="sf2-serif sf2-product-reviews__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="sf2-product-reviews__apps">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            <div class="sf2-product-reviews__app" {{ block.shopify_attributes }}>
              {% render block %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Product Reviews",
  "tag": "section",
  "class": "sf2-product-reviews-section",
  "enabled_on": { "templates": ["product"] },
  "blocks": [{ "type": "@app" }],
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Reviews" }
  ],
  "presets": [{ "name": "SF2 Product Reviews" }]
}
{% endschema %}
