{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-home.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}

<section id="history" class="sf2-history sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap sf2-history__grid">
    <div class="sf2-history__copy">
      {% render 'sf2-eyebrow', text: section.settings.eyebrow %}
      <h2 class="sf2-serif">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<div>{{ section.settings.body }}</div>{%- endif -%}
      {%- if section.settings.button_label != blank -%}
        {% render 'sf2-button', preset: 'primary_dark', label: section.settings.button_label, url: section.settings.button_url, class: 'sf2-history__btn' %}
      {%- endif -%}
      <div class="sf2-history__chapters">
        {%- for block in section.blocks -%}
          <div class="sf2-history__chapter" {{ block.shopify_attributes }}>
            <time>{{ block.settings.year_label }}</time>
            <b>{{ block.settings.title }}</b>
            <span>{% render 'sf2-icon', icon: 'arrow-right', size: 18 %}</span>
          </div>
        {%- endfor -%}
      </div>
    </div>
    <div class="sf2-history__image">
      {%- if section.settings.image != blank -%}
        {% render 'sf2-picture', image: section.settings.image, sizes: '(min-width: 990px) 46vw, 100vw' %}
      {%- endif -%}
      {%- if section.settings.callout_text != blank -%}
        <div class="sf2-history__callout">{{ section.settings.callout_text }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 History Preview",
  "tag": "section",
  "class": "sf2-history-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "A dedicated history destination" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "175 years deserves more than a timeline strip." },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore the Full History" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "callout_text", "label": "Callout text", "default": "The full history becomes its own immersive page" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "ivory", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }, { "value": "editorial", "label": "Editorial" }
    ]}
  ],
  "blocks": [
    {
      "type": "chapter",
      "name": "Chapter",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "year_label", "label": "Year", "default": "1851" },
        { "type": "text", "id": "title", "label": "Title", "default": "Foundation and the Seppelt family" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 History Preview" }]
}
{% endschema %}
