<section class="spp-section" {% render 'section-style-attributes' %}>
  <div class="section section--{{ section.settings.section_width }}">
    <div class="spp-newsletter" data-reveal>
      <div>
        {% if section.settings.eyebrow != blank %}{% render 'heading-eyebrow', text: section.settings.eyebrow %}{% endif %}
        <h2 style="margin-top:14px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
      </div>
      {% form 'customer', class: 'spp-newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required>
        <button type="submit" class="seppeltsfield-button seppeltsfield-button--outline">{{ section.settings.button_label }}</button>
      {% endform %}
    </div>
  </div>
</section>

{% stylesheet %}
  .spp-newsletter { display:flex; gap:36px; justify-content: space-between; align-items: end; flex-wrap: wrap; border-bottom: 1px solid var(--spp-line); padding-bottom: 16px; }
  .spp-newsletter-form { display:flex; gap: 12px; min-width: 340px; max-width: 520px; width: 100%; }
  .spp-newsletter-form input { flex:1; border: 0; border-bottom: 1px solid var(--spp-line); background: transparent; padding: 10px 4px; font: inherit; }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Newsletter" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the Seppeltsfield mailing list for cellar releases and estate news." },
    { "type": "text", "id": "placeholder", "label": "Email placeholder", "default": "Email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#0b0c0d" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#f5f7f8" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#f5f7f8" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 22, "max": 48, "step": 2, "unit": "px", "default": 28 },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 20, "step": 1, "unit": "px", "default": 16 },
    { "type": "select", "id": "padding_top", "label": "Top spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "md" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "md" },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{ "value": "page-width", "label": "Page" }, { "value": "full-width", "label": "Full" }], "default": "page-width" }
  ],
  "presets": [{ "name": "Newsletter CTA" }]
}
{% endschema %}
