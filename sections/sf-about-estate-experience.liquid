{{ 'sf-about.css' | asset_url | stylesheet_tag }}
<section id="SfAboutEstateExperience-{{ section.id }}" class="sf-about-estate-experience" style="--sf-bg:{{ section.settings.background_color }};--sf-text:{{ section.settings.text_color }};--sf-accent:{{ section.settings.accent_color }};--sf-gap:{{ section.settings.card_gap }}px;--sf-pad-top-d:{{ section.settings.padding_top_desktop }}px;--sf-pad-bottom-d:{{ section.settings.padding_bottom_desktop }}px;--sf-pad-top-m:{{ section.settings.padding_top_mobile }}px;--sf-pad-bottom-m:{{ section.settings.padding_bottom_mobile }}px;">
  <div class="sf-about-container">
    <div class="sf-about-estate-experience__layout">
      <div class="sf-about-estate-experience__intro">
        {% if section.settings.eyebrow != blank %}<p class="sf-about-estate-experience__eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
        {% if section.settings.heading != blank %}<h2 class="sf-about-estate-experience__heading">{{ section.settings.heading | newline_to_br }}</h2>{% endif %}
        {% if section.settings.copy != blank %}<p class="sf-about-estate-experience__copy">{{ section.settings.copy }}</p>{% endif %}
        {% if section.settings.link_label != blank and section.settings.link_url != blank %}<a class="sf-about-link" href="{{ section.settings.link_url }}">{{ section.settings.link_label }}</a>{% endif %}
      </div>
      <div class="sf-about-estate-experience__cards">
        {% for block in section.blocks %}
          {%- assign mobile_image = block.settings.mobile_image | default: block.settings.image -%}
          <article class="sf-about-estate-experience__card" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1000 | image_tag: class: 'sf-about-estate-experience__img sf-about-estate-experience__img--desktop', loading: 'lazy', widths: '375,550,750,990,1000', sizes: '(min-width:990px) 18vw, 84vw', alt: block.settings.heading }}
              {{ mobile_image | image_url: width: 900 | image_tag: class: 'sf-about-estate-experience__img sf-about-estate-experience__img--mobile', loading: 'lazy', widths: '375,550,750,900', sizes: '(max-width:989px) 84vw, 1px', alt: block.settings.heading }}
            {% endif %}
            <div class="sf-about-estate-experience__overlay"></div>
            <div class="sf-about-estate-experience__content">
              {% if block.settings.heading != blank %}<h3>{{ block.settings.heading }}</h3>{% endif %}
              {% if block.settings.link_label != blank and block.settings.link_url != blank %}<a class="sf-about-link" href="{{ block.settings.link_url }}">{{ block.settings.link_label }}</a>{% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
{% stylesheet %}
.sf-about-estate-experience{background:var(--sf-bg);padding-top:var(--sf-pad-top-d);padding-bottom:var(--sf-pad-bottom-d)}.sf-about-estate-experience__layout{display:flex;gap:var(--sf-gap)}.sf-about-estate-experience__intro{flex:0 0 clamp(220px,22vw,340px);color:var(--sf-text)}.sf-about-estate-experience__eyebrow{margin:0;color:var(--sf-accent);text-transform:uppercase;letter-spacing:.14em;font-size:.75rem}.sf-about-estate-experience__heading{margin:.5rem 0 0;font-size:clamp(1.7rem,2.6vw,2.8rem);line-height:1.04}.sf-about-estate-experience__copy{margin:.8rem 0 1rem}.sf-about-estate-experience__cards{display:flex;gap:var(--sf-gap);flex:1}.sf-about-estate-experience__card{position:relative;min-width:0;flex:1;min-height:280px;overflow:hidden}.sf-about-estate-experience__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.sf-about-estate-experience__img--mobile{display:none}.sf-about-estate-experience__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(5,5,5,.15),rgba(5,5,5,.74))}.sf-about-estate-experience__content{position:relative;z-index:2;color:#fff;padding:.8rem;display:grid;align-content:end;min-height:100%}.sf-about-estate-experience__content h3{margin:0;font-size:.92rem;text-transform:uppercase;letter-spacing:.08em}@media(max-width:989px){.sf-about-estate-experience{padding-top:var(--sf-pad-top-m);padding-bottom:var(--sf-pad-bottom-m)}.sf-about-estate-experience__layout{display:grid;grid-template-columns:1fr}.sf-about-estate-experience__cards{display:grid;grid-auto-flow:column;grid-auto-columns:minmax(84vw,1fr);overflow-x:auto;scroll-snap-type:x mandatory}.sf-about-estate-experience__card{scroll-snap-align:start}.sf-about-estate-experience__img--desktop{display:none}.sf-about-estate-experience__img--mobile{display:block}}
{% endstylesheet %}
{% schema %}
{"name":"SF About Estate","tag":"section","class":"sf-about-section","max_blocks":8,"settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"THE ESTATE EXPERIENCE"},{"type":"textarea","id":"heading","label":"Heading","default":"More than wine.\nA place to belong."},{"type":"textarea","id":"copy","label":"Copy","default":"Taste, dine, stay and celebrate in the heart of the Barossa Valley."},{"type":"text","id":"link_label","label":"Link label","default":"EXPLORE EXPERIENCES"},{"type":"url","id":"link_url","label":"Link URL"},{"type":"color","id":"background_color","label":"Background","default":"#050505"},{"type":"color","id":"text_color","label":"Text color","default":"#FFFFFF"},{"type":"color","id":"accent_color","label":"Accent color","default":"#47A8DF"},{"type":"range","id":"card_gap","label":"Card gap","min":8,"max":36,"step":2,"unit":"px","default":8},{"type":"range","id":"padding_top_desktop","label":"Desktop padding top","min":0,"max":200,"step":4,"unit":"px","default":28},{"type":"range","id":"padding_bottom_desktop","label":"Desktop padding bottom","min":0,"max":200,"step":4,"unit":"px","default":28},{"type":"range","id":"padding_top_mobile","label":"Mobile padding top","min":0,"max":200,"step":4,"unit":"px","default":20},{"type":"range","id":"padding_bottom_mobile","label":"Mobile padding bottom","min":0,"max":200,"step":4,"unit":"px","default":20}],"blocks":[{"type":"experience_card","name":"Experience card","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"image_picker","id":"mobile_image","label":"Mobile image"},{"type":"text","id":"heading","label":"Heading","default":"CENTENNIAL CELLAR"},{"type":"text","id":"link_label","label":"Link label","default":"EXPLORE"},{"type":"url","id":"link_url","label":"Link URL"}]}],"presets":[{"name":"SF About Estate","category":"Seppeltsfield","blocks":[{"type":"experience_card","settings":{"heading":"CENTENNIAL CELLAR"}},{"type":"experience_card","settings":{"heading":"DINE AT FINO"}},{"type":"experience_card","settings":{"heading":"STAY THE LODGE"}},{"type":"experience_card","settings":{"heading":"EXPERIENCES ON THE ESTATE"}}]}]}
{% endschema %}
