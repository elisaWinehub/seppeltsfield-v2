<section class="spp-section" {% render 'section-style-attributes' %}>
  <div class="section section--{{ section.settings.section_width }}">
    <div class="spp-hours-grid" data-reveal>
      <div>
        {% if section.settings.eyebrow != blank %}{% render 'heading-eyebrow', text: section.settings.eyebrow %}{% endif %}
        <h2 style="margin-top:14px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
        <table style="width:100%;margin-top:22px;border-collapse:collapse;">
          {% for block in section.blocks %}
            {% if block.type == 'hour' %}
              <tr style="border-top:1px solid var(--spp-line);" {{ block.shopify_attributes }}>
                <td style="padding:14px 10px;">{{ block.settings.label }}</td>
                <td style="padding:14px 10px;text-align:right;color:var(--spp-text-color);">{{ block.settings.value }}</td>
              </tr>
            {% endif %}
          {% endfor %}
        </table>
      </div>
      <div class="spp-hours-grid__media">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.heading }}
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .spp-hours-grid { display:grid; grid-template-columns:6fr 4fr; gap: 64px; align-items: start; }
  .spp-hours-grid__media img, .spp-hours-grid__media svg { width: 100%; height: auto; display: block; }
  @media screen and (max-width: 989px) { .spp-hours-grid { grid-template-columns: 1fr; gap: 24px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Hours and contact",
  "blocks": [
    { "type": "hour", "name": "Hour row", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Cellar door" },
      { "type": "text", "id": "value", "label": "Value", "default": "10am - 5pm daily" }
    ] }
  ],
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Hours and location" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Seppeltsfield Road, Seppeltsfield SA 5355" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f1f2f1" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#0e1012" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#53575b" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 22, "max": 56, "step": 2, "unit": "px", "default": 36 },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 13, "max": 20, "step": 1, "unit": "px", "default": 16 },
    { "type": "select", "id": "padding_top", "label": "Top spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "lg" },
    { "type": "select", "id": "padding_bottom", "label": "Bottom spacing", "options": [{ "value": "sm", "label": "Small" }, { "value": "md", "label": "Medium" }, { "value": "lg", "label": "Large" }, { "value": "xl", "label": "Extra large" }], "default": "lg" },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{ "value": "page-width", "label": "Page" }, { "value": "full-width", "label": "Full" }], "default": "page-width" }
  ],
  "presets": [{ "name": "Hours and contact", "blocks": [{ "type": "hour" }, { "type": "hour" }, { "type": "hour" }] }]
}
{% endschema %}
