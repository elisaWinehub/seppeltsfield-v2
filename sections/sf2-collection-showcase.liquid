{% render 'sf2-fonts' %}
{{ 'sf2-tokens.css' | asset_url | stylesheet_tag }}
{{ 'sf2-components.css' | asset_url | stylesheet_tag }}
{{ 'sf2-inner-pages.css' | asset_url | stylesheet_tag }}

{%- capture section_style -%}{% render 'sf2-scheme-vars', color_scheme: section.settings.color_scheme, spacing_preset: section.settings.spacing_preset %}{%- endcapture -%}

<section class="sf2-showcase sf2-section" style="{{ section_style | strip }}">
  <div class="sf2-wrap">
    {% render 'sf2-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      body: section.settings.body
    %}
    <div class="sf2-showcase__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign card_title = block.settings.title_override
          if card_title == blank and block.settings.collection != blank
            assign card_title = block.settings.collection.title
          endif
          assign card_url = block.settings.url_override
          if card_url == blank and block.settings.collection != blank
            assign card_url = block.settings.collection.url
          endif
        -%}
        <a class="sf2-showcase__card" href="{{ card_url | default: '#' }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {% render 'sf2-picture', image: block.settings.image, sizes: '(min-width: 990px) 50vw, 100vw' %}
          {%- elsif block.settings.collection != blank and block.settings.collection.image != blank -%}
            {% render 'sf2-picture', image: block.settings.collection.image, sizes: '(min-width: 990px) 50vw, 100vw' %}
          {%- endif -%}
          <div class="sf2-showcase__copy">
            <span>Collection {{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            {%- if card_title != blank -%}<h3>{{ card_title }}</h3>{%- endif -%}
            {%- if block.settings.body != blank -%}<p>{{ block.settings.body }}</p>{%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SF2 Collection Showcase",
  "tag": "section",
  "class": "sf2-showcase-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Explore the range" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by collection." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Browse the key Seppeltsfield collections and continue into the dedicated Shopify collection pages." },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "ivory", "options": [
      { "value": "light", "label": "Light" }, { "value": "ivory", "label": "Ivory" }
    ]},
    { "type": "select", "id": "spacing_preset", "label": "Spacing", "default": "spacious", "options": [
      { "value": "standard", "label": "Standard" }, { "value": "spacious", "label": "Spacious" }
    ]}
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "limit": 6,
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title_override", "label": "Title override" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "url", "id": "url_override", "label": "URL override" }
      ]
    }
  ],
  "presets": [{ "name": "SF2 Collection Showcase" }]
}
{% endschema %}
