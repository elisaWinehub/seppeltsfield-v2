{{ 'sf-collection.css' | asset_url | stylesheet_tag }}

<section
  class="sf-collection-service-strip"
  style="
    --sf-services-columns: {{ section.settings.columns }};
    --sf-services-icon-size: {{ section.settings.icon_size }}px;
    --sf-collection-services-padding-top: {{ section.settings.padding_top }}px;
    --sf-collection-services-padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background_color }};
  "
>
  <div class="sf-collection-service-strip__grid">
    {% for block in section.blocks %}
      <div class="sf-collection-service-strip__item" {{ block.shopify_attributes }}>
        {% if block.settings.custom_icon != blank %}
          {{
            block.settings.custom_icon
            | image_url: width: 64
            | image_tag:
              class: 'sf-collection-service-strip__icon',
              widths: '24, 36, 48, 64',
              sizes: '32px',
              loading: 'lazy',
              alt: block.settings.heading
          }}
        {% else %}
          <span class="sf-collection-service-strip__icon" aria-hidden="true">
            {% case block.settings.icon %}
              {% when 'delivery' %}
                {{ 'icon-checkmark.svg' | inline_asset_content }}
              {% when 'gift' %}
                {{ 'icon-discount.svg' | inline_asset_content }}
              {% when 'secure' %}
                {{ 'icon-checkmark-burst.svg' | inline_asset_content }}
              {% else %}
                {{ 'icon-shopify.svg' | inline_asset_content }}
            {% endcase %}
          </span>
        {% endif %}

        <div>
          {% if block.settings.heading != blank %}
            {% if block.settings.link != blank %}
              <h3><a href="{{ block.settings.link }}">{{ block.settings.heading }}</a></h3>
            {% else %}
              <h3>{{ block.settings.heading }}</h3>
            {% endif %}
          {% endif %}
          {% if block.settings.copy != blank %}
            <p>{{ block.settings.copy }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "SF Collection Services",
  "class": "sf-collection-section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "max_blocks": 8,
  "settings": [
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 4, "step": 1, "default": 4 },
    { "type": "range", "id": "icon_size", "label": "Icon size", "min": 16, "max": 40, "step": 1, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 24 }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Built-in icon",
          "options": [
            { "value": "delivery", "label": "Delivery" },
            { "value": "gift", "label": "Gift" },
            { "value": "secure", "label": "Secure" },
            { "value": "quality", "label": "Quality" }
          ],
          "default": "delivery"
        },
        { "type": "image_picker", "id": "custom_icon", "label": "Custom image icon" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "NATIONWIDE DELIVERY" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Fast and reliable delivery across Australia" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SF Collection Service Strip",
      "category": "Seppeltsfield",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "icon": "delivery",
            "heading": "NATIONWIDE DELIVERY",
            "copy": "Fast and reliable delivery across Australia"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "gift",
            "heading": "GIFT PACKAGING",
            "copy": "Beautifully packaged for any occasion"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "secure",
            "heading": "SECURE PAYMENTS",
            "copy": "Safe and secure checkout guaranteed"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "quality",
            "heading": "ESTATE QUALITY",
            "copy": "Award-winning wines from our historic estate"
          }
        }
      ]
    }
  ]
}
{% endschema %}
