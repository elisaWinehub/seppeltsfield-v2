        "secondary_image": "shopify://shop_images/1878-Centennial-Cellar.jpg",
        "note_eyebrow": "Est. 1851",
        "note_heading": "Seven generations of Barossa history.",
        "color_scheme": "light",
        "spacing_preset": "spacious"
      }
